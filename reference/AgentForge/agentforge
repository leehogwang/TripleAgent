def _default_codex_hint_path() -> Path:
    if os.name == "nt":
        return Path.home() / "AppData" / "Roaming" / "npm" / "codex.cmd"
    return Path.home() / ".npm-global" / "bin" / "codex"


_CODEX_BIN_HINT = _default_codex_hint_path()
_CODEX_BIN_CACHE: Path | None = None
_BWRAP_ARGV0_SUPPORTED: bool | None = None


def _npm_global_bin_dir() -> Path | None:
    npm_candidates = ["npm.cmd", "npm"] if os.name == "nt" else ["npm"]
    for npm_bin in npm_candidates:
        try:
            result = subprocess.run(
                [npm_bin, "prefix", "-g"],
                capture_output=True,
                text=True,
                timeout=5,
            )
        except Exception:
            continue
        if result.returncode != 0:
            continue
        prefix = (result.stdout or "").strip().splitlines()
        if not prefix:
            continue
        base = Path(prefix[-1].strip()).expanduser()
        return base if os.name == "nt" else (base / "bin")
    return None


def _iter_codex_candidates():
    seen: set[str] = set()

    def _yield(pathlike) -> None:
        if not pathlike:
            return
        try:
            path = Path(pathlike).expanduser()
        except Exception:
            return
        key = str(path)
        if key in seen:
            return
        seen.add(key)
        yield path

    env_path = os.environ.get("CODEX_BIN")
    if env_path:
        yield from _yield(env_path)

    finder = "where" if os.name == "nt" else "which"
    names = ["codex.cmd", "codex.exe", "codex"] if os.name == "nt" else ["codex"]
    for name in names:
        try:
            result = subprocess.run(
                [finder, name],
                capture_output=True,
                text=True,
                timeout=3,
            )
        except Exception:
            continue
        if result.returncode != 0:
            continue
        for line in (result.stdout or "").splitlines():
            yield from _yield(line.strip())

    npm_bin_dir = _npm_global_bin_dir()
    if npm_bin_dir is not None:
        for name in names:
            yield from _yield(npm_bin_dir / name)

    home = Path.home()
    if os.name == "nt":
        for candidate in (
            home / "AppData" / "Roaming" / "npm" / "codex.cmd",
            home / "AppData" / "Roaming" / "npm" / "codex.exe",
            home / ".npm-global" / "bin" / "codex.cmd",
            home / ".npm-global" / "bin" / "codex",
        ):
            yield from _yield(candidate)
    else:
        for candidate in (
            home / ".npm-global" / "bin" / "codex",
            home / ".local" / "bin" / "codex",
        ):
            yield from _yield(candidate)


def _refresh_codex_bin() -> Path | None:
    global _CODEX_BIN_CACHE
    for candidate in _iter_codex_candidates():
        try:
            if candidate.exists():
                _CODEX_BIN_CACHE = candidate
                return candidate
        except OSError:
            continue
    _CODEX_BIN_CACHE = None
    return None


def _get_codex_bin() -> Path | None:
    global _CODEX_BIN_CACHE
    if _CODEX_BIN_CACHE is not None:
        try:
            if _CODEX_BIN_CACHE.exists():
                return _CODEX_BIN_CACHE
        except OSError:
            pass
    return _refresh_codex_bin()


def _codex_display_path() -> str:
    return str(_get_codex_bin() or _CODEX_BIN_HINT)


def _supports_bwrap_argv0() -> bool:
    global _BWRAP_ARGV0_SUPPORTED
    if _BWRAP_ARGV0_SUPPORTED is not None:
        return _BWRAP_ARGV0_SUPPORTED
    if os.name == "nt":
        _BWRAP_ARGV0_SUPPORTED = True
        return True
    try:
        result = subprocess.run(
            ["bwrap", "--help"],
            capture_output=True,
            text=True,
            timeout=3,
        )
        help_text = f"{result.stdout or ''}\n{result.stderr or ''}"
        _BWRAP_ARGV0_SUPPORTED = "--argv0" in help_text
    except Exception:
        _BWRAP_ARGV0_SUPPORTED = False
    return _BWRAP_ARGV0_SUPPORTED


def _codex_exec_sandbox_args(sandbox: str) -> list[str]:
    if sandbox == "danger-full-access":
        return ["--dangerously-bypass-approvals-and-sandbox"]
    if sandbox in {"workspace-write", "read-only"}:
        if _supports_bwrap_argv0():
            return ["--sandbox", sandbox]
        # Older bubblewrap releases reject --argv0, which breaks every shell
        # command inside codex exec. Fall back to the unsandboxed mode that
        # matches AgentForge's legacy local-shell behavior.
        return ["--dangerously-bypass-approvals-and-sandbox"]
    return []

