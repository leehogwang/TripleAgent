def _get_pkg_info() -> "tuple[str, str] | None":
    """
    현재 설치 방식에 따라 (현재버전, 설치방식) 반환.
    - npm 설치: package.json에서 버전 읽기 → ('0.1.32', 'npm')
    - git 클론: git HEAD SHA → ('abc1234', 'git')
    """
    script_dir = Path(__file__).resolve().parent

    # npm 설치: 스크립트 옆에 package.json 존재
    pkg_json = script_dir / "package.json"
    if pkg_json.exists():
        try:
            data = json.loads(pkg_json.read_text())
            version = data.get("version", "")
            if version:
                return version, "npm"
        except Exception:
            pass

    # git 클론: .git 디렉토리 탐색
    src_dir = _find_source_repo()
    if src_dir:
        try:
            sha = subprocess.check_output(
                ["git", "rev-parse", "HEAD"], cwd=src_dir, stderr=subprocess.DEVNULL
            ).decode().strip()
            return sha, "git"
        except Exception:
            pass

    return None


def _check_and_update() -> None:
    """시작 시 업데이트 확인 후 사용자에게 선택지 제공 (npm/git 모두 지원)."""
    pkg_info = _get_pkg_info()
    if pkg_info is None:
        return

    current_ver, install_type = pkg_info

    if install_type == "npm":
        # npm registry에서 최신 버전 확인
        try:
            resp = _requests.get(
                f"https://registry.npmjs.org/{_AGENTFORGE_NPM_PACKAGE}/latest",
                timeout=3,
            )
            latest_ver = resp.json()["version"]
        except Exception:
            return

        if current_ver == latest_ver:
            return  # 이미 최신

        display_cur = f"v{current_ver}"
        display_new = f"v{latest_ver}"
        update_cmd  = ["npm", "install", "-g", _AGENTFORGE_NPM_PACKAGE]

    else:  # git
        # GitHub API로 최신 commit 확인
        try:
            resp = _requests.get(
                f"https://api.github.com/repos/{_AGENTFORGE_REPO}/commits/{_AGENTFORGE_BRANCH}",
                headers={"User-Agent": "agentforge-updater"},
                timeout=3,
            )
            latest_ver = resp.json()["sha"]
        except Exception:
            return

        if current_ver == latest_ver:
            return  # 이미 최신

        display_cur = current_ver[:8]
        display_new = latest_ver[:8]
        update_cmd  = None  # git pull 사용

    # 업데이트 프롬프트
    console.print()
    console.print(
        f"[bold cyan]✨ AgentForge 업데이트 가능[/bold cyan]  "
