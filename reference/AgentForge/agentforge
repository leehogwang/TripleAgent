def _read_log_tail(log_path: str, lines: int = 200) -> str:
    """파일 끝에서 N줄 효율적으로 읽기 (최대 32KB seek)."""
    try:
        p = Path(log_path)
        if not p.exists():
            return "(log file not found)"
        size = p.stat().st_size
        with open(log_path, 'rb') as f:
            if size > 32768:
                f.seek(-32768, 2)
                raw = f.read()[1:]
            else:
                raw = f.read()
        text = raw.decode('utf-8', errors='replace')
        return "\n".join(text.splitlines()[-lines:])
    except Exception as e:
        return f"(error reading log: {e})"


def _is_proc_alive(pid: int, proc) -> bool:
    if proc is not None:
        return proc.poll() is None
    try:
        os.kill(pid, 0)
        return True
    except (ProcessLookupError, PermissionError):
        return False




def _build_monitor_prompt(goal: str, log_tail: str, pid: int,
                           elapsed: float, poll_count: int,
                           command: str = "") -> str:
    return "\n".join([
        f"TRAINING GOAL: {goal}",
        f"PID: {pid}  |  Elapsed: {int(elapsed // 60)}m {int(elapsed % 60)}s  |  Poll #{poll_count}",
        "",
        "TRAINING LOG (last 30 lines):",
        "─" * 60,
        log_tail.strip(),
        "─" * 60,
    ])


def _cleanup_bg(bg: dict) -> None:
    """백그라운드 job proc + log FD 정리."""
    proc = bg.get("proc")
    with _active_procs_lock:
        if proc:
            _active_procs.discard(proc)
    log_fd = getattr(proc, "_agentforge_log_fd", None) if proc else None
    if log_fd:
        try:
            log_fd.close()
        except Exception:
            pass


def _parse_monitor_decision(text: str) -> tuple[str, str]:
    """CONTINUE/ALERT 파싱 — 대시·공백 구분자도 허용."""
    first_line = text.strip().split('\n')[0].strip()
    for kw in ('ALERT', 'CONTINUE'):
        if first_line.upper().startswith(kw):
            rest = first_line[len(kw):].lstrip(' :—–-').strip()
            # ALERT: include full message as context for evaluator
            if kw == 'ALERT':
                full_rest = text.strip()[len(first_line):].strip()
                return kw, (rest + ('\n' + full_rest if full_rest else ''))
            return kw, rest
    return 'CONTINUE', f"(parse failed) {text[:200]}"


def _run_monitor_loop(bg: dict, goal: str, workdir: str, eval_model: str | None,
                      poll_sec: int, layout, live, worker_buf: deque,
                      eval_history: list, iteration: int, refresh) -> str:
    """
    poll_sec 마다 로그 확인 → 모니터 Evaluator 실행.
    반환: "DONE" | "KILL:<reason>" | "natural_exit" | "interrupted"
    """
    pid = bg["pid"]
    log_path = bg["log_path"]
    proc = bg.get("proc")

    while True:
        # poll_sec 대기 (100ms 단위로 인터럽트/자연종료 체크)
        deadline = time.time() + poll_sec
        proc_exited = False
        while time.time() < deadline:
            if _interrupt_event.is_set():
                _cleanup_bg(bg)
                return "interrupted"
            if not _is_proc_alive(pid, proc):
                worker_buf.append(f"[green]PID {pid} 자연 종료됨[/green]")
                proc_exited = True
                break
            refresh("worker", iteration)
            time.sleep(0.1)

        if _interrupt_event.is_set():
            _cleanup_bg(bg)
            return "interrupted"

        bg["poll_count"] += 1
        bg["last_poll_at"] = time.time()
        elapsed = time.time() - bg["started_at"]

        log_tail = _read_log_tail(log_path, lines=30)
        monitor_prompt = _build_monitor_prompt(goal, log_tail, pid, elapsed, bg["poll_count"],
                                               command=bg.get("command", ""))

        refresh("evaluator", iteration)
        monitor_profile = _detect_task_profile(goal, mode="code")
        eval_msg, _ = run_evaluator(monitor_prompt, workdir, eval_model,
                                    system_prompt=_compose_evaluator_system(monitor_profile, monitor=True),
                                    output_schema=_FAST_EVALUATOR_OUTPUT_SCHEMA,
                                    retry_invalid_json=True)
        eval_payload = _normalize_evaluator_payload(
            eval_msg,
            allow=("CONTINUE", "IMPROVE", "REDIRECT", "DONE"),
        )
        decision = eval_payload["decision"].upper()
        feedback = _decision_feedback_from_payload(eval_payload)

        eval_history.append({
            "iter": f"{iteration}.{bg['poll_count']}",
            "decision": decision,
            "feedback": feedback,
            "full_msg": eval_msg,
            "type": "monitor",
            "meta": eval_payload,
        })
        _append_memory_event(goal, {
            "event_type": "monitor_decision",
            "iter": f"{iteration}.{bg['poll_count']}",
            "decision": decision,
            "reason_type": eval_payload["reason_type"],
            "next_action": eval_payload["next_action"],
            "confidence": eval_payload["confidence"],
            "needs_long_run_monitor": eval_payload["needs_long_run_monitor"],
            "summary": eval_payload["summary"],
        })
        worker_buf.append(
            f"[cyan]Monitor #{bg['poll_count']}: {decision}"
            + (f" — {feedback[:80]}" if feedback else "")
            + "[/cyan]"
        )
        refresh("worker", iteration)

        if decision == "DONE":
            _cleanup_bg(bg)
            return "DONE"
        elif decision in ("REDIRECT", "IMPROVE"):
            # 평가자가 중단 판정 — 프로세스가 살아있으면 종료
            if _is_proc_alive(pid, proc):
                try:
                    if hasattr(os, 'killpg'):
                        os.killpg(os.getpgid(pid), _signal.SIGKILL)
                    else:
                        os.kill(pid, _signal.SIGTERM)
                    if proc:
                        proc.wait()
                except (ProcessLookupError, OSError):
                    pass
            _cleanup_bg(bg)
            return f"KILL:{feedback}"
        else:  # CONTINUE
            if proc_exited or not _is_proc_alive(pid, proc):
                _cleanup_bg(bg)
                return "natural_exit"
            # 다음 poll 사이클로


