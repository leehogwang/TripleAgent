        return

    if choice != "u":
        console.print("[dim]업데이트 건너뜁니다.[/dim]\n")
        return

    console.print("[dim]⬇  최신 코드 받는 중...[/dim]")

    if install_type == "npm":
        # npm install -g agentforge-multi
        try:
            subprocess.run(update_cmd, check=True)
        except subprocess.CalledProcessError as e:
            console.print(f"[red]npm 업데이트 실패.[/red] 수동으로 실행하세요: {' '.join(update_cmd)}")
            return
    else:
        # git pull + .local/bin 재배포
        src_dir = _find_source_repo()
        try:
            result = subprocess.run(
                ["git", "pull", "--ff-only"], cwd=src_dir,
                capture_output=True, text=True, check=True
            )
            console.print(f"[dim]{result.stdout.strip()}[/dim]")
        except subprocess.CalledProcessError as e:
            console.print(f"[red]git pull 실패:[/red] {e.stderr.strip()}")
            return
        import shutil as _shutil_up
        deploy_target = Path.home() / ".local" / "bin" / "agentforge"
        src_script = src_dir / "agentforge"
