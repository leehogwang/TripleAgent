def run_agent_loop(goal: str, workdir: str, worker_model: str | None,
                   eval_model: str | None, max_iter: int,
                   layout: Layout, live: Live,
                   initial_history: list | None = None,
                   initial_eval_history: list | None = None,
                   mode: str = "code",
                   eval_every: int = 1,
                   train_poll_seconds: int = 300,
                   session_context: list | None = None,
                   always_ab: bool = False) -> str:
    """
    Worker + Evaluator 반복 루프.
    always_ab=True: one_dual 모드 — 매 iteration A/B 실험, 승자가 다음 base.
    반환: 'done' | 'max' | 'interrupted'
    """
    global _last_session
    history = list(initial_history or [])
    eval_history = list(initial_eval_history or [])
    worker_buf = deque(maxlen=WORKER_BUF_LINES)
    worker_spoken = [""]
    worker_status = ["idle"]
    done = False
    bg_train: dict | None = None   # 백그라운드 학습 job 추적
    # 이전 세션에서 실행 중인 학습 프로세스 복원
    _resumed_bg = _load_bg_train_state()
    if _resumed_bg:
        bg_train = _resumed_bg
        worker_buf.append(
            f"[cyan]📊 이전 세션 학습 재모니터링: PID {bg_train['pid']} "
            f"로그: {bg_train['log_path']}[/cyan]"
        )
    ab_cooldown = 0                # A/B 직후 N회는 정체 감지 억제
    _session_start = time.time()   # 세션 시작 시각

    # 모드별 도구 선택
    base_tools   = RESEARCH_TOOLS if mode == "research" else WORKER_TOOLS
    active_tools = base_tools + ([] if _IS_SSH else _mcp_all_tools())

    # 압축 상태 — 백그라운드 압축 스레드 결과 수신용
    _compress_result: list[list] = []   # [new_history] 채워지면 완료
    _compress_thread: threading.Thread | None = None

    # ── 지식 저장소 로드 ─────────────────────────────────────────────────
    past_attempts = _load_past_attempts(goal)
    knowledge_dir = _knowledge_path(goal)
    similar_dirs = _find_similar_goals(goal, threshold=0.6)
    if past_attempts:
        if similar_dirs:
            _rag_note = (
                f"[dim]📚 RAG: {len(past_attempts)}개 시도 로드"
                f" ([cyan]+{len(similar_dirs)}개 유사 목표 병합[/cyan]:"
                + ", ".join(d.name[:30] for d in similar_dirs[:3]) + ")[/dim]"
            )
        else:
            _rag_note = f"[dim]📚 RAG: {len(past_attempts)}개 과거 시도 로드 (exact match)[/dim]"
    else:
        _rag_note = "[dim]📚 RAG: 매칭 없음 — 새 목표로 시작[/dim]"

    def _finish(result: str) -> str:
        return result

    # ── DEBUG: 로그 파일 경로 설정 (agentforge 실행 위치에 생성) ───────────────
    global _DEBUG_LOG_PATH
    _DEBUG_LOG_PATH = str(Path(workdir) / f"agentforge_debug_{_dt.datetime.now().strftime('%Y%m%d_%H%M%S')}.log")
    _dbg("LOOP", f"SESSION_START  mode={mode}  workdir={workdir}  goal={goal[:80]}")
    # ── END DEBUG ────────────────────────────────────────────────────────────

    def refresh(phase: str, iteration: int):
        layout["header"].update(render_header(goal, iteration, max_iter, phase, _rag_note, _session_start))
        layout["worker"].update(render_worker_panel(
            worker_buf, iteration, worker_status[0], history, done))
        layout["evaluator"].update(render_evaluator_panel(
            eval_history, iteration, phase, done))
        layout["cmd_bar"].update(
            render_cmd_bar(worker_buf, deque(), worker_status[0], "idle",
                           worker_spoken[0], "")
        )

    for iteration in range(1, max_iter + 1):
        # ── DEBUG: 이터레이션 시작 ────────────────────────────────────────
        _dbg("LOOP", f"ITER_START  iteration={iteration}")
        _iter_t0 = time.time()
        # ── END DEBUG ────────────────────────────────────────────────────
        policy_profile = _detect_task_profile(goal, mode=mode, history=history)
        worker_sys = _compose_worker_system(policy_profile)
        eval_sys = _compose_evaluator_system(policy_profile)
        # ── Worker ──────────────────────────────────────────────────────
        worker_buf.clear()
        worker_spoken[0] = ""
        worker_status[0] = "running"
        if not live._started:
            live.start()
        refresh("worker", iteration)

        # 체크포인트 저장 (REDIRECT 시 롤백용)
        cp_before = _cp_save(workdir)

        # ── 정체 감지 → A/B 전략 분기 ───────────────────────────────────
        if not always_ab:
            if ab_cooldown > 0:
                ab_cooldown -= 1
        stagnated = always_ab or (ab_cooldown == 0 and _detect_stagnation(history))
        ab_chosen = None

        if stagnated:
            if always_ab:
                worker_buf.append("[cyan bold]🔀 A/B 코드 제안 시작 (one_dual)[/cyan bold]")
            else:
                worker_buf.append(
                    f"[yellow bold]🔀 정체 감지 ({STAGNATION_THRESHOLD}회 연속) "
                    f"— 전략 A/B 분기 시작[/yellow bold]"
                )
            refresh("worker", iteration)
            ab_output, ab_chosen = _run_ab_strategy(
                goal, history, workdir,
                worker_model, worker_sys, active_tools,
                eval_model, past_attempts,
                worker_buf, iteration, refresh,
                code_only=always_ab,
                policy_profile=policy_profile,
                last_spoken_ref=worker_spoken,
            )
            if ab_chosen == "interrupted":
                live.stop()
                _last_session = {"goal": goal, "history": history,
                                 "eval_history": eval_history, "workdir": workdir}
                _persist_session(_last_session)
                return _finish('interrupted')
            if not always_ab:
                ab_cooldown = STAGNATION_THRESHOLD  # A/B 직후 N회는 재발동 억제

            if always_ab and ab_chosen not in ("interrupted", "no_pick"):
                # one_dual: 평가자가 코드 선택 완료 → 승자 코드로 학습 실행
                worker_buf.append(
                    f"[cyan bold]── 전략 {ab_chosen} 채택 → 학습 실행 시작 ──[/cyan bold]"
                )
                refresh("worker", iteration)
                train_prompt = (
                    build_worker_prompt(goal, history, past_attempts=past_attempts,
                                        session_context=session_context,
                                        policy_profile=policy_profile)
                    + f"\n\n[ONE_DUAL] 전략 {ab_chosen}의 코드가 workdir에 적용되었습니다. "
                      "학습 스크립트를 background에서 실행하고 PID와 로그 경로를 보고하라. "
                      "코드를 추가로 수정하지 마라."
                )
                train_result: list = [None]

                def _train_worker():
                    train_result[0], _ = run_worker(
                        train_prompt, workdir, worker_model, worker_buf, worker_status,
                        system_prompt=worker_sys, tools=active_tools,
                        goal_context=goal, iteration_id=iteration,
                        last_spoken_ref=worker_spoken)

                t_train = threading.Thread(target=_train_worker, daemon=True)
                t_train.start()
                while t_train.is_alive():
                    if _interrupt_event.is_set():
                        break
                    refresh("worker", iteration)
                    time.sleep(0.1)
                t_train.join(timeout=10)
                refresh("worker", iteration)

                if _interrupt_event.is_set():
                    live.stop()
                    _last_session = {"goal": goal, "history": history,
                                     "eval_history": eval_history, "workdir": workdir}
                    _persist_session(_last_session)
                    return _finish('interrupted')

                last_msg = train_result[0] or ab_output
            elif ab_chosen == "no_pick":
                # 최대 재시도 초과 → 일반 워커로 fallback (아래 else 블록과 동일 로직)
                ab_chosen = None
                worker_prompt = build_worker_prompt(goal, history, past_attempts=past_attempts,
                                                    session_context=session_context,
                                                    policy_profile=policy_profile)
                worker_result = [None, None]

                def _worker_np():
                    worker_result[0], worker_result[1] = run_worker(
                        worker_prompt, workdir, worker_model, worker_buf, worker_status,
                        system_prompt=worker_sys, tools=active_tools,
                        goal_context=goal, iteration_id=iteration,
                        last_spoken_ref=worker_spoken)

                t_np = threading.Thread(target=_worker_np, daemon=True)
                t_np.start()
                while t_np.is_alive():
                    if _interrupt_event.is_set():
                        break
                    refresh("worker", iteration)
                    time.sleep(0.1)
                t_np.join(timeout=10)
                refresh("worker", iteration)

                if _interrupt_event.is_set():
                    live.stop()
                    _last_session = {"goal": goal, "history": history,
                                     "eval_history": eval_history, "workdir": workdir}
                    _persist_session(_last_session)
                    return _finish('interrupted')

                last_msg, _ = worker_result
            else:
                last_msg = ab_output
        else:
            # 일반 Worker 실행
            worker_prompt = build_worker_prompt(goal, history, past_attempts=past_attempts,
                                                session_context=session_context,
                                                policy_profile=policy_profile)
            worker_result = [None, None]

            def _worker():
                worker_result[0], worker_result[1] = run_worker(
                    worker_prompt, workdir, worker_model, worker_buf, worker_status,
                    system_prompt=worker_sys, tools=active_tools,
                    goal_context=goal, iteration_id=iteration,
                    last_spoken_ref=worker_spoken)

            t = threading.Thread(target=_worker, daemon=True)
            t.start()
            while t.is_alive():
                if _interrupt_event.is_set():
                    break
                refresh("worker", iteration)
                time.sleep(0.1)
            t.join(timeout=10)
            refresh("worker", iteration)

            if _interrupt_event.is_set():
                _cp_delete(cp_before)
                live.stop()
                _last_session = {"goal": goal, "history": history,
                                 "eval_history": eval_history, "workdir": workdir}
                _persist_session(_last_session)
                return _finish('interrupted')

            last_msg, _ = worker_result

        last_msg_str = last_msg or ""
        worker_summary = last_msg_str.replace('\n', ' ')[:300]
        hypothesis = _extract_hypothesis(last_msg_str)
        changed_files = _collect_changed_files(workdir)
        attempt_signals = _classify_attempt_signals(last_msg_str, worker_summary, changed_files)
        history.append({
            'iter': iteration,
            'worker_summary': worker_summary,
            'worker_lines': list(worker_buf)[-12:],
            'decision': '',
            'feedback': '',
            'changed_files': changed_files,
            'attempt_signals': attempt_signals,
            'policy_labels': list(policy_profile.get("labels", [])),
            'eval_meta': {},
            **({"ab_chosen": ab_chosen} if ab_chosen else {}),
        })

        # ── 백그라운드 학습 job 감지 ─────────────────────────────────────
        # 1순위: shell_background 사이드 채널 (툴 실행 직후 등록됨)
        global _pending_bg_job
        with _pending_bg_job_lock:
            _side_job = _pending_bg_job
            _pending_bg_job = None  # 소비

        if _side_job and bg_train is None:
            bg_train = {
                "pid": _side_job["pid"],
                "log_path": _side_job["log_path"],
                "proc": _side_job.get("proc"),
                "started_at": time.time(),
                "last_poll_at": time.time(),
                "poll_count": 0,
            }
            _save_bg_train_state(bg_train)
            worker_buf.append(f"[cyan]📊 학습 모니터 시작: PID {_side_job['pid']}[/cyan]")
            refresh("worker", iteration)
        else:
            # 2순위: 워커 텍스트에서 PID/LOG 직접 파싱 (폴백)
            pid_m = _BG_PID_RE.search(last_msg_str)
            log_m = _BG_LOG_RE.search(last_msg_str)
            if pid_m and log_m and bg_train is None:
                bg_pid = int(pid_m.group(1))
                with _active_procs_lock:
                    bg_proc = next((p for p in _active_procs if p.pid == bg_pid), None)
                bg_train = {
                    "pid": bg_pid,
                    "log_path": log_m.group(1).strip(),
                    "proc": bg_proc,
                    "started_at": time.time(),
                    "last_poll_at": time.time(),
                    "poll_count": 0,
                }
                _save_bg_train_state(bg_train)
                worker_buf.append(f"[cyan]📊 학습 모니터 시작: PID {bg_pid}[/cyan]")
                refresh("worker", iteration)

        # ── 학습 모니터링 루프 ────────────────────────────────────────────
        if bg_train is not None:
            monitor_result = _run_monitor_loop(
                bg_train, goal, workdir, eval_model, train_poll_seconds,
                layout, live, worker_buf, eval_history, iteration, refresh,
            )
            if monitor_result == "DONE":
                done = True
                refresh("done", iteration)
                time.sleep(0.8)
                live.stop()
                _last_session = {
                    "goal": goal, "history": history,
                    "eval_history": eval_history, "workdir": workdir,
                }
                _persist_session(_last_session)
                console.print()
                console.print(Rule(f"[bold green]✓ 학습 완료 — {iteration}번 반복[/bold green]"))
                return _finish('done')
            elif monitor_result.startswith("KILL:"):
                kill_reason = monitor_result[5:]
                history[-1]['decision'] = 'REDIRECT'
                history[-1]['feedback'] = f"학습 중단({kill_reason}). 다른 접근 시도."
                eval_history.append({
                    'iter': iteration,
                    'decision': 'REDIRECT',
                    'feedback': f"학습 중단: {kill_reason}",
                    'full_msg': f"KILL:{kill_reason}",
                })
                bg_train = None
                _save_bg_train_state(None)
                continue  # 다음 iteration → Worker가 REDIRECT 보고 새 전략 시도
            elif monitor_result == "interrupted":
                bg_train = None
                _save_bg_train_state(None)
                live.stop()
                _last_session = {
                    "goal": goal, "history": history,
                    "eval_history": eval_history, "workdir": workdir,
                }
                _persist_session(_last_session)
                return _finish('interrupted')
            else:  # "natural_exit"
                bg_train_log = bg_train.get("log_path", "")
                bg_train = None
                _save_bg_train_state(None)
                # 학습 완료 → evaluator context에 로그 tail + 안내 주입
                if bg_train_log:
                    _completed_log_tail = _read_log_tail(bg_train_log, lines=50)
                    last_msg = (
                        (last_msg or "")
                        + "\n\n[BACKGROUND TRAINING COMPLETED]\n"
                        + f"Final training log (last 50 lines):\n{_completed_log_tail}\n\n"
                        + "NOTE: Background training has finished. "
                        + "The worker must now run evaluation (evaluate.py or equivalent) "
                        + "and report actual PMAE/metric numbers before this iteration "
                        + "can be considered complete."
                    )

        # ── Evaluator ────────────────────────────────────────────────────
        if _interrupt_event.is_set():
            live.stop()
            _last_session = {"goal": goal, "history": history,
                             "eval_history": eval_history, "workdir": workdir}
            _persist_session(_last_session)
            return _finish('interrupted')

        preemptive_payload = _preemptive_eval_override(history, last_msg_str, worker_summary, changed_files)
        if preemptive_payload is not None:
            eval_payload = preemptive_payload
            eval_msg = json.dumps(
                {k: v for k, v in eval_payload.items() if k != "raw_text"},
                ensure_ascii=False,
            )
        elif iteration % eval_every == 0 or iteration == max_iter:
            refresh("evaluator", iteration)
            eval_prompt = build_evaluator_prompt(goal, last_msg or "", iteration, workdir,
                                                 past_attempts=past_attempts,
                                                 history=history,
                                                 policy_profile=policy_profile)
            eval_msg, _ = run_evaluator(eval_prompt, workdir, eval_model,
                                        system_prompt=eval_sys,
                                        output_schema=_FAST_EVALUATOR_OUTPUT_SCHEMA,
                                        retry_invalid_json=True)
            eval_payload = _normalize_evaluator_payload(eval_msg)
        else:
            eval_payload = {
                "decision": "IMPROVE",
                "reason_type": "monitoring",
                "next_action": "(evaluation skipped for this iteration)",
                "confidence": 0.5,
                "rollback_needed": False,
                "needs_search": False,
                "needs_long_run_monitor": False,
                "summary": {
                    "judgment": "",
                    "result_paths": [],
                    "result_summary": "",
                },
            }
            eval_msg = json.dumps(eval_payload, ensure_ascii=False)

        eval_payload = _apply_eval_policy_overrides(
            history,
            eval_payload,
            last_msg_str,
            worker_summary,
            changed_files,
        )
        eval_msg = json.dumps(
            {k: v for k, v in eval_payload.items() if k != "raw_text"},
            ensure_ascii=False,
        )
        decision = eval_payload["decision"]
        feedback = _decision_feedback_from_payload(eval_payload)
        history[-1]['decision'] = decision
        history[-1]['feedback'] = feedback
        history[-1]['eval_meta'] = eval_payload
        eval_history.append({
            'iter': iteration,
            'decision': decision,
            'feedback': feedback,
            'full_msg': eval_msg,
            'meta': eval_payload,
        })

        # ── 체크포인트 처리 ───────────────────────────────────────────────
        if eval_payload['rollback_needed'] and cp_before is not None:
            restored = _cp_restore(workdir, cp_before)
            if restored:
                worker_buf.append("[yellow]↩ 평가자 요청에 따라 변경사항 롤백됨[/yellow]")
            _cp_delete(cp_before)
        else:
            _cp_delete(cp_before)

        # ── 지식 저장소에 attempt 기록 ───────────────────────────────────
        attempt_record = {
            "timestamp": time.strftime("%Y-%m-%dT%H:%M:%S"),
            "iter": iteration,
            "decision": decision,
            "feedback": feedback,
            "worker_summary": worker_summary,
            "hypothesis": hypothesis,
            "goal": goal,
            "reason_type": eval_payload["reason_type"],
            "next_action": eval_payload["next_action"],
            "confidence": eval_payload["confidence"],
            "rollback_needed": eval_payload["rollback_needed"],
            "needs_search": eval_payload["needs_search"],
            "needs_long_run_monitor": eval_payload["needs_long_run_monitor"],
            "changed_files": changed_files,
            "attempt_signals": attempt_signals,
            "summary": eval_payload["summary"],
        }
        _save_attempt(goal, attempt_record)
        past_attempts.append(attempt_record)  # 현재 세션 내 즉시 반영
        _write_report_entry(goal, iteration, decision, feedback, worker_summary, hypothesis)
        _append_memory_event(goal, {
            "event_type": "decision",
            "iter": iteration,
            "decision": decision,
            "reason_type": eval_payload["reason_type"],
            "next_action": eval_payload["next_action"],
            "confidence": eval_payload["confidence"],
            "rollback_needed": eval_payload["rollback_needed"],
            "needs_search": eval_payload["needs_search"],
            "needs_long_run_monitor": eval_payload["needs_long_run_monitor"],
            "worker_summary": worker_summary,
            "hypothesis": hypothesis,
            "changed_files": changed_files,
            "attempt_signals": attempt_signals,
            "summary": eval_payload["summary"],
        })
        for path in changed_files:
            _append_memory_event(goal, {
                "event_type": "file_change",
                "iter": iteration,
                "path": path,
                "decision": decision,
                "rolled_back": eval_payload["rollback_needed"],
            })
        for metric in _extract_metric_events(last_msg_str):
            _append_memory_event(goal, {
                "event_type": "metric",
                "iter": iteration,
                **metric,
            })
        for artifact_path in eval_payload["summary"].get("result_paths", []):
            _append_memory_event(goal, {
                "event_type": "artifact",
                "iter": iteration,
                "artifact_path": artifact_path,
                "decision": decision,
            })

        # ── 이전 압축 결과 반영 ──────────────────────────────────────────
        if _compress_thread and not _compress_thread.is_alive() and _compress_result:
            history = _compress_result[0]
            _compress_result.clear()
            _compress_thread = None

        # ── 프롬프트 토큰이 100k 초과 시 백그라운드 압축 시작 ────────────
        prompt_tokens = _estimate_tokens(build_worker_prompt(
            goal,
            history,
            past_attempts=past_attempts,
            policy_profile=policy_profile,
        ))
        if (prompt_tokens > TOKEN_COMPRESS_THRESHOLD
                and (_compress_thread is None or not _compress_thread.is_alive())
                and decision != 'DONE'):
            _snap = list(history)  # 스냅샷 캡처
            _res  = _compress_result

            def _do_compress():
                new_h = compress_history(_snap, goal, eval_model)
                _res.clear()
                _res.append(new_h)
                if len(new_h) < len(_snap):
                    _append_memory_event(goal, {
                        "event_type": "history_compression",
                        "iter": iteration,
                        "summary": {
                            "judgment": f"Compressed history from {len(_snap)} to {len(new_h)} entries.",
                            "result_paths": [],
                            "result_summary": "Older iterations were summarized to control prompt size.",
                        },
                    })

            _compress_thread = threading.Thread(target=_do_compress, daemon=True)
            _compress_thread.start()

        if decision == 'DONE':
            done = True
            refresh("done", iteration)
            time.sleep(0.8)
            live.stop()
            _last_session = {
                "goal": goal, "history": history,
                "eval_history": eval_history, "workdir": workdir,
            }
            _persist_session(_last_session)

            # 완료 요약 출력
            console.print()
            console.print(Rule(f"[bold green]✓ 완료 — {iteration}번 반복[/bold green]"))
            console.print()

            # Q&A / 조회 작업: 결과물 위치가 없으면 worker 답변을 직접 출력
            done_summary = eval_payload.get("summary", {})
            result_paths = done_summary.get("result_paths", [])
            _loc_val = ", ".join(result_paths)
            _no_file = (not _loc_val or
                        _loc_val.lower().startswith(('없음', '해당 없음', 'n/a', 'none', '-')) or
                        not any(c in _loc_val for c in ('/', '\\', '.')))
            if _no_file and last_msg and last_msg.strip():
                global _last_qa_answer
                _last_qa_answer = last_msg.strip()
                console.print(Panel(
                    last_msg.strip(),
                    title="[bold cyan]답변[/bold cyan]",
                    border_style="cyan",
                    padding=(0, 1),
                ))
                console.print("[dim]  /last 로 언제든 다시 볼 수 있습니다[/dim]")
                console.print()

            summary_sections = [
                ("판단 이유", done_summary.get("judgment", ""), 'white'),
                ("결과물 위치", "\n".join(result_paths), 'cyan'),
                ("결과 요약", done_summary.get("result_summary", ""), 'bright_white'),
            ]
            for section, value, color in summary_sections:
                value = (value or "").strip()
                if not value:
                    continue
                console.print(f"[bold]{section}[/bold]")
                for line in value.splitlines():
                    console.print(f"  [{color}]{line}[/{color}]")
                console.print()
            # 실험 결과 자동 시각화
            plots = _try_visualize(workdir, goal)
            if plots:
                console.print(f"[dim]📊 학습 결과 시각화 — {len(plots)}개 플롯 생성됨[/dim]")
                for p in plots:
                    console.print(f"  [cyan]{p}[/cyan]")
                console.print()
            # 리포트 위치 안내
            report_path = _knowledge_path(goal) / "report.md"
            if report_path.exists():
                console.print(f"[dim]📝 실험 리포트: {report_path}[/dim]")
                console.print(f"[dim]   확인: /report[/dim]")
                console.print()
            return _finish('done')

    live.stop()
    _last_session = {
        "goal": goal, "history": history,
        "eval_history": eval_history, "workdir": workdir,
    }
    _persist_session(_last_session)
    return _finish('max')


def run_dual_agent_loop(
    goal: str, task_a: str, task_b: str,
    workdir: str, worker_model: str | None, eval_model: str | None,
    max_iter: int, layout: Layout, live: Live,
    initial_history1=None, initial_history2=None,
    initial_eval_history1=None, initial_eval_history2=None,
    mode: str = "code", eval_every: int = 1,
    session_context: list | None = None,
) -> str:
    """
    Dual Worker + Dual Evaluator 병렬 루프.
    반환: 'done' | 'max' | 'interrupted'
    """
    global _last_session
    history1 = list(initial_history1 or [])
    history2 = list(initial_history2 or [])
    eval_history1 = list(initial_eval_history1 or [])
    eval_history2 = list(initial_eval_history2 or [])
    buf1 = deque(maxlen=WORKER_BUF_LINES)
    buf2 = deque(maxlen=WORKER_BUF_LINES)
    spoken1 = [""]
    spoken2 = [""]
    status1 = ["idle"]
    status2 = ["idle"]
    _session_start = time.time()   # 세션 시작 시각
    done1 = False
    done2 = False
    current_task_a = task_a
    current_task_b = task_b

    policy_profile = _detect_task_profile(goal, mode=mode)
    worker_sys = _compose_worker_system(policy_profile)
    active_tools = (RESEARCH_TOOLS if mode == "research" else WORKER_TOOLS) + ([] if _IS_SSH else _mcp_all_tools())

    past_attempts1 = _load_past_attempts(task_a)
    past_attempts2 = _load_past_attempts(task_b)
    _sim1 = _find_similar_goals(task_a, threshold=0.6)
    _sim2 = _find_similar_goals(task_b, threshold=0.6)
    def _rag_line(attempts, sim_dirs):
        if attempts:
            if sim_dirs:
                return (f"[dim]📚 RAG: {len(attempts)}개 시도"
                        f" ([cyan]+{len(sim_dirs)}개 유사 병합[/cyan])[/dim]")
            return f"[dim]📚 RAG: {len(attempts)}개 과거 시도 (exact)[/dim]"
        return "[dim]📚 RAG: 매칭 없음[/dim]"
    _rag_note = _rag_line(past_attempts1 or past_attempts2,
                          _sim1 + [d for d in _sim2 if d not in _sim1])

    def _finish(result: str) -> str:
        return result

    # ── DEBUG: 로그 파일 경로 설정 (agentforge 실행 위치에 생성) ───────────────
    global _DEBUG_LOG_PATH
    _DEBUG_LOG_PATH = str(Path(workdir) / f"agentforge_debug_{_dt.datetime.now().strftime('%Y%m%d_%H%M%S')}.log")
    _dbg("LOOP", f"SESSION_START  mode=dual  workdir={workdir}  goal={goal[:80]}")
    _dbg("LOOP", f"TASK_A={task_a[:80]}")
    _dbg("LOOP", f"TASK_B={task_b[:80]}")
    # ── END DEBUG ────────────────────────────────────────────────────────────

    def _persist_dual():
        global _last_session
        _last_session = {
            "mode": "dual", "goal": goal,
            "task_a": current_task_a, "task_b": current_task_b,
            "history1": history1, "history2": history2,
            "eval_history1": eval_history1, "eval_history2": eval_history2,
            "workdir": workdir,
        }
        _persist_session(_last_session)

    def refresh(phase: str, iteration: int):
        layout["header"].update(render_header(goal, iteration, max_iter, phase, _rag_note, _session_start))
        layout["summary_bar"].update(
            render_summary_bar(current_task_a, current_task_b, status1[0], status2[0])
        )
        layout["worker1"].update(
            render_worker_panel(buf1, iteration, status1[0], history1, done1, label="WORKER 1")
        )
        layout["worker2"].update(
            render_worker_panel(buf2, iteration, status2[0], history2, done2, label="WORKER 2")
        )
        layout["evaluator"].update(
            render_dual_evaluator_panel(eval_history1, eval_history2, iteration, phase, done1, done2)
        )
        layout["cmd_bar"].update(
            render_cmd_bar(buf1, buf2, status1[0], status2[0], spoken1[0], spoken2[0])
        )

    # 이전 레이아웃 잔상 제거 후 즉시 듀얼 레이아웃 시작
    console.clear()
    if not live._started:
        live.start()
    refresh("idle", 0)

    for iteration in range(1, max_iter + 1):
        # ── DEBUG: 이터레이션 시작 ────────────────────────────────────────
        _dbg("LOOP", f"ITER_START  iteration={iteration}  done1={done1}  done2={done2}")
        _iter_t0 = time.time()
        # ── END DEBUG ────────────────────────────────────────────────────
        if done1 and done2:
            break

        # ── Phase 1: Workers 병렬 실행 ───────────────────────────────────
        buf1.clear()
        buf2.clear()
        spoken1[0] = ""
        spoken2[0] = ""
        if not done1:
            status1[0] = "running"
        if not done2:
            status2[0] = "running"

        refresh("dual_worker", iteration)

        w1_result: list = [None, None]
        w2_result: list = [None, None]

        def _w1():
            if done1:
                return
            prompt = build_worker_prompt(current_task_a, history1, past_attempts=past_attempts1,
                                         session_context=session_context,
                                         policy_profile=policy_profile)
            w1_result[0], w1_result[1] = run_worker(
                prompt, workdir, worker_model, buf1, status1,
                system_prompt=worker_sys, tools=active_tools, worker_id=1,
                goal_context=current_task_a, iteration_id=iteration,
                last_spoken_ref=spoken1)

        def _w2():
            if done2:
                return
            prompt = build_worker_prompt(current_task_b, history2, past_attempts=past_attempts2,
                                         session_context=session_context,
                                         policy_profile=policy_profile)
            w2_result[0], w2_result[1] = run_worker(
                prompt, workdir, worker_model, buf2, status2,
                system_prompt=worker_sys, tools=active_tools, worker_id=2,
                goal_context=current_task_b, iteration_id=iteration,
                last_spoken_ref=spoken2)

        t1 = threading.Thread(target=_w1, daemon=True)
        t2 = threading.Thread(target=_w2, daemon=True)
        if not done1:
            t1.start()
        if not done2:
            t2.start()

        while (not done1 and t1.is_alive()) or (not done2 and t2.is_alive()):
            if _interrupt_event.is_set():
                break
            refresh("dual_worker", iteration)
            time.sleep(0.1)

        if not done1:
            t1.join(timeout=10)
        if not done2:
            t2.join(timeout=10)
        refresh("dual_worker", iteration)

        if _interrupt_event.is_set():
            live.stop()
            _persist_dual()
            return _finish('interrupted')

        # Worker 출력 수집
        msg1 = w1_result[0] or "" if not done1 else "(W1 이미 완료)"
        msg2 = w2_result[0] or "" if not done2 else "(W2 이미 완료)"
        summary1 = msg1.replace('\n', ' ')[:300]
        summary2 = msg2.replace('\n', ' ')[:300]

        if not done1:
            history1.append({
                'iter': iteration, 'worker_summary': summary1,
                'worker_lines': list(buf1)[-12:], 'decision': '', 'feedback': '',
            })
        if not done2:
            history2.append({
                'iter': iteration, 'worker_summary': summary2,
                'worker_lines': list(buf2)[-12:], 'decision': '', 'feedback': '',
            })

        # ── Phase 2: Evaluators 병렬 실행 ────────────────────────────────
        refresh("dual_evaluator", iteration)

        eval1_result: list = [None, None]
        eval2_result: list = [None, None]

        def _e1():
            if done1:
                return
            ep = build_evaluator_prompt(current_task_a, msg1, iteration, workdir,
                                        past_attempts=past_attempts1, history=history1,
                                        policy_profile=policy_profile)
            eval1_result[0], eval1_result[1] = run_evaluator(
                ep, workdir, eval_model,
                system_prompt=_compose_dual_evaluator_system(policy_profile),
                output_schema=_FAST_EVALUATOR_OUTPUT_SCHEMA,
                retry_invalid_json=True)

        def _e2():
            if done2:
                return
            ep = build_evaluator_prompt(current_task_b, msg2, iteration, workdir,
                                        past_attempts=past_attempts2, history=history2,
                                        policy_profile=policy_profile)
            eval2_result[0], eval2_result[1] = run_evaluator(
                ep, workdir, eval_model,
                system_prompt=_compose_dual_evaluator_system(policy_profile),
                output_schema=_FAST_EVALUATOR_OUTPUT_SCHEMA,
                retry_invalid_json=True)

        et1 = threading.Thread(target=_e1, daemon=True)
        et2 = threading.Thread(target=_e2, daemon=True)
        if not done1:
            et1.start()
        if not done2:
            et2.start()

        while (not done1 and et1.is_alive()) or (not done2 and et2.is_alive()):
            if _interrupt_event.is_set():
                break
            refresh("dual_evaluator", iteration)
            time.sleep(0.1)

        if not done1:
            et1.join(timeout=10)
        if not done2:
            et2.join(timeout=10)

        if _interrupt_event.is_set():
            live.stop()
            _persist_dual()
            return _finish('interrupted')

        # ── Phase 3: Decision 처리 ────────────────────────────────────────
        eval_msg1 = eval1_result[0] or json.dumps({
            "decision": "IMPROVE",
            "reason_type": "other",
            "next_action": "(no response)",
            "confidence": 0.5,
            "rollback_needed": False,
            "needs_search": False,
            "needs_long_run_monitor": False,
            "summary": {"judgment": "", "result_paths": [], "result_summary": ""},
        }, ensure_ascii=False) if not done1 else ""
        eval_msg2 = eval2_result[0] or json.dumps({
            "decision": "IMPROVE",
            "reason_type": "other",
            "next_action": "(no response)",
            "confidence": 0.5,
            "rollback_needed": False,
            "needs_search": False,
            "needs_long_run_monitor": False,
            "summary": {"judgment": "", "result_paths": [], "result_summary": ""},
        }, ensure_ascii=False) if not done2 else ""

        payload1 = _normalize_evaluator_payload(
            eval_msg1, allow=("CONTINUE", "IMPROVE", "REDIRECT", "DONE", "GPU_PICK")
        ) if not done1 else {"decision": "DONE", "next_action": ""}
        payload2 = _normalize_evaluator_payload(
            eval_msg2, allow=("CONTINUE", "IMPROVE", "REDIRECT", "DONE", "GPU_PICK")
        ) if not done2 else {"decision": "DONE", "next_action": ""}

        decision1 = payload1["decision"] if not done1 else "DONE"
        decision2 = payload2["decision"] if not done2 else "DONE"
        feedback1 = _decision_feedback_from_payload(payload1) if not done1 else ""
        feedback2 = _decision_feedback_from_payload(payload2) if not done2 else ""

        if not done1:
            history1[-1]['decision'] = decision1
            history1[-1]['feedback'] = feedback1
            history1[-1]['eval_meta'] = payload1
            eval_history1.append({
                'iter': iteration, 'decision': decision1,
                'feedback': feedback1, 'full_msg': eval_msg1,
                'meta': payload1,
            })
        if not done2:
            history2[-1]['decision'] = decision2
            history2[-1]['feedback'] = feedback2
            history2[-1]['eval_meta'] = payload2
            eval_history2.append({
                'iter': iteration, 'decision': decision2,
                'feedback': feedback2, 'full_msg': eval_msg2,
                'meta': payload2,
            })

        refresh("dual_evaluator", iteration)

        # GPU_PICK 처리
        if decision1 == 'GPU_PICK' or decision2 == 'GPU_PICK':
            rw = 2 if decision2 == 'GPU_PICK' else 1
            live.stop()

            gpu_list = _list_all_gpus()
            console.print(Rule(f"[yellow]Worker {rw} — GPU 선택 필요[/yellow]"))
            reason = feedback2 if rw == 2 else feedback1
            console.print(f"[yellow]평가자 판단:[/yellow] {reason}\n")
            for i, g in enumerate(gpu_list, 1):
                w1_tag = " [dim](Worker 1 사용 중)[/dim]" if _ACTIVE_GPU.get(1) == g['id'] else ""
                bar = "█" * int(g['util'] * 10) + "░" * (10 - int(g['util'] * 10))
                console.print(
                    f"  [[cyan]{i}[/cyan]] GPU {g['id']} {g['name'][:20]}"
                    f"  {g['used_mb']:.0f}/{g['total_mb']:.0f}MB  [{bar}] {g['util']*100:.0f}%"
                    f"{w1_tag}"
                )
            console.print(f"  [[cyan]0[/cyan]] 다른 명령 내리기")
            console.print()

            try:
                choice_str = safe_input('\x1b[33m선택 (번호)\x1b[0m \x1b[37m>\x1b[0m ').strip()
                choice = int(choice_str)
            except (ValueError, EOFError, KeyboardInterrupt):
                choice = -1

            if choice == 0:
                try:
                    user_instruction = safe_input(
                        f'\x1b[36mWorker {rw} 에게 내릴 명령\x1b[0m \x1b[37m>\x1b[0m '
                    ).strip()
                except (EOFError, KeyboardInterrupt):
                    user_instruction = ""
                if user_instruction:
                    target_task = current_task_b if rw == 2 else current_task_a
                    override_prompt = (
                        f"User override instruction for Worker {rw}: {user_instruction}\n"
                        f"Worker's previous task: {target_task}\n"
                        f"Based on this user instruction, issue an IMPROVE or REDIRECT decision "
                        f"to guide the worker on what to do next."
                    )
                    override_eval_msg, _ = run_evaluator(
                        override_prompt, workdir, eval_model,
                        system_prompt=_compose_dual_evaluator_system(policy_profile),
                        output_schema=_FAST_EVALUATOR_OUTPUT_SCHEMA,
                        retry_invalid_json=True)
                    override_payload = _normalize_evaluator_payload(
                        override_eval_msg, allow=("IMPROVE", "REDIRECT", "DONE", "GPU_PICK", "CONTINUE")
                    )
                    ov_decision = override_payload["decision"]
                    ov_feedback = _decision_feedback_from_payload(override_payload)
                    target_hist = history2 if rw == 2 else history1
                    if target_hist:
                        target_hist[-1]['decision'] = ov_decision
                        target_hist[-1]['feedback'] = ov_feedback
                        target_hist[-1]['eval_meta'] = override_payload
                    target_eval_hist = eval_history2 if rw == 2 else eval_history1
                    target_eval_hist.append({
                        'iter': iteration, 'decision': ov_decision,
                        'feedback': ov_feedback, 'full_msg': override_eval_msg,
                        'meta': override_payload,
                    })
                else:
                    live.start()
                    _persist_dual()
                    continue

            elif 1 <= choice <= len(gpu_list):
                selected_gpu = gpu_list[choice - 1]['id']
                with _ACTIVE_GPU_LOCK:
                    _ACTIVE_GPU[rw] = selected_gpu
                target_hist = history2 if rw == 2 else history1
                if target_hist:
                    target_hist[-1]['decision'] = 'REDIRECT'
                    target_hist[-1]['feedback'] = f"GPU {selected_gpu}(으)로 재시도"
                target_eval_hist = eval_history2 if rw == 2 else eval_history1
                target_eval_hist.append({
                    'iter': iteration, 'decision': 'REDIRECT',
                    'feedback': f"사용자 선택: GPU {selected_gpu}",
                    'full_msg': f"GPU_PICK resolved: GPU {selected_gpu}",
                })

            live.start()
            refresh("idle", iteration)
            _persist_dual()
            continue

        # DONE 처리
        if decision1 == 'DONE' and not done1:
            done1 = True
            buf1.append("[green bold]✓ W1 완료[/green bold]")
        if decision2 == 'DONE' and not done2:
            done2 = True
            buf2.append("[green bold]✓ W2 완료[/green bold]")

        refresh("dual_evaluator", iteration)

        # RAG 기록
        if not done1 or history1 and history1[-1].get('decision'):
            _save_attempt(current_task_a, {
                "timestamp": time.strftime("%Y-%m-%dT%H:%M:%S"),
                "iter": iteration, "decision": decision1, "feedback": feedback1,
                "worker_summary": summary1, "goal": current_task_a,
                "reason_type": payload1.get("reason_type", "") if not done1 else "",
                "next_action": payload1.get("next_action", "") if not done1 else "",
                "confidence": payload1.get("confidence", 0.5) if not done1 else 0.5,
                "rollback_needed": payload1.get("rollback_needed", False) if not done1 else False,
            })
        if not done2 or history2 and history2[-1].get('decision'):
            _save_attempt(current_task_b, {
                "timestamp": time.strftime("%Y-%m-%dT%H:%M:%S"),
                "iter": iteration, "decision": decision2, "feedback": feedback2,
                "worker_summary": summary2, "goal": current_task_b,
                "reason_type": payload2.get("reason_type", "") if not done2 else "",
                "next_action": payload2.get("next_action", "") if not done2 else "",
                "confidence": payload2.get("confidence", 0.5) if not done2 else 0.5,
                "rollback_needed": payload2.get("rollback_needed", False) if not done2 else False,
            })

        _persist_dual()

        if done1 and done2:
            time.sleep(0.8)
            live.stop()
            console.print()
            console.print(Rule(f"[bold green]✓ 듀얼 완료 — {iteration}번 반복[/bold green]"))
            console.print(f"[cyan]W1:[/cyan] {current_task_a[:60]}")
            console.print(f"[cyan]W2:[/cyan] {current_task_b[:60]}")
            return _finish('done')

    live.stop()
    _persist_dual()
    if done1 and done2:
        return _finish('done')
    return _finish('max')


def _prepare_single_shell(
    ui: InteractiveShellUI,
    goal: str,
    max_iter: int,
    iteration: int = 0,
    history: list | None = None,
    eval_history: list | None = None,
):
    layout = ui.activate_mode("single")
    layout["header"].update(render_header(goal, iteration, max_iter, "idle"))
    layout["worker"].update(render_worker_panel(
        deque(), iteration, "idle", history or [], False
    ))
    layout["evaluator"].update(render_evaluator_panel(
        eval_history or [], iteration, "idle", False
    ))
    layout["cmd_bar"].update(render_cmd_bar(deque(), deque(), "idle", "idle", "", ""))
    return layout, ui.create_live_proxy()


def _prepare_dual_shell(
    ui: InteractiveShellUI,
    goal: str,
    max_iter: int,
    task_a: str,
    task_b: str,
    iteration: int = 0,
    history1: list | None = None,
    history2: list | None = None,
    eval_history1: list | None = None,
    eval_history2: list | None = None,
):
    layout = ui.activate_mode("dual")
    layout["header"].update(render_header(goal, iteration, max_iter, "idle"))
    layout["summary_bar"].update(render_summary_bar(task_a, task_b, "idle", "idle"))
    layout["worker1"].update(render_worker_panel(
        deque(), iteration, "idle", history1 or [], False, label="WORKER 1"
    ))
    layout["worker2"].update(render_worker_panel(
        deque(), iteration, "idle", history2 or [], False, label="WORKER 2"
    ))
    layout["evaluator"].update(render_dual_evaluator_panel(
        eval_history1 or [], eval_history2 or [], iteration, "idle", False, False
    ))
    layout["cmd_bar"].update(render_cmd_bar(deque(), deque(), "idle", "idle", "", ""))
    return layout, ui.create_live_proxy()


# ── Interrupt Handler ─────────────────────────────────────────────────────────

def _handle_interrupt(goal: str, workdir: str, args, max_iter: int) -> str:
    """
    ESC 중단 후 목표 편집 프롬프트 표시.
    새 목표로 루프를 재실행하고, 최종 목표 문자열 반환.
    """
    console.print(
        "\n[yellow]⚠  중단됨.[/yellow] "
        "목표를 수정하거나 Enter로 재실행, Ctrl+C로 REPL 복귀:"
    )
    try:
        new_goal = safe_input(
            '\x1b[33m\x1b[1m목표 수정\x1b[0m \x1b[37m>\x1b[0m ',
            default=goal,
        ).strip()
    except (EOFError, KeyboardInterrupt):
        console.print("[dim]취소됨. REPL로 돌아갑니다.[/dim]")
        return goal

    if not new_goal:
        new_goal = goal  # Enter만 누르면 동일 목표 재실행

    layout2, live2 = _prepare_single_shell(_ACTIVE_UI, new_goal, max_iter)

    # 목표가 바뀌면 히스토리 없이 fresh 실행
    outcome = run_agent_loop(
        new_goal, workdir, args.worker_model, args.eval_model,
        max_iter, layout2, live2,
    )
    if outcome == 'interrupted':
        return _handle_interrupt(new_goal, workdir, args, max_iter)
    elif outcome == 'max':
        console.print(f"[red]{max_iter}번 반복 후에도 완료되지 않았습니다.[/red]")
    console.print("[dim]다음 명령을 입력하세요. /exit 로 종료.[/dim]")
    return new_goal


# ── Main ──────────────────────────────────────────────────────────────────────

def _interactive_controller(args, workdir: str, max_iter: int, ui: InteractiveShellUI) -> None:
    global _last_session

    current_mode = args.mode
    eval_every = args.eval_every
    current_goal = ""
    _session_summaries: list[dict] = []
    def _fast_mode_label() -> str:
        requested = bool(ui.fast_mode)
        if requested and _get_codex_bin() is not None:
            return "[green]on[/green]"
        if requested:
            return "[yellow]requested (codex missing)[/yellow]"
        return "[dim]off[/dim]"

    def _apply_fast_mode(enabled: bool, announce: bool = False) -> bool:
        requested = bool(enabled)
        codex_bin = _refresh_codex_bin() if requested else _get_codex_bin()
        if requested and codex_bin is None:
            ui.set_fast_mode(False)
            _set_fast_mode(False)
            if announce:
                console.print(f"[red]/fast on 실패: codex 실행 파일이 없습니다 ({_codex_display_path()}).[/red]")
            return False
        ui.set_fast_mode(requested)
        _set_fast_mode(requested)
        _append_session_event("fast_mode", enabled=requested)
        if announce:
            console.print(
                f"[cyan]Fast transport: {'on' if requested else 'off'}[/cyan]  "
                f"[dim]({'official codex exec' if requested else 'legacy backend'})[/dim]"
            )
        return True

    _apply_fast_mode(bool(ui.fast_mode))

    def _record_session_summary(outcome: str, fallback_goal: str) -> None:
        if outcome == "interrupted" or not _last_session:
            return
        sess = _last_session
        if sess.get("mode") == "dual":
            iter_count = max(len(sess.get("history1", [])), len(sess.get("history2", [])))
            feedback_parts = []
            if sess.get("eval_history1"):
                feedback_parts.append(sess["eval_history1"][-1].get("feedback", ""))
            if sess.get("eval_history2"):
                feedback_parts.append(sess["eval_history2"][-1].get("feedback", ""))
            last_feedback = " | ".join(part for part in feedback_parts if part)
        else:
            real_history = [
                h for h in sess.get("history", [])
                if h.get("type") != "compressed_summary"
            ]
            iter_count = len(real_history)
            last_feedback = next(
                (
                    h.get("feedback", "")
                    for h in reversed(real_history)
                    if h.get("decision") in ("IMPROVE", "REDIRECT", "DONE")
                ),
                "",
            )
        _session_summaries.append({
            "goal": sess.get("goal", fallback_goal),
            "outcome": outcome,
            "iter_count": iter_count,
            "last_feedback": last_feedback,
        })

    def _report_outcome(outcome: str) -> None:
        if outcome == "interrupted":
            console.print("[yellow]⚠  중단됨. REPL로 돌아갑니다.[/yellow]")
            return
        if outcome == "max":
            console.print(f"[red]{max_iter}번 반복 후에도 완료되지 않았습니다.[/red]")
        console.print("[dim]다음 명령을 입력하세요. /exit 로 종료.[/dim]")

    def _run_single_goal(
        goal_text: str,
        initial_history: list | None = None,
        initial_eval_history: list | None = None,
    ) -> str:
        iteration = len(initial_history or [])
        layout2, live2 = _prepare_single_shell(
            ui,
            goal_text,
            max_iter,
            iteration=iteration,
            history=initial_history,
            eval_history=initial_eval_history,
        )
        return run_agent_loop(
            goal_text,
            workdir,
            args.worker_model,
            args.eval_model,
            max_iter,
            layout2,
            live2,
            initial_history=initial_history,
            initial_eval_history=initial_eval_history,
            mode=current_mode,
            eval_every=eval_every,
            session_context=_session_summaries if _session_summaries else None,
            always_ab=(current_mode == "one_dual"),
        )

    def _run_dual_goal(
        goal_text: str,
        task_a: str,
        task_b: str,
        initial_history1: list | None = None,
        initial_history2: list | None = None,
        initial_eval_history1: list | None = None,
        initial_eval_history2: list | None = None,
    ) -> str:
        iteration = max(len(initial_history1 or []), len(initial_history2 or []))
        layout2, live2 = _prepare_dual_shell(
            ui,
            goal_text,
            max_iter,
            task_a,
            task_b,
            iteration=iteration,
            history1=initial_history1,
            history2=initial_history2,
            eval_history1=initial_eval_history1,
            eval_history2=initial_eval_history2,
        )
        return run_dual_agent_loop(
            goal_text,
            task_a,
            task_b,
            workdir,
            args.worker_model,
            args.eval_model,
            max_iter,
            layout2,
            live2,
            initial_history1=initial_history1,
            initial_history2=initial_history2,
            initial_eval_history1=initial_eval_history1,
            initial_eval_history2=initial_eval_history2,
            mode=current_mode,
            eval_every=eval_every,
            session_context=_session_summaries if _session_summaries else None,
        )

    def _run_goal(goal_text: str) -> str:
        nonlocal current_goal
        current_goal = goal_text
        if current_mode == "dual":
            task_a, task_b = split_goal_to_tasks(goal_text, args.eval_model)
            outcome = _run_dual_goal(goal_text, task_a, task_b)
        else:  # code, research, one_dual
            outcome = _run_single_goal(goal_text)
        _record_session_summary(outcome, goal_text)
        _report_outcome(outcome)
        return outcome

    def _resume_saved_session() -> None:
        nonlocal current_goal
        global _last_session
        if not _last_session:
            _last_session = _load_persisted_session()
        if not _last_session:
            console.print("[yellow]재개할 세션이 없습니다. 먼저 목표를 실행하세요.[/yellow]")
            return

        sess = _last_session
        current_goal = sess.get("goal", current_goal)
        saved_at = sess.get("saved_at", "알 수 없음")
        console.print(Rule("[cyan]세션 재개[/cyan]"))
        console.print(f"[dim]목표:[/dim]    [white]{current_goal[:80]}[/white]")
        console.print(f"[dim]저장:[/dim]    {saved_at}")

        if sess.get("mode") == "dual":
            prev_iters = max(len(sess.get("history1", [])), len(sess.get("history2", [])))
            console.print(f"[dim]반복:[/dim]    {prev_iters}회 완료 (듀얼 모드)")
            console.print(f"[dim]W1 task:[/dim] {sess.get('task_a', '')[:60]}")
            console.print(f"[dim]W2 task:[/dim] {sess.get('task_b', '')[:60]}")
            outcome = _run_dual_goal(
                current_goal,
                sess.get("task_a", current_goal),
                sess.get("task_b", current_goal),
                initial_history1=sess.get("history1"),
                initial_history2=sess.get("history2"),
                initial_eval_history1=sess.get("eval_history1"),
                initial_eval_history2=sess.get("eval_history2"),
            )
        else:
            prev_iters = len(sess.get("history", []))
            last_decision = next(
                (
                    h["decision"]
                    for h in reversed(sess.get("history", []))
                    if h.get("decision") and h.get("type") != "compressed_summary"
                ),
                "없음",
            )
            console.print(f"[dim]반복:[/dim]    {prev_iters}회 완료")
            console.print(f"[dim]마지막 판정:[/dim] {last_decision}")
            outcome = _run_single_goal(
                current_goal,
                initial_history=sess.get("history"),
                initial_eval_history=sess.get("eval_history"),
            )

        _record_session_summary(outcome, current_goal)
        _report_outcome(outcome)

    status = auth_status()
    if not status or not status["has_token"]:
        console.print("[yellow]⚠  로그인되지 않았습니다.[/yellow] y / n / device")
        try:
            ans = safe_input(
                "\x1b[33mlogin\x1b[0m \x1b[37m>\x1b[0m ",
                default="n",
            ).strip().lower()
        except (EOFError, KeyboardInterrupt):
            ans = "n"
        if ans in ("y", ""):
            cmd_auth_login(device=False)
        elif ans == "device":
            cmd_auth_login(device=True)
        else:
            console.print(
                "[dim]로그인을 건너뜁니다. "
                "agentforge auth login 으로 나중에 로그인할 수 있습니다.[/dim]"
            )

    console.print(
        f"[dim]명령을 입력하세요. /help 로 커맨드 목록 확인. "
        f"모드: {current_mode}  |  fast: {'on' if ui.fast_mode else 'off'}[/dim]"
    )

    try:
        while True:
            try:
                raw = ui.get_command().strip()
            except EOFError:
                console.print("[dim]종료합니다.[/dim]")
                break

            if not raw:
                continue

            if raw.startswith("/"):
                token = raw[1:].split(None, 1)
                cmd_name = token[0].lower() if token else ""
                cmd_arg = token[1] if len(token) > 1 else ""

                if cmd_name == "exit":
                    console.print("[dim]종료합니다.[/dim]")
                    break

                if cmd_name == "resume":
                    _resume_saved_session()
                    continue

                if cmd_name == "fast":
                    arg = cmd_arg.strip().lower()
                    if arg in ("", "status"):
                        console.print(
                            f"fast transport: {_fast_mode_label()}  "
                            f"[dim]({'official codex exec' if ui.fast_mode else 'legacy backend'})[/dim]"
                        )
                    elif arg == "on":
                        _apply_fast_mode(True, announce=True)
                    elif arg == "off":
                        _apply_fast_mode(False, announce=True)
                    else:
                        console.print("[red]/fast on|off|status[/red]")
                    continue

                if cmd_name == "mode":
                    if cmd_arg in ("code", "research", "dual", "single", "one_dual"):
                        current_mode = "code" if cmd_arg == "single" else cmd_arg
                        if current_mode == "dual":
                            _prepare_dual_shell(ui, "", max_iter, "", "")
                            console.print("[dim]Dual 모드: Coordinator가 목표를 W1/W2로 분기합니다.[/dim]")
                        else:
                            _prepare_single_shell(ui, "", max_iter)
                        if current_mode == "one_dual":
                            console.print("[dim]One-Dual 모드: 매 iteration A/B 실험, 승자가 다음 base.[/dim]")
                        console.print(f"[cyan]모드 변경: {current_mode}[/cyan]")
                        console.print(f"[dim]명령을 입력하세요. 모드: {current_mode}[/dim]")
                    else:
                        console.print("[red]/mode code|research|dual|single|one_dual[/red]")
                    continue

                if cmd_name == "eval-every":
                    try:
                        n = int(cmd_arg)
                        if n < 1:
                            raise ValueError
                        eval_every = n
                        console.print(f"[cyan]Evaluator: {eval_every}번마다 실행[/cyan]")
                    except ValueError:
                        console.print("[red]1 이상의 숫자를 입력하세요. 예: /eval-every 3[/red]")
                    continue

                if cmd_name == "dir":
                    if not cmd_arg:
                        console.print(f"현재 작업 디렉토리: [cyan]{workdir}[/cyan]")
                        console.print("[dim]변경: /dir <경로>  예) /dir ~/AgentForge[/dim]")
                    else:
                        new_dir = Path(cmd_arg).expanduser().resolve()
                        if not new_dir.exists():
                            console.print(f"[red]존재하지 않는 경로: {new_dir}[/red]")
                        elif not new_dir.is_dir():
                            console.print(f"[red]디렉토리가 아닙니다: {new_dir}[/red]")
                        else:
                            workdir = str(new_dir)
                            console.print(f"[cyan]작업 디렉토리 변경: {workdir}[/cyan]")
                    continue

                if cmd_name == "status":
                    wandb_str = (
                        "[green]✓ 연동됨[/green]"
                        if _WANDB_API_KEY else "[yellow]미연동[/yellow]"
                    )
                    console.print(
                        f"모드: [cyan]{current_mode}[/cyan]  |  "
                        f"eval-every: [cyan]{eval_every}[/cyan]  |  "
                        f"dir: [cyan]{workdir}[/cyan]  |  "
                        f"fast: {_fast_mode_label()}  |  "
                        f"wandb: {wandb_str}"
                    )
                    continue

                if cmd_name == "wandb":
                    _wandb_status()
                    continue

                if cmd_name == "last":
                    if _last_qa_answer:
                        console.print(Panel(
                            _last_qa_answer,
                            title="[bold cyan]마지막 답변[/bold cyan]",
                            border_style="cyan",
                            padding=(0, 1),
                        ))
                    else:
                        console.print("[dim]아직 Q&A 답변이 없습니다.[/dim]")
                    continue

                if cmd_name == "report":
                    _print_report(current_goal)
                    continue

                if cmd_name == "paper":
                    if not cmd_arg:
                        console.print(
                            "[red]사용법: /paper <url>  예) "
                            "/paper https://arxiv.org/abs/2312.xxxxx[/red]"
                        )
                    else:
                        paper_goal = _fetch_paper_and_extract(cmd_arg, args.eval_model)
                        if not paper_goal:
                            console.print("[red]논문 분석 실패. URL을 확인하거나 직접 목표를 입력하세요.[/red]")
                        else:
                            short = paper_goal.split("\n")[0][:80]
                            console.print("[green]✓ 논문 분석 완료[/green]")
                            console.print(f"[dim]목표: {short}[/dim]")
                            _run_goal(paper_goal)
                    continue

                if cmd_name == "mcp":
                    if _IS_SSH:
                        console.print("[yellow]MCP는 로컬 환경에서만 사용 가능합니다.[/yellow]")
                    else:
                        sub_cmd, _, sub_arg = (cmd_arg or "").partition(" ")
                        sub_arg = sub_arg.strip()

                        if sub_cmd == "list" or not sub_cmd:
                            if not _MCP_REGISTRY:
                                console.print("[yellow]연결된 MCP 서버 없음[/yellow]")
                            for sname, client in _MCP_REGISTRY.items():
                                console.print(f"  [green]●[/green] [cyan]{sname}[/cyan]  port={client.port}  툴 {len(client.tools)}개")
                                for t in client.tools:
                                    console.print(f"      [dim]{t['name']}[/dim]")

                        elif sub_cmd == "install":
                            if not sub_arg:
                                console.print("[red]사용법: /mcp install <npm패키지>  예) /mcp install @playwright/mcp[/red]")
                            else:
                                pkg = sub_arg.strip()
                                console.print(f"[cyan]설치 중: {pkg}[/cyan]")
                                r = subprocess.run(
                                    ["npm", "install", "-g", pkg],
                                    capture_output=True, text=True
                                )
                                if r.returncode != 0:
                                    console.print(f"[red]설치 실패:[/red]\n{r.stderr[:400]}")
                                else:
                                    console.print(f"[green]✓ 설치 완료[/green]")
                                    # 서버 이름 추론: @scope/name → name, name → name
                                    sname = pkg.split("/")[-1].replace("-mcp", "").replace("server-", "")
                                    cmd_list = ["npx", pkg, "--headless"] if "playwright" in pkg else ["npx", pkg]
                                    # mcp.json 업데이트
                                    cfg_path = Path.home() / ".agentforge" / "mcp.json"
                                    try:
                                        cfg = json.loads(cfg_path.read_text()) if cfg_path.exists() else {"servers": {}}
                                    except Exception:
                                        cfg = {"servers": {}}
                                    cfg.setdefault("servers", {})[sname] = {"command": cmd_list}
                                    cfg_path.write_text(json.dumps(cfg, indent=2, ensure_ascii=False))
                                    console.print(f"[dim]~/.agentforge/mcp.json 에 '{sname}' 등록됨[/dim]")
                                    # 즉시 연결 시도
                                    client = _MCPClient(sname, cmd_list)
                                    if client.start():
                                        _MCP_REGISTRY[sname] = client
                                        tool_names = [t["name"] for t in client.tools]
                                        console.print(f"[green]✓ 연결됨 — 툴 {len(tool_names)}개: {', '.join(tool_names[:5])}[/green]")
                                    else:
                                        console.print(f"[yellow]설치됐지만 서버 시작 실패. agentforge 재시작 시 자동 연결됩니다.[/yellow]")

                        elif sub_cmd == "remove":
                            if not sub_arg:
                                console.print("[red]사용법: /mcp remove <서버이름>[/red]")
                            else:
                                sname = sub_arg.strip()
                                if sname in _MCP_REGISTRY:
                                    _MCP_REGISTRY[sname].stop()
                                    del _MCP_REGISTRY[sname]
                                cfg_path = Path.home() / ".agentforge" / "mcp.json"
                                if cfg_path.exists():
                                    try:
                                        cfg = json.loads(cfg_path.read_text())
                                        cfg.get("servers", {}).pop(sname, None)
                                        cfg_path.write_text(json.dumps(cfg, indent=2, ensure_ascii=False))
                                    except Exception:
                                        pass
                                console.print(f"[cyan]{sname} 제거됨[/cyan]")
                        else:
                            console.print("[red]사용법: /mcp list | /mcp install <pkg> | /mcp remove <name>[/red]")
                    continue

                if cmd_name == "help":
                    for cmd, desc in SLASH_COMMANDS:
                        console.print(f"  [cyan]{cmd:<30}[/cyan] {desc}")
                    continue

                console.print(f"[red]알 수 없는 커맨드: /{cmd_name}[/red]")
                console.print("[dim]/help 로 커맨드 목록을 확인하세요.[/dim]")
                continue

            _run_goal(raw)
    finally:
        ui.request_exit()


def main():
    argv = sys.argv[1:]

    # --skip-update-check: 업데이트 후 재시작 시 루프 방지
    _skip_update = "--skip-update-check" in argv
    argv = [a for a in argv if a != "--skip-update-check"]

    if argv and argv[0] in ("-r", "--reconnect"):
        _tmux_reconnect(_resolve_cli_workdir(argv[1:]))
        return

    force_new = "--new-session" in argv
    cli_args = [arg for arg in argv if arg != "--new-session"]

    parser = argparse.ArgumentParser(
        prog="agentforge",
        description="Worker + Evaluator 인터랙티브 멀티에이전트 CLI",
    )
    sub = parser.add_subparsers(dest="subcommand")

    auth_parser = sub.add_parser("auth", help="인증 관리 (ChatGPT Plus/Pro)")
    auth_sub = auth_parser.add_subparsers(dest="auth_cmd")

    login_parser = auth_sub.add_parser("login", help="로그인")
    login_parser.add_argument(
        "--device",
        action="store_true",
        help="SSH/헤드리스 환경용 device auth 사용",
    )
    auth_sub.add_parser("logout", help="로그아웃")
    auth_sub.add_parser("status", help="현재 인증 상태 확인")

    parser.add_argument(
        "-d",
        "--dir",
        default=".",
        metavar="DIR",
        help="작업 디렉토리 (기본: 현재 디렉토리)",
    )
    parser.add_argument("--worker-model", default=None, metavar="MODEL", help="Worker 모델")
    parser.add_argument("--eval-model", default=None, metavar="MODEL", help="Evaluator 모델")
    parser.add_argument(
        "-n",
        "--max-iterations",
        type=int,
        default=DEFAULT_MAX_ITER,
        metavar="N",
        help=f"최대 반복 횟수 (기본: {DEFAULT_MAX_ITER})",
    )
    parser.add_argument(
        "--mode",
        choices=["code", "research", "dual", "one_dual"],
        default="code",
        help="실행 모드: code(기본) / research(웹 검색·분석) / dual(W1+W2) / one_dual(매 iter A/B)",
    )
    parser.add_argument(
        "--eval-every",
        type=int,
        default=1,
        metavar="N",
        help="N번 반복마다 Evaluator 실행 (기본: 1, 즉 매번)",
    )
    args = parser.parse_args(cli_args)

    if args.subcommand == "auth":
        if _refresh_codex_bin() is None:
            console.print(f"[red]Error: codex not found at {_codex_display_path()}[/red]")
            sys.exit(1)
        if args.auth_cmd == "login":
            cmd_auth_login(device=getattr(args, "device", False))
        elif args.auth_cmd == "logout":
            cmd_auth_logout()
        elif args.auth_cmd == "status":
            cmd_auth_status()
        else:
            auth_parser.print_help()
        return

    workdir = str(Path(args.dir).resolve())
    max_iter = args.max_iterations

    if not _in_tmux() and _shutil.which("tmux"):
        session_name = _tmux_session_name_for_workdir(workdir)
        if force_new and _tmux_session_exists(session_name):
            subprocess.run(["tmux", "kill-session", "-t", session_name])
        _tmux_launch(cli_args, session_name)

    # 업데이트 체크 (tmux 안에서 실행, 재시작 후에는 스킵)
    if not _skip_update:
        _check_and_update()

    _set_session_context(workdir)

    if not _IS_SSH:
        _mcp_init()
        if _MCP_REGISTRY:
            tool_names = [t["name"] for c in _MCP_REGISTRY.values() for t in c.tools]
            console.print(
                f"[dim]🔌 MCP 서버 {len(_MCP_REGISTRY)}개 연결됨 — 툴: "
                f"{', '.join(tool_names[:6])}{'...' if len(tool_names) > 6 else ''}[/dim]"
            )
        import atexit
        atexit.register(_mcp_stop_all)

    global _ACTIVE_UI
    _ACTIVE_UI = InteractiveShellUI()
    _prepare_single_shell(_ACTIVE_UI, "", max_iter)

    controller = threading.Thread(
        target=_interactive_controller,
        args=(args, workdir, max_iter, _ACTIVE_UI),
        daemon=True,
    )
    controller.start()

    try:
        _ACTIVE_UI.run()
    finally:
        if _ACTIVE_UI is not None:
            _ACTIVE_UI.request_exit()
        controller.join(timeout=2)
        _ACTIVE_UI = None


if __name__ == "__main__":
    main()
