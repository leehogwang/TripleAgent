def _capture_rich_text(*objects, width: int | None = None,
                       height: int | None = None, **print_kwargs) -> str:
    stream = io.StringIO()
    temp_console = Console(
        file=stream,
        force_terminal=True,
        color_system="truecolor",
        width=width,
        height=height,
        legacy_windows=False,
    )
    temp_console.print(*objects, **print_kwargs)
    return stream.getvalue().rstrip("\n")


class SessionContext:
    def __init__(self, workdir: str):
        resolved = str(Path(workdir).resolve())
        base = Path(resolved).name or "root"
        slug = re.sub(r"[^a-zA-Z0-9_.-]+", "-", base).strip("-") or "root"
        digest = hashlib.sha1(resolved.encode("utf-8")).hexdigest()[:10]
        self.workdir = resolved
        self.key = f"{slug}-{digest}"
        self.dir = SESSION_ROOT / self.key
        self.session_file = self.dir / "session.json"
        self.ui_state_file = self.dir / "ui_state.json"
        self.event_log_file = self.dir / "events.jsonl"
        self.tmux_session = f"agentforge-{digest}"


_SESSION_CTX: SessionContext | None = None


def _write_json_atomic(path: Path, data: dict) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_name(path.name + ".tmp")
    tmp.write_text(json.dumps(data, ensure_ascii=False, indent=2))
    tmp.replace(path)


def _append_jsonl(path: Path, payload: dict) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    with path.open("a", encoding="utf-8") as f:
        f.write(json.dumps(payload, ensure_ascii=False) + "\n")


def _set_session_context(workdir: str) -> SessionContext:
    global _SESSION_CTX
    _SESSION_CTX = SessionContext(workdir)
    _SESSION_CTX.dir.mkdir(parents=True, exist_ok=True)
    return _SESSION_CTX


