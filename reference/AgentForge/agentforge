# ── MCP Client ────────────────────────────────────────────────────────────────

class _MCPClient:
    """
    HTTP(Streamable) 기반 MCP 서버 클라이언트.
    서버 프로세스를 띄우고 POST /mcp 로 JSON-RPC 2.0 통신.
    """
    def __init__(self, name: str, command: list[str],
                 port: int = 0, env: dict | None = None):
        self.name = name
        self.command = command
        self.env = env
        self.port = port or self._find_free_port()
        self._proc: subprocess.Popen | None = None
        self._req_id = 0
        self._session_id: str | None = None
        self.tools: list[dict] = []

    @staticmethod
    def _find_free_port() -> int:
        import socket
        with socket.socket() as s:
            s.bind(("", 0))
            return s.getsockname()[1]

    def start(self) -> bool:
        try:
            _env = os.environ.copy()
            if self.env:
                _env.update(self.env)
            cmd = self.command + ["--port", str(self.port)]
            self._proc = subprocess.Popen(
                cmd, stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL, env=_env,
            )
            # 서버 준비 대기 (최대 8초)
            base = f"http://localhost:{self.port}"
            for _ in range(16):
                time.sleep(0.5)
                try:
                    r = _requests.get(base, timeout=1)
                    break
                except Exception:
                    continue
            else:
                return False
            # initialize
            resp = self._post("initialize", {
                "protocolVersion": "2024-11-05",
                "capabilities": {},
                "clientInfo": {"name": "agentforge", "version": "1.0"},
            })
            if resp is None:
                return False
            self._post_notify("notifications/initialized", {})
            self.tools = self._discover_tools()
            return True
        except Exception:
            self._proc = None
            return False

    def stop(self):
        try:
            if self._proc:
                self._proc.terminate()
                self._proc = None
        except Exception:
            pass

    def _next_id(self) -> int:
        self._req_id += 1
        return self._req_id

    def _post(self, method: str, params: dict) -> dict | None:
        req_id = self._next_id()
        body = {"jsonrpc": "2.0", "id": req_id, "method": method, "params": params}
        headers = {
            "Content-Type": "application/json",
            "Accept": "application/json, text/event-stream",
        }
        if self._session_id:
            headers["mcp-session-id"] = self._session_id
        try:
            r = _requests.post(
                f"http://localhost:{self.port}/mcp",
                json=body, headers=headers, timeout=60,
            )
            if "mcp-session-id" in r.headers:
                self._session_id = r.headers["mcp-session-id"]
            if r.status_code == 202:
                return {}
            ct = r.headers.get("content-type", "")
            if "text/event-stream" in ct:
                for line in r.text.splitlines():
                    if line.startswith("data:"):
                        data = line[5:].strip()
                        if data and data != "[DONE]":
                            return json.loads(data)
                return None
            return r.json()
        except Exception:
            return None

    def _post_notify(self, method: str, params: dict):
        body = {"jsonrpc": "2.0", "method": method, "params": params}
        headers = {"Content-Type": "application/json"}
        if self._session_id:
            headers["mcp-session-id"] = self._session_id
        try:
            _requests.post(
                f"http://localhost:{self.port}/mcp",
                json=body, headers=headers, timeout=5,
            )
        except Exception:
            pass

    def _discover_tools(self) -> list[dict]:
        resp = self._post("tools/list", {})
        if not resp or "result" not in resp:
            return []
        tools = []
        for t in resp["result"].get("tools", []):
            tools.append({
                "type": "function",
                "name": f"mcp__{self.name}__{t['name']}",
                "description": f"[MCP:{self.name}] {t.get('description', '')}",
                "parameters": t.get("inputSchema", {"type": "object", "properties": {}}),
                "strict": False,
            })
        return tools

    def call(self, tool_name: str, args: dict) -> str:
        actual = tool_name.removeprefix(f"mcp__{self.name}__")
        resp = self._post("tools/call", {"name": actual, "arguments": args})
        if not resp:
            return f"[MCP:{self.name}] 응답 없음"
        if "error" in resp:
            return f"[MCP:{self.name}] 오류: {resp['error'].get('message', str(resp['error']))}"
        content = resp.get("result", {}).get("content", [])
        parts = []
        for c in content:
            if c.get("type") == "text":
                parts.append(c.get("text", ""))
            elif c.get("type") == "image":
                parts.append(f"[image: {c.get('mimeType','?')}]")
        return "\n".join(parts) if parts else str(resp.get("result", ""))


# MCP 서버 레지스트리
_MCP_REGISTRY: dict[str, _MCPClient] = {}

def _mcp_init():
    global _MCP_REGISTRY
    config_path = Path.home() / ".agentforge" / "mcp.json"
    if not config_path.exists():
        return  # mcp.json 없으면 MCP 비활성화
    try:
        cfg = json.loads(config_path.read_text(encoding="utf-8"))
        servers = cfg.get("servers", {})
    except Exception:
        return
    for name, conf in servers.items():
        cmd = conf.get("command", [])
        env = conf.get("env", None) or None
        port = conf.get("port", 0)
        client = _MCPClient(name, cmd, port=port, env=env)
        if client.start():
            _MCP_REGISTRY[name] = client

def _mcp_stop_all():
    for c in _MCP_REGISTRY.values():
        c.stop()
    _MCP_REGISTRY.clear()

def _mcp_all_tools() -> list[dict]:
    """모든 MCP 서버의 tool 목록을 합쳐서 반환."""
    tools = []
    for c in _MCP_REGISTRY.values():
        tools.extend(c.tools)
    return tools

def _mcp_call(tool_name: str, args: dict) -> str | None:
    """tool_name이 mcp__ 로 시작하면 해당 서버로 라우팅. 아니면 None."""
    if not tool_name.startswith("mcp__"):
        return None
    parts = tool_name.split("__", 2)
    if len(parts) < 2:
        return f"잘못된 MCP 툴명: {tool_name}"
    server_name = parts[1]
    client = _MCP_REGISTRY.get(server_name)
    if not client:
        return f"[MCP] 서버 '{server_name}' 없음 (등록된 서버: {list(_MCP_REGISTRY.keys())})"
    return client.call(tool_name, args)

