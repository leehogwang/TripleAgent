# ── Stagnation Detection ──────────────────────────────────────────────────────

def _detect_stagnation(history: list, threshold: int = STAGNATION_THRESHOLD) -> bool:
    """CONTINUE를 건너뛰고 IMPROVE/REDIRECT만 추출해 N회 유사 피드백이면 정체."""
    real = [h for h in history if h.get('type') != 'compressed_summary']
    # CONTINUE는 무시하고 IMPROVE/REDIRECT만 추출
    improve_only = [h for h in real if h.get('decision') in ('IMPROVE', 'REDIRECT')]
    if len(improve_only) < threshold:
        return False
    recent = improve_only[-threshold:]
    feedbacks = [h.get('feedback', '')[:80] for h in recent]
    summaries = [h.get('worker_summary', '')[:80] for h in recent]
    # 완전 동일
    if len(set(feedbacks)) == 1 or len(set(summaries)) == 1:
        return True
    # 단어 겹침으로 유사도 판단 (Jaccard ≥ 0.3 → 유사)
    def _jaccard(a: str, b: str) -> float:
        sa, sb = set(a.lower().split()), set(b.lower().split())
        if not sa or not sb:
            return 0.0
        return len(sa & sb) / len(sa | sb)
    for i in range(len(feedbacks) - 1):
        if _jaccard(feedbacks[i], feedbacks[i + 1]) < 0.3:
            return False
    return True


# ── A/B Strategy Fork ────────────────────────────────────────────────────────

def _run_ab_strategy(
    goal: str, history: list, workdir: str,
    worker_model: str | None, worker_sys: str, active_tools: list,
    eval_model: str | None, past_attempts: list,
    worker_buf: deque, iteration: int, refresh,
    code_only: bool = False,
    policy_profile: dict | None = None,
    last_spoken_ref: list[str] | None = None,
) -> tuple[str | None, str]:
    """
    2개의 Worker를 서로 다른 전략으로 순차 실행하고 Evaluator가 더 나은 쪽 채택.
    code_only=True: workers는 코드 작성만(학습 실행 X), 평가자가 코드/접근법 비교.
                    평가자가 RETRY하면 최대 3회 재시도. 한도 초과 시 "no_pick" 반환.
    반환: (selected_output, "A" | "B" | "interrupted" | "no_pick")
    """
    base_patch = _cp_save(workdir)
    if base_patch is None:
        worker_buf.append("[yellow]⚠ 스냅샷 저장 실패 — 단일 Worker로 계속합니다.[/yellow]")
        return None, "no_pick"

    DEFAULT_HINTS = [
        "\n\n[STRATEGY A] 이전에 시도한 방법과 완전히 다른 접근법을 사용하라. 기존 시도와 겹치는 방법은 금지.",
        "\n\n[STRATEGY B] 문제를 가장 작은 단위로 분해하여 핵심 원인부터 해결하라. 가장 기본적이고 단순한 것부터 시작.",
    ]

    MAX_CODE_RETRIES = 3
    retry_feedback = ""
    chosen: str | None = None
    final_outputs: list[str] = []
    final_patches: list[str | None] = []

    attempts = range(MAX_CODE_RETRIES) if code_only else range(1)

    for attempt in attempts:
        if attempt > 0:
            worker_buf.append(
                f"[yellow]↩ A/B 재시도 {attempt}/{MAX_CODE_RETRIES - 1} "
                f"— {retry_feedback[:80]}[/yellow]"
            )
            refresh("worker", iteration)
            _cp_restore(workdir, base_patch)

        if code_only:
            no_train_suffix = "\n학습 스크립트를 수정/작성하되 학습은 실행하지 마라. 코드 완성 후 멈춰라."
            feedback_suffix = f"\n[평가자 피드백] {retry_feedback}" if retry_feedback else ""
            hints = [
                "\n\n[STRATEGY A] 현재 접근법을 점진적으로 개선하라." + no_train_suffix + feedback_suffix,
                "\n\n[STRATEGY B] 현재와 완전히 다른 접근법을 제안하라." + no_train_suffix + feedback_suffix,
            ]
        else:
            hints = DEFAULT_HINTS

        outputs: list[str] = []
        patches: list[str | None] = []

        for i, (label, hint) in enumerate([("A", hints[0]), ("B", hints[1])]):
            if _interrupt_event.is_set():
                _cp_delete(base_patch)
                return None, "interrupted"

            if i == 1:
                _cp_restore(workdir, base_patch)

            worker_buf.append(f"[cyan bold]── 전략 {label} ─────────────────────────────[/cyan bold]")
            refresh("worker", iteration)

            prompt = build_worker_prompt(
                goal,
                history,
                past_attempts=past_attempts,
                policy_profile=policy_profile,
            ) + hint
            buf_tmp: deque = deque(maxlen=WORKER_BUF_LINES)
            status_tmp = ["idle"]
            res: list = [None]

            def _w(p=prompt, b=buf_tmp, s=status_tmp):
                out, _ = run_worker(p, workdir, worker_model, b, s,
                                    system_prompt=worker_sys, tools=active_tools,
                                    goal_context=goal, iteration_id=iteration,
                                    last_spoken_ref=last_spoken_ref)
                res[0] = out

            t = threading.Thread(target=_w, daemon=True)
            t.start()
            while t.is_alive():
                if _interrupt_event.is_set():
                    break
                for line in list(buf_tmp):
                    worker_buf.append(f"[dim][{label}][/dim] {line}")
                buf_tmp.clear()
                refresh("worker", iteration)
                time.sleep(0.1)
            t.join(timeout=10)

            if _interrupt_event.is_set():
                _cp_delete(base_patch)
                return None, "interrupted"

            outputs.append(res[0] or "")
            patches.append(_cp_save(workdir))

        # ── Evaluator: A vs B 비교 ─────────────────────────────────────────
        worker_buf.append("[magenta bold]── Evaluator: 전략 A vs B 비교 중 ──────────[/magenta bold]")
        refresh("evaluator", iteration)

        compare_prompt = "\n".join([
            f"GOAL: {goal}",
            "",
            "=== 전략 A ===" if code_only else "=== 전략 A 실행 결과 ===",
            outputs[0][-2000:],
            "",
            "=== 전략 B ===" if code_only else "=== 전략 B 실행 결과 ===",
            outputs[1][-2000:],
            "",
            "어느 전략이 GOAL에 더 유망한가?" if code_only else "어느 전략이 목표에 더 가까운가?",
        ])
        compare_sys = AB_COMPARE_CODE_SYSTEM if code_only else AB_COMPARE_SYSTEM
        eval_msg, _ = run_evaluator(compare_prompt, workdir, eval_model,
                                    system_prompt=compare_sys)

        m = _AB_PICK_RE.search(eval_msg)
        if m:
            chosen = m.group(1).upper()
            final_outputs = outputs
            final_patches = patches
            break

        if not code_only:
            # code_only=False: PICK 없으면 B로 fallback (기존 동작 유지)
            chosen = "B"
            final_outputs = outputs
            final_patches = patches
            break

        # RETRY 경로: 평가자 피드백 저장 후 다음 attempt
        retry_feedback = eval_msg.strip()[:300]
        worker_buf.append(f"[yellow]평가자: 재시도 요청 — {retry_feedback[:60]}[/yellow]")
        refresh("worker", iteration)
        # patches 정리 (다음 attempt를 위해 base_patch만 남김)
        for p in patches:
            _cp_delete(p)
    else:
        # 최대 재시도 소진
        worker_buf.append("[yellow]⚠ A/B 최대 재시도 초과 → 일반 워커로 계속[/yellow]")
        refresh("worker", iteration)
        _cp_restore(workdir, base_patch)
        _cp_delete(base_patch)
        return None, "no_pick"

    # ── 선택된 전략 적용 ──────────────────────────────────────────────────────
    chosen_idx = 0 if chosen == "A" else 1
    other_idx  = 1 - chosen_idx

    worker_buf.append(f"[green bold]✓ 전략 {chosen} 채택됨[/green bold]")
    refresh("worker", iteration)

    if chosen == "A":
        _cp_restore(workdir, final_patches[0])

    _cp_delete(base_patch)
    _cp_delete(final_patches[other_idx])
    _cp_delete(final_patches[chosen_idx])

    return final_outputs[chosen_idx], chosen


