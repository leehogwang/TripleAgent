_EMBED_MODEL = None
_EMBED_MODEL_NAME = "paraphrase-multilingual-MiniLM-L12-v2"

def _get_embed_model():
    """sentence-transformers 모델 lazy 로드 (최초 1회만)."""
    global _EMBED_MODEL
    if _EMBED_MODEL is None:
        try:
            import warnings
            warnings.filterwarnings("ignore", category=FutureWarning)
            from sentence_transformers import SentenceTransformer
            _EMBED_MODEL = SentenceTransformer(_EMBED_MODEL_NAME)
        except Exception:
            _EMBED_MODEL = False  # 실패 시 폴백 표시
    return _EMBED_MODEL if _EMBED_MODEL is not False else None


def _embed_goal(text: str):
    """goal 텍스트 임베딩 벡터 반환. 모델 없으면 None."""
    model = _get_embed_model()
    if model is None:
        return None
    try:
        import numpy as np
        vec = model.encode(text, normalize_embeddings=True)
        return vec.astype(np.float32)
    except Exception:
        return None


def _cosine_sim(a, b) -> float:
    """두 정규화된 벡터의 cosine similarity (내적)."""
    try:
        import numpy as np
        return float(np.dot(a, b))
    except Exception:
        return 0.0


def _goal_similarity_fallback(a: str, b: str) -> float:
    """임베딩 불가 시 토큰 recall 폴백."""
    def tokens(s: str) -> set:
        return set(re.sub(r'[^\w가-힣]', ' ', s.lower()).split())
    ta, tb = tokens(a), tokens(b)
    if not ta or not tb:
        return 0.0
    shorter, longer = (ta, tb) if len(ta) <= len(tb) else (tb, ta)
    return len(shorter & longer) / len(shorter)


def _ensure_goal_txt(d: Path) -> str:
    """goal.txt 없으면 폴더명으로 복원 후 저장. 내용 반환."""
    goal_txt = d / "goal.txt"
    if goal_txt.exists():
        try:
            return goal_txt.read_text(encoding="utf-8").strip()
        except Exception:
            pass
    text = d.name.replace("_", " ")
    try:
        goal_txt.write_text(text, encoding="utf-8")
    except Exception:
        pass
    return text


def _ensure_goal_embedding(d: Path, goal_text: str):
    """
    goal_embedding.npy 없으면 계산해서 저장.
    저장된 벡터 반환. 실패 시 None.
    """
    import numpy as np
    emb_path = d / "goal_embedding.npy"
    if emb_path.exists():
        try:
            return np.load(str(emb_path))
        except Exception:
            pass
    vec = _embed_goal(goal_text)
    if vec is not None:
        try:
            np.save(str(emb_path), vec)
        except Exception:
            pass
    return vec


def _find_similar_goals(goal: str, threshold: float = 0.6) -> list[Path]:
    """
    KNOWLEDGE_DIR 내 모든 폴더와 유사도 비교.
    - 임베딩 사용 가능: cosine similarity (goal_embedding.npy)
    - 불가능: 토큰 recall 폴백
    임계값 이상인 폴더 목록 반환 (현재 goal 폴더 제외).
    """
    if not KNOWLEDGE_DIR.exists():
        return []

    current_slug = _goal_to_slug(goal)
    use_embedding = _get_embed_model() is not None
    current_vec = _embed_goal(goal) if use_embedding else None

    matched = []
    for d in KNOWLEDGE_DIR.iterdir():
        if not d.is_dir() or d.name == current_slug:
            continue
        candidate_text = _ensure_goal_txt(d)
        if use_embedding and current_vec is not None:
            cand_vec = _ensure_goal_embedding(d, candidate_text)
            if cand_vec is not None:
                sim = _cosine_sim(current_vec, cand_vec)
            else:
                sim = _goal_similarity_fallback(goal, candidate_text)
        else:
            sim = _goal_similarity_fallback(goal, candidate_text)
        if sim >= threshold:
            matched.append((sim, d))

    matched.sort(key=lambda x: x[0], reverse=True)
    return [d for _, d in matched]


def _load_attempts_from_dir(d: Path) -> list[dict]:
    """디렉토리에서 attempts.jsonl 로드."""
    try:
        records = []
        events_path = d / "events.jsonl"
        if events_path.exists():
            for line in events_path.read_text(encoding="utf-8").splitlines():
                line = line.strip()
                if not line:
                    continue
                try:
                    item = json.loads(line)
                    if isinstance(item, dict):
                        item.setdefault("event_type", "generic")
                        records.append(item)
                except Exception:
                    pass

        legacy_path = d / "attempts.jsonl"
        if legacy_path.exists():
            for line in legacy_path.read_text(encoding="utf-8").splitlines():
                line = line.strip()
                if not line:
                    continue
                try:
                    item = json.loads(line)
                except Exception:
                    continue
                if not isinstance(item, dict):
                    continue
                item.setdefault("event_type", "attempt_summary")
                records.append(item)

        records.sort(key=lambda item: str(item.get("timestamp", "")))
        deduped = []
        seen = set()
        for item in records:
            key = (
                item.get("event_type"),
                item.get("timestamp"),
                item.get("iter"),
                item.get("tool_name"),
                item.get("path"),
                item.get("decision"),
                item.get("worker_summary"),
            )
            if key in seen:
                continue
            seen.add(key)
            deduped.append(item)
        return deduped
    except Exception:
        return []


def _load_past_attempts(goal: str) -> list[dict]:
    """
    과거 시도 기록 로드.
    1) 현재 goal 폴더 exact match
    2) 유사 goal 폴더들 (Jaccard >= 0.6) 도 합산
    """
    # 현재 goal의 폴더에 goal.txt + 임베딩 저장 (향후 유사도 비교용)
    try:
        gdir = _knowledge_path(goal)
        gtxt = gdir / "goal.txt"
        if not gtxt.exists():
            gtxt.write_text(goal, encoding="utf-8")
        _ensure_goal_embedding(gdir, goal)
    except Exception:
        pass

    records = _load_attempts_from_dir(_knowledge_path(goal))

    # 유사 goal 폴더 병합
    similar_dirs = _find_similar_goals(goal, threshold=0.6)
    seen_dirs = {_goal_to_slug(goal)}
    for d in similar_dirs:
        if d.name not in seen_dirs:
            seen_dirs.add(d.name)
            records += _load_attempts_from_dir(d)

    return records


def _retrieve_relevant(query: str, attempts: list[dict], top_k: int = 6) -> list[dict]:
    """
    BM25로 query와 가장 관련 있는 과거 시도 검색.
    rank_bm25 없으면 단어 overlap 기반 폴백.
    """
    if not attempts:
        return []

    def _text(a: dict) -> str:
        event_type = a.get("event_type", "generic")
        parts = [
            event_type,
            a.get("decision", ""),
            a.get("reason_type", ""),
            a.get("feedback", ""),
            a.get("next_action", ""),
            a.get("worker_summary", ""),
            a.get("hypothesis", ""),
            a.get("tool_name", ""),
            a.get("command", ""),
            a.get("path", ""),
            a.get("artifact_path", ""),
            a.get("metric_name", ""),
            str(a.get("metric_value", "")),
            " ".join(a.get("changed_files", []) if isinstance(a.get("changed_files"), list) else []),
        ]
        summary = a.get("summary")
        if isinstance(summary, dict):
            parts.extend([
                summary.get("judgment", ""),
                summary.get("result_summary", ""),
                " ".join(summary.get("result_paths", []) if isinstance(summary.get("result_paths"), list) else []),
            ])
        return " ".join(str(part) for part in parts if part)

    try:
        from rank_bm25 import BM25Okapi
        corpus = [_text(a).lower().split() for a in attempts]
        bm25 = BM25Okapi(corpus)
        scores = bm25.get_scores(query.lower().split())
        top_idx = sorted(range(len(scores)), key=lambda i: scores[i], reverse=True)[:top_k]
        return [attempts[i] for i in top_idx]
    except Exception:
        # 폴백: 단어 overlap 점수
        q_words = set(query.lower().split())
        scored = []
        for a in attempts:
            words = set(_text(a).lower().split())
            scored.append((len(q_words & words), a))
        scored.sort(key=lambda x: x[0], reverse=True)
        return [a for _, a in scored[:top_k]]


def _build_rag_section(past_attempts: list[dict], current_context: str) -> str:
    """
    현재 상황과 관련된 과거 시도를 RAG로 검색하여
    Worker 프롬프트에 삽입할 경고 섹션 생성.
    """
    if not past_attempts:
        return ""

    MAX_FULL = 50
    if len(past_attempts) <= MAX_FULL:
        relevant = past_attempts
    else:
        relevant = _retrieve_relevant(current_context, past_attempts, top_k=50)
    if not relevant:
        return ""

    lines = [
        "━" * 60,
        "PAST MEMORY EVENTS FROM PREVIOUS SESSIONS — USE THESE TO AVOID REPEATING FAILURES:",
    ]
    for a in relevant:
        event_type = a.get("event_type", "generic")
        ts = str(a.get("timestamp", ""))[:10]
        if event_type == "tool_call":
            lines.append(
                f"  [tool_call] ({ts}) {a.get('tool_name','?')} -> "
                f"{a.get('result_summary','')[:160]}"
            )
            continue
        if event_type == "file_change":
            lines.append(
                f"  [file_change] ({ts}) {a.get('path','')} "
                f"(rolled_back={a.get('rolled_back', False)})"
            )
            continue
        if event_type == "metric":
            lines.append(
                f"  [metric] ({ts}) {a.get('metric_name','metric')}={a.get('metric_value','')}"
            )
            continue
        if event_type == "decision":
            lines.append(
                f"  [decision] ({ts}) {a.get('decision','?')} / {a.get('reason_type','other')}"
            )
            if a.get("next_action"):
                lines.append(f"    next: {a.get('next_action','')[:180]}")
            if a.get("worker_summary"):
                lines.append(f"    worker: {a.get('worker_summary','')[:160]}")
            continue

        decision = a.get("decision", "?")
        feedback = a.get("feedback", "")[:200]
        summary = a.get("worker_summary", "")[:150]
        badge = {"DONE": "✓", "IMPROVE": "▲", "REDIRECT": "↩", "CONTINUE": "→"}.get(decision, "?")
        lines.append(f"  [{badge} {decision}] ({ts}) {feedback}")
        if summary:
            lines.append(f"    tried: {summary}")
        hyp = a.get("hypothesis", "")
        if hyp:
            lines.append(f"    hypothesis was: {hyp[:160]}")
    lines.append("━" * 60)
    return "\n".join(lines)


def _extract_hypothesis(text: str) -> str:
    m = _HYPOTHESIS_RE.search(text)
    return m.group(1).strip()[:200] if m else ""


def _write_report_entry(goal: str, iteration: int, decision: str,
                        feedback: str, worker_summary: str,
                        hypothesis: str = "") -> None:
    """각 iteration 판정을 Markdown 리포트에 append."""
    try:
        path = _knowledge_path(goal) / "report.md"
        if not path.exists():
            path.write_text(
                f"# AgentForge 실험 리포트\n\n"
                f"**목표:** {goal}\n\n"
                f"**시작:** {time.strftime('%Y-%m-%d %H:%M:%S')}\n\n"
                f"---\n\n",
                encoding="utf-8",
            )
        badge = {"DONE": "✅", "IMPROVE": "🔄", "REDIRECT": "↩️"}.get(decision, "❓")
        entry = (
            f"## Iter {iteration} — {badge} {decision}\n\n"
            + (f"**가설:** {hypothesis}\n\n" if hypothesis else "")
            + f"**Worker 작업:** {worker_summary[:300]}\n\n"
            + f"**Evaluator 판정:** {feedback[:300]}\n\n"
            + f"*{time.strftime('%H:%M:%S')}*\n\n---\n\n"
        )
        with open(path, "a", encoding="utf-8") as f:
            f.write(entry)
    except Exception:
        pass


def _try_visualize(workdir: str, goal: str) -> list[str]:
    """학습 완료 후 결과 시각화 시도. 생성된 플롯 경로 목록 반환."""
    try:
        import matplotlib
        matplotlib.use('Agg')
        import matplotlib.pyplot as plt
    except ImportError:
        return []

    plots: list[str] = []
    plot_dir = _knowledge_path(goal) / "plots"
    plot_dir.mkdir(exist_ok=True)

    import csv as _csv
    for csv_path in list(Path(workdir).rglob("*.csv"))[:5]:
        try:
            with open(csv_path, newline='', errors='replace') as f:
                rows = list(_csv.DictReader(f))
            if len(rows) < 3:
                continue
            headers = list(rows[0].keys())
            x_col = next((h for h in headers
                          if h.lower() in ('epoch', 'step', 'iteration', 'iter')), None)
            if not x_col:
                continue
            metric_cols = [h for h in headers
                           if any(kw in h.lower() for kw in ('loss', 'acc', 'map', 'f1', 'score', 'auc'))
                           and h != x_col]
            if not metric_cols:
                continue
            n = min(len(metric_cols), 4)
            fig, axes = plt.subplots(1, n, figsize=(5 * n, 4), squeeze=False)
            x = [float(r[x_col]) for r in rows if r.get(x_col, '').strip()]
            for i, col in enumerate(metric_cols[:4]):
                y = []
                for r in rows:
                    try:
                        y.append(float(r[col]))
                    except (ValueError, TypeError):
                        y.append(float('nan'))
                axes[0][i].plot(x[:len(y)], y)
                axes[0][i].set_title(col, fontsize=10)
                axes[0][i].set_xlabel(x_col, fontsize=8)
                axes[0][i].grid(True, alpha=0.3)
            plt.suptitle(csv_path.stem, fontsize=11)
            plt.tight_layout()
            out = plot_dir / f"{csv_path.stem}.png"
            plt.savefig(out, dpi=100, bbox_inches='tight')
            plt.close()
            plots.append(str(out))
        except Exception:
            plt.close('all')

    loss_re = re.compile(r'(?:loss|Loss)[\s:=]+([0-9]+\.?[0-9]*(?:e[-+]?\d+)?)')
    acc_re  = re.compile(r'(?:acc(?:uracy)?|Acc)[\s:=]+([0-9]+\.?[0-9]*)')
    log_files = list(Path(workdir).rglob("*.log")) + list(Path(workdir).rglob("train*.txt"))
    for log_path in log_files[:3]:
        try:
            text = log_path.read_text(errors='replace')
            losses = [float(m) for m in loss_re.findall(text)]
            accs   = [float(m) for m in  acc_re.findall(text)]
            if len(losses) < 3:
                continue
            n = 2 if len(accs) >= 3 else 1
            fig, axes = plt.subplots(1, n, figsize=(6 * n, 4), squeeze=False)
            axes[0][0].plot(losses)
            axes[0][0].set_title('Loss', fontsize=10)
            axes[0][0].set_xlabel('Step', fontsize=8)
            axes[0][0].grid(True, alpha=0.3)
            if n == 2:
                axes[0][1].plot(accs)
                axes[0][1].set_title('Accuracy', fontsize=10)
                axes[0][1].set_xlabel('Step', fontsize=8)
                axes[0][1].grid(True, alpha=0.3)
            plt.suptitle(log_path.stem, fontsize=11)
            plt.tight_layout()
            out = plot_dir / f"{log_path.stem}.png"
            plt.savefig(out, dpi=100, bbox_inches='tight')
            plt.close()
            plots.append(str(out))
        except Exception:
            plt.close('all')

    return plots


