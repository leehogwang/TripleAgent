def _execute_tool(name: str, args: dict, workdir: str, worker_id: int = 0) -> str:
    """Worker 도구 실행."""
    # ── DEBUG: 도구 호출 시작 시각 기록 ──────────────────────────────────────
    _dbg_label = f"W{worker_id}" if worker_id else "W?"
    _arg_preview = str(args)[:120].replace("\n", " ")
    _dbg(_dbg_label, f"TOOL_START  {name}  args={_arg_preview}")
    _t0 = time.time()
    # ── END DEBUG ────────────────────────────────────────────────────────────
    try:
        # MCP 툴 라우팅
        mcp_result = _mcp_call(name, args)
        if mcp_result is not None:
            return mcp_result

        if name == "shell":
            timeout = min(int(args.get("timeout_seconds", 120)), 7200)
            _env = os.environ.copy()
            _env.setdefault('CUDA_VISIBLE_DEVICES', '2')
            if _WANDB_API_KEY:
                _env.setdefault('WANDB_API_KEY', _WANDB_API_KEY)
                _env.setdefault('WANDB_PROJECT', Path(workdir).name)
            # GPU 충돌 체크 (듀얼 워커 모드)
            gpu = None
            if worker_id in (1, 2):
                gpu = _detect_gpu_in_command(args["command"])
                if gpu is not None:
                    other_id = 2 if worker_id == 1 else 1
                    with _ACTIVE_GPU_LOCK:
                        other_gpu = _ACTIVE_GPU.get(other_id)
                    if other_gpu == gpu:
                        util = _check_gpu_capacity(gpu)
                        if util is not None and util >= _GPU_CONFLICT_THRESH:
                            return (
                                f"GPU_CONFLICT: GPU {gpu}는 Worker {other_id}이 "
                                f"점유 중입니다 ({util*100:.0f}% 사용). "
                                f"추가 학습 여력이 없습니다."
                            )
                    with _ACTIVE_GPU_LOCK:
                        _ACTIVE_GPU[worker_id] = gpu
            proc = subprocess.Popen(
                args["command"], shell=True,
                stdout=subprocess.PIPE, stderr=subprocess.STDOUT,
                text=True, errors='replace', cwd=workdir,
                start_new_session=True, env=_env,
            )
            with _active_procs_lock:
                _active_procs.add(proc)
            try:
                stdout, _ = proc.communicate(timeout=timeout)
                out = (stdout or "").strip()
                return (out[:6000] if out else "(no output)") + (
                    f"\n[exit code: {proc.returncode}]" if proc.returncode else ""
                )
            except subprocess.TimeoutExpired:
                try:
                    if hasattr(os, 'killpg'):
                        os.killpg(os.getpgid(proc.pid), _signal.SIGKILL)
                    else:
                        proc.kill()
                except (ProcessLookupError, OSError):
                    pass
                proc.wait()
                return f"(timeout after {timeout}s — process group killed)"
            finally:
                with _active_procs_lock:
                    _active_procs.discard(proc)
                if worker_id in (1, 2) and gpu is not None:
                    with _ACTIVE_GPU_LOCK:
                        if _ACTIVE_GPU.get(worker_id) == gpu:
                            _ACTIVE_GPU[worker_id] = None
        elif name == "data_profile":
            data_path = Path(args["path"])
            if not data_path.is_absolute():
                data_path = Path(workdir) / data_path
            try:
                import pandas as pd
                if data_path.suffix == '.parquet':
                    df = pd.read_parquet(data_path)
                elif data_path.suffix == '.json':
                    df = pd.read_json(data_path)
                else:
                    df = pd.read_csv(data_path)
                target = args.get("target_col")
                lines = [
                    f"📊 Dataset: {data_path.name}  ({len(df):,} rows × {len(df.columns)} cols)",
                    "", "── Column Overview ──",
                ]
                for col in df.columns:
                    dtype = df[col].dtype
                    null_pct = df[col].isna().mean() * 100
                    n_unique = df[col].nunique()
                    if dtype == object or str(dtype) == 'category':
                        top = df[col].value_counts().head(3).to_dict()
                        lines.append(f"  {col} [cat, {n_unique} unique, {null_pct:.1f}% null]: top={list(top.keys())}")
                    else:
                        try:
                            desc = df[col].describe()
                            lines.append(f"  {col} [{dtype}, {null_pct:.1f}% null]: "
                                         f"min={desc['min']:.3g} mean={desc['mean']:.3g} max={desc['max']:.3g}")
                        except Exception:
                            lines.append(f"  {col} [{dtype}, {null_pct:.1f}% null]")
                lines += ["", "── Feature Engineering Suggestions ──"]
                date_cols = [c for c in df.columns
                             if any(kw in c.lower() for kw in ('date','time','dt','year','month','hour'))]
                if date_cols:
                    lines.append(f"  📅 Date features: extract year/month/day/weekday/hour from {date_cols}")
                high_card = [c for c in df.select_dtypes('object').columns if df[c].nunique() > 20]
                if high_card:
                    lines.append(f"  🔤 High-cardinality: target-encode or embed {high_card}")
                missing_cols = df.columns[df.isna().mean() > 0.1].tolist()
                if missing_cols:
                    lines.append(f"  ❓ High missing (>10%): impute or add indicator for {missing_cols}")
                num_cols = df.select_dtypes('number').columns.tolist()
                if target and target in df.columns and len(num_cols) > 1:
                    corr = df[num_cols].corr()[target].drop(target).abs().sort_values(ascending=False)
                    lines.append(f"  ⭐ Top corr with '{target}': {corr.head(5).index.tolist()}")
                    low = corr[corr < 0.05].index.tolist()
                    if low:
                        lines.append(f"  ⚠  Low corr (<0.05), consider dropping: {low[:5]}")
                skewed = [c for c in num_cols
                          if abs(float(df[c].skew())) > 2 and c != target]
                if skewed:
                    lines.append(f"  📊 High skew: log/sqrt transform {skewed[:5]}")
                if target and target in df.columns:
                    vc = df[target].value_counts(normalize=True)
                    if len(vc) > 1 and vc.iloc[0] > 0.8:
                        lines.append(f"  ⚖️  Class imbalance ({vc.iloc[0]*100:.0f}% dominant): use SMOTE/class_weight")
                return "\n".join(lines)
            except ImportError:
                return "Error: pandas not installed. Run: pip install pandas"
            except Exception as e:
                return f"Error profiling {data_path}: {e}"
        elif name == "shell_background":
            log_path = args.get("log_path") or f"/tmp/agentforge_bg_{int(time.time())}.log"
            log_path = Path(log_path)
            if not log_path.is_absolute():
                log_path = Path(workdir) / log_path
            log_path.parent.mkdir(parents=True, exist_ok=True)
            log_fd = open(log_path, "w", buffering=1)
            _bg_env = os.environ.copy()
            _bg_env.setdefault('CUDA_VISIBLE_DEVICES', '2')
            if _WANDB_API_KEY:
                _bg_env.setdefault('WANDB_API_KEY', _WANDB_API_KEY)
                _bg_env.setdefault('WANDB_PROJECT', Path(workdir).name)
            # GPU 충돌 체크 (듀얼 워커 모드)
            bg_gpu = None
            if worker_id in (1, 2):
                bg_gpu = _detect_gpu_in_command(args["command"])
                if bg_gpu is not None:
                    other_id = 2 if worker_id == 1 else 1
                    with _ACTIVE_GPU_LOCK:
                        other_gpu = _ACTIVE_GPU.get(other_id)
                    if other_gpu == bg_gpu:
                        util = _check_gpu_capacity(bg_gpu)
                        if util is not None and util >= _GPU_CONFLICT_THRESH:
                            return (
                                f"GPU_CONFLICT: GPU {bg_gpu}는 Worker {other_id}이 "
                                f"점유 중입니다 ({util*100:.0f}% 사용). "
                                f"추가 학습 여력이 없습니다."
                            )
                    with _ACTIVE_GPU_LOCK:
                        _ACTIVE_GPU[worker_id] = bg_gpu
            proc = subprocess.Popen(
                args["command"], shell=True,
                stdout=log_fd, stderr=log_fd,
                cwd=workdir, start_new_session=True, env=_bg_env,
            )
            proc._agentforge_log_fd = log_fd
            with _active_procs_lock:
                _active_procs.add(proc)
            # run_agent_loop이 모니터 루프를 시작할 수 있도록 사이드 채널에 등록
            global _pending_bg_job
            with _pending_bg_job_lock:
                _pending_bg_job = {"pid": proc.pid, "log_path": str(log_path), "proc": proc}
            return f"PID:{proc.pid}\nLOG:{log_path}\n학습이 백그라운드에서 시작됐습니다."
        elif name == "read_file":
            path = Path(args["path"])
            if not path.is_absolute():
                path = Path(workdir) / path
            return path.read_text(errors='replace')[:10000]
        elif name == "write_file":
            path = Path(args["path"])
            if not path.is_absolute():
                path = Path(workdir) / path
            path.parent.mkdir(parents=True, exist_ok=True)
            path.write_text(args["content"])
            return f"Written: {path}"
        elif name == "list_files":
            path = Path(args["path"])
            if not path.is_absolute():
                path = Path(workdir) / path
            items = sorted(path.iterdir())
            return "\n".join(
                ("dir  " if p.is_dir() else "file ") + p.name for p in items
            )
        elif name == "web_search":
            query = args["query"]
            brave_key = os.environ.get("BRAVE_API_KEY")
            if brave_key:
                r = _session.get(
                    "https://api.search.brave.com/res/v1/web/search",
                    params={"q": query, "count": 10},
                    headers={"Accept": "application/json",
                             "Accept-Encoding": "gzip",
                             "X-Subscription-Token": brave_key},
                    timeout=15,
                )
                items = r.json().get("web", {}).get("results", [])
                return "\n".join(
                    f"[{i+1}] {it['title']}\n    {it['url']}\n    {it.get('description','')}"
                    for i, it in enumerate(items[:8])
                ) or "(결과 없음)"
            else:
                # 1순위: ddgs 패키지 (duckduckgo-search 후속, 안정적)
                try:
                    try:
                        from ddgs import DDGS
                    except ImportError:
                        from duckduckgo_search import DDGS  # 구버전 호환
                    with DDGS() as ddgs:
                        results = list(ddgs.text(query, max_results=8))
                    if results:
                        return "\n".join(
                            f"[{i+1}] {r.get('title','')}\n    {r.get('href','')}\n    {r.get('body','')}"
                            for i, r in enumerate(results)
                        )
                except Exception:
                    pass
                # 2순위: DuckDuckGo HTML 스크래핑 (폴백)
                try:
                    from urllib.parse import unquote
                    r = _session.get(
                        "https://html.duckduckgo.com/html/",
                        params={"q": query},
                        headers={"User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"},
                        timeout=15,
                    )
                    snippets = re.findall(r'class="result__snippet"[^>]*>(.*?)</(?:a|span)>', r.text, re.S)
                    titles   = re.findall(r'class="result__a"[^>]*>(.*?)</a>', r.text, re.S)
                    urls     = re.findall(r'uddg=(https?[^&"]+)', r.text)
                    lines = []
                    for i, (t, u, s) in enumerate(zip(titles, urls, snippets)):
                        t = re.sub(r'<[^>]+>', '', t).strip()
                        s = re.sub(r'<[^>]+>', '', s).strip()
                        lines.append(f"[{i+1}] {t}\n    {unquote(u)}\n    {s}")
                        if i >= 7:
                            break
                    if lines:
                        return "\n".join(lines)
                except Exception:
                    pass
                return "(결과 없음)"
        elif name == "fetch_url":
            url = args["url"]
            r = _session.get(url, timeout=15, headers={"User-Agent": "Mozilla/5.0"})
            text = re.sub(r'<[^>]+>', ' ', r.text)
            text = re.sub(r'\s+', ' ', text).strip()
            return text[:8000]
        else:
            return f"Unknown tool: {name}"
    except Exception as e:
        # ── DEBUG: 도구 오류 기록 ─────────────────────────────────────────────
        _dbg(_dbg_label, f"TOOL_ERROR  {name}  elapsed={time.time()-_t0:.2f}s  err={e}")
