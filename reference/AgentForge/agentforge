def _extract_json_object(text: str):
    decoder = json.JSONDecoder()
    for idx, ch in enumerate(text):
        if ch != "{":
            continue
        try:
            obj, _ = decoder.raw_decode(text[idx:])
            if isinstance(obj, dict):
                return obj
        except json.JSONDecodeError:
            continue
    return None


def _coerce_bool(value) -> bool:
    if isinstance(value, bool):
        return value
    if isinstance(value, (int, float)):
        return bool(value)
    if isinstance(value, str):
        return value.strip().lower() in {"1", "true", "yes", "y"}
    return False


def _coerce_confidence(value) -> float:
    try:
        conf = float(value)
    except (TypeError, ValueError):
        return 0.5
    return max(0.0, min(1.0, conf))


def _decision_feedback_from_payload(payload: dict) -> str:
    if payload.get("decision") == "DONE":
        summary = payload.get("summary") or {}
        return (
            summary.get("judgment")
            or summary.get("result_summary")
            or payload.get("next_action")
            or ""
        ).strip()
    return (
        payload.get("next_action")
        or payload.get("reason_type")
        or ""
    ).strip()


def _make_eval_payload(
    decision: str,
    reason_type: str,
    next_action: str,
    *,
    confidence: float = 0.75,
    rollback_needed: bool = False,
    needs_search: bool = False,
    needs_long_run_monitor: bool = False,
    judgment: str = "",
    result_paths: list[str] | None = None,
    result_summary: str = "",
) -> dict:
    payload = {
        "decision": decision,
        "reason_type": reason_type,
        "next_action": next_action.strip(),
        "confidence": _coerce_confidence(confidence),
        "rollback_needed": bool(rollback_needed),
        "needs_search": bool(needs_search),
        "needs_long_run_monitor": bool(needs_long_run_monitor),
        "summary": {
            "judgment": judgment.strip(),
            "result_paths": [str(p).strip() for p in (result_paths or []) if str(p).strip()],
            "result_summary": result_summary.strip(),
        },
    }
    payload["raw_text"] = json.dumps(
        {k: v for k, v in payload.items() if k != "raw_text"},
        ensure_ascii=False,
    )
    return payload


def _attempt_has_evidence(worker_summary: str, changed_files: list[str] | None) -> bool:
    return bool((worker_summary or "").strip()) or bool(changed_files)


def _classify_attempt_signals(worker_output: str, worker_summary: str,
                              changed_files: list[str] | None) -> dict:
    text = "\n".join(part for part in (worker_output or "", worker_summary or "") if part).strip()
    has_evidence = _attempt_has_evidence(worker_summary, changed_files)
    auth_success = bool(_AUTH_SUCCESS_RE.search(text))
    task_parse_failure = bool(_TASK_PARSE_FAILURE_RE.search(text))
    return {
        "has_evidence": has_evidence,
        "auth_success": auth_success,
        "task_parse_failure": task_parse_failure,
        "auth_setup_only": auth_success and not task_parse_failure,
    }


def _real_history_entries(history: list | None) -> list[dict]:
    if not history:
        return []
    return [h for h in history if h.get("type") != "compressed_summary"]


def _history_entry_has_evidence(entry: dict) -> bool:
    signals = entry.get("attempt_signals") or {}
    if "has_evidence" in signals:
        return bool(signals.get("has_evidence"))
    return _attempt_has_evidence(entry.get("worker_summary", ""), entry.get("changed_files"))


def _count_trailing_no_evidence_attempts(history: list | None) -> int:
    count = 0
    for entry in reversed(_real_history_entries(history)):
        if _history_entry_has_evidence(entry):
            break
        count += 1
    return count


def _count_trailing_auth_parse_failures(history: list | None) -> int:
    count = 0
    for entry in reversed(_real_history_entries(history)):
        signals = entry.get("attempt_signals") or {}
        if signals.get("auth_success") and signals.get("task_parse_failure"):
            count += 1
            continue
        break
    return count


def _word_jaccard(a: str, b: str) -> float:
    ta = set(re.findall(r"[a-z0-9가-힣_]+", (a or "").lower()))
    tb = set(re.findall(r"[a-z0-9가-힣_]+", (b or "").lower()))
    if not ta or not tb:
        return 0.0
    return len(ta & tb) / len(ta | tb)


def _same_feedback_family(payload: dict, history_entry: dict) -> bool:
    current_reason = str(payload.get("reason_type") or "").strip()
    prev_meta = history_entry.get("eval_meta") or {}
    prev_reason = str(prev_meta.get("reason_type") or history_entry.get("reason_type") or "").strip()
    if current_reason and prev_reason and current_reason == prev_reason:
        return True
    current_fb = _decision_feedback_from_payload(payload)
    prev_fb = str(history_entry.get("feedback") or "").strip()
    return _word_jaccard(current_fb, prev_fb) >= 0.55


def _count_trailing_similar_feedback(history: list | None, payload: dict) -> int:
    count = 0
    for entry in reversed(_real_history_entries(history)):
        decision = str(entry.get("decision") or "").upper()
        if not decision:
            continue
        if decision not in {"IMPROVE", "REDIRECT"}:
            break
        if not _same_feedback_family(payload, entry):
            break
        count += 1
    return count


def _preemptive_eval_override(history: list | None, worker_output: str,
                              worker_summary: str, changed_files: list[str] | None) -> dict | None:
    signals = _classify_attempt_signals(worker_output, worker_summary, changed_files)
    no_evidence_streak = _count_trailing_no_evidence_attempts(history)
    auth_parse_streak = _count_trailing_auth_parse_failures(history)

    if signals.get("auth_success") and signals.get("task_parse_failure"):
        if auth_parse_streak >= AUTH_PARSE_REDIRECT_THRESHOLD:
            return _make_eval_payload(
                "REDIRECT",
                "task_parse_failure",
                "로그인/인증은 이미 성공했습니다. 인증 흐름은 더 만지지 말고, 실과제 파싱 실패 계층을 분리해 다른 접근으로 수정하라.",
                confidence=0.92,
                rollback_needed=bool(changed_files),
                judgment="로그인 성공과 과제 파싱 실패가 반복적으로 함께 나타났습니다.",
                result_summary="인증 성공 이후 파싱 실패 반복",
            )
        return _make_eval_payload(
            "IMPROVE",
            "task_parse_failure",
            "로그인/인증 성공과 과제 파싱 실패를 분리해서 처리하라. 인증 코드는 유지하고 파싱 실패 재현, 입력 확인, 추출 경로 수정에만 집중하라.",
            confidence=0.86,
            judgment="인증 자체는 성공했지만 실제 과제 파싱은 실패했습니다.",
            result_summary="인증 성공 후 파싱 실패",
        )

    if not signals.get("has_evidence"):
        if no_evidence_streak >= NO_EVIDENCE_REDIRECT_THRESHOLD:
            return _make_eval_payload(
                "REDIRECT",
                "no_artifact",
                "두 회차 연속으로 작업 증거가 없습니다. 기존 접근을 버리고, 다음 시도에서는 파일 변경·실행 결과·측정값 중 하나를 반드시 남기는 전략으로 전환하라.",
                confidence=0.9,
                rollback_needed=False,
                judgment="연속 회차에서 구체적인 작업 산출물이 남지 않았습니다.",
                result_summary="무증거 회차 반복",
            )
        return _make_eval_payload(
            "CONTINUE",
            "no_artifact",
            "이번 회차에는 작업 증거가 없습니다. 다음 회차에는 파일 변경, 실행 결과, 측정값 중 최소 하나를 반드시 남겨라.",
            confidence=0.72,
            judgment="이번 회차는 구체적인 작업 산출물이 없습니다.",
            result_summary="무증거 회차",
        )
    return None


def _apply_eval_policy_overrides(history: list | None, payload: dict,
                                 worker_output: str, worker_summary: str,
                                 changed_files: list[str] | None) -> dict:
    signals = _classify_attempt_signals(worker_output, worker_summary, changed_files)
    no_evidence_streak = _count_trailing_no_evidence_attempts(history)
    auth_parse_streak = _count_trailing_auth_parse_failures(history)

    if payload.get("decision") == "DONE" and not signals.get("has_evidence") and not payload.get("summary", {}).get("result_paths"):
        return _make_eval_payload(
            "IMPROVE",
            "no_artifact",
            "검증 가능한 작업 증거가 없습니다. 파일 변경, 실행 결과, 측정값 중 하나를 먼저 남긴 뒤 완료 여부를 다시 판단하라.",
            confidence=0.9,
            judgment="작업 증거 없이 완료로 판정할 수 없습니다.",
            result_summary="증거 없는 완료 판정 차단",
        )

    if signals.get("auth_success") and signals.get("task_parse_failure") and payload.get("decision") in {"CONTINUE", "IMPROVE"}:
        if auth_parse_streak >= AUTH_PARSE_REDIRECT_THRESHOLD:
            return _make_eval_payload(
                "REDIRECT",
                "task_parse_failure",
                "로그인/인증은 이미 해결됐습니다. 인증 경로는 유지하고, 과제 파싱 실패 전용 흐름을 새 접근으로 수정하라.",
                confidence=0.9,
                rollback_needed=bool(changed_files),
                judgment="인증 성공과 파싱 실패가 반복되고 있습니다.",
                result_summary="파싱 실패 반복",
            )
        return _make_eval_payload(
            "IMPROVE",
            "task_parse_failure",
            "로그인 성공과 과제 파싱 실패를 분리해서 다뤄라. 인증은 건드리지 말고 파싱 실패 경로만 최소 재현 후 수정하라.",
            confidence=0.84,
            judgment="인증은 통과했지만 과제 파싱은 실패했습니다.",
            result_summary="인증 성공, 파싱 실패",
        )

    if not signals.get("has_evidence") and payload.get("decision") in {"CONTINUE", "IMPROVE"}:
        if no_evidence_streak >= NO_EVIDENCE_REDIRECT_THRESHOLD:
            return _make_eval_payload(
                "REDIRECT",
                "no_artifact",
                "두 회차 연속으로 작업 증거가 없습니다. 기존 접근을 버리고, 다음 시도에서는 파일 변경·실행 결과·측정값 중 하나를 반드시 남겨라.",
                confidence=0.9,
                judgment="무증거 회차가 반복되고 있습니다.",
                result_summary="무증거 회차 반복",
            )
        return _make_eval_payload(
            "CONTINUE",
            "no_artifact",
            "이번 회차에는 작업 증거가 없습니다. 다음 회차에는 파일 변경, 실행 결과, 측정값 중 최소 하나를 반드시 남겨라.",
            confidence=0.7,
            judgment="이번 회차는 구체적 산출물이 없습니다.",
            result_summary="무증거 회차",
        )

    if payload.get("decision") == "IMPROVE":
        similar_count = _count_trailing_similar_feedback(history, payload)
        if similar_count >= REPEATED_FEEDBACK_REDIRECT_THRESHOLD - 1:
            repeated_note = _decision_feedback_from_payload(payload)[:180]
            return _make_eval_payload(
                "REDIRECT",
                "repeated_feedback",
                f"같은 종류의 피드백이 {similar_count + 1}회 반복되었습니다. 기존 접근을 버리고 다른 전략으로 전환하라. 이전 핵심 피드백: {repeated_note}",
                confidence=0.88,
                rollback_needed=bool(changed_files),
                judgment="같은 계열의 피드백이 반복되어 현재 전략의 수익이 낮습니다.",
                result_summary="반복 피드백 예산 초과",
            )

    return payload


def _normalize_evaluator_payload(text: str, allow: tuple[str, ...] = ("CONTINUE", "IMPROVE", "REDIRECT", "DONE")) -> dict:
    raw = _extract_json_object(text) or {}
    decision = _canonicalize_evaluator_decision(raw.get("decision", ""))
    if decision not in allow:
        decision, fallback_feedback = parse_decision(text)
        if decision not in allow:
            decision = "IMPROVE" if "IMPROVE" in allow else allow[0]
        raw.setdefault("next_action", fallback_feedback)

    summary = raw.get("summary")
    if isinstance(summary, str):
        summary = {
            "judgment": summary,
            "result_paths": [],
            "result_summary": summary,
        }
    if not isinstance(summary, dict):
        summary = {}
    result_paths = summary.get("result_paths")
    if not isinstance(result_paths, list):
        result_paths = []

    payload = {
        "decision": decision,
        "reason_type": str(raw.get("reason_type") or "other").strip() or "other",
        "next_action": str(raw.get("next_action") or "").strip(),
        "confidence": _coerce_confidence(raw.get("confidence", 0.5)),
        "rollback_needed": _coerce_bool(raw.get("rollback_needed")) or decision == "REDIRECT",
        "needs_search": _coerce_bool(raw.get("needs_search")),
        "needs_long_run_monitor": _coerce_bool(raw.get("needs_long_run_monitor")),
        "summary": {
            "judgment": str(summary.get("judgment") or "").strip(),
            "result_paths": [str(p).strip() for p in result_paths if str(p).strip()],
            "result_summary": str(summary.get("result_summary") or "").strip(),
        },
        "raw_text": text,
    }
    if not payload["next_action"] and decision != "DONE":
        payload["next_action"] = _decision_feedback_from_payload(payload) or f"(parse fallback) {text[:200]}"
    return payload


def _call_compressor(entries: list[dict], goal: str, model: str | None) -> str:
    """과거 history entries를 LLM으로 요약. 실패 시 원본 한 줄 요약 반환."""
    lines = [f"GOAL: {goal}", "", "ITERATIONS TO SUMMARIZE:"]
    for h in entries:
        lines.append(f"  Iter {h['iter']}: [{h['decision']}] {h.get('feedback','')[:200]}")
        ws = h.get('worker_summary', '')
        if ws:
            lines.append(f"    Worker did: {ws[:200]}")
        eval_meta = h.get("eval_meta") or {}
        if eval_meta.get("reason_type"):
            lines.append(f"    Reason type: {eval_meta['reason_type']}")
        if eval_meta.get("next_action"):
            lines.append(f"    Next action: {eval_meta['next_action'][:180]}")
        if h.get("changed_files"):
            lines.append(f"    Changed files: {', '.join(h['changed_files'][:8])}")
    prompt_text = "\n".join(lines)

    model = model or DEFAULT_EVAL_MODEL
    result, rc = _run_text_completion(
        prompt_text,
        _current_session_workdir(),
        model,
        system_prompt=COMPRESSOR_SYSTEM,
        sandbox="read-only",
    )
    if rc != 0:
        result = ""
    if not result:
        # 폴백: 원본 한 줄 목록
        result = "\n".join(
            f"Iter {h['iter']} [{h['decision']}]: {h.get('feedback','')[:100]}"
            for h in entries
        )
    return result


def compress_history(history: list, goal: str, model: str | None) -> list:
    """
    history가 COMPRESS_THRESHOLD를 넘으면 오래된 항목을 LLM 요약으로 교체.
    최근 KEEP_RECENT 항목은 보존.
    반환: 새 history 리스트 (압축 entry + 최근 항목)
    """
    # 이미 압축된 summary entry가 있으면 그것도 포함해 재압축 대상 선정
    to_compress = history[:-HISTORY_KEEP_RECENT]
    keep = history[-HISTORY_KEEP_RECENT:]

    # summary entry는 그대로, 일반 entry만 압축
    prev_summary_text = ""
    normal_entries = []
    for h in to_compress:
        if h.get('type') == 'compressed_summary':
            prev_summary_text = h['content']
        else:
            normal_entries.append(h)

    if not normal_entries:
        return history  # 압축할 게 없음

    new_text = _call_compressor(normal_entries, goal, model)
    if prev_summary_text:
        combined = prev_summary_text + "\n\n--- Additional history ---\n" + new_text
    else:
        combined = new_text

    first_iter = normal_entries[0]['iter']
    last_iter  = normal_entries[-1]['iter']
    summary_entry = {
        'type': 'compressed_summary',
        'covers': f"{first_iter}–{last_iter}",
        'content': combined,
    }
    return [summary_entry] + keep


def build_worker_prompt(goal: str, history: list,
                        past_attempts: list[dict] | None = None,
                        session_context: list[dict] | None = None,
                        policy_profile: dict | None = None) -> str:
    lines = [f"GOAL: {goal}", ""]
    profile = policy_profile or {}

    if profile:
        labels = ", ".join(profile.get("labels", []))
        if labels:
            lines.append(f"ACTIVE POLICIES: {labels}")
            lines.append("")

    # 같은 REPL 세션에서 이전에 완료한 목표들의 컨텍스트
    if session_context:
        lines.append("PREVIOUS SESSION CONTEXT (completed earlier in this same session):")
        for sc in session_context[-3:]:  # 최근 3개만
            outcome_str = {"done": "✓ 완료", "max": "반복 초과 미완", "interrupted": "중단"}.get(sc.get("outcome",""), sc.get("outcome",""))
            lines.append(f"  - Goal: {sc['goal'][:120]}")
            lines.append(f"    Outcome: {outcome_str} ({sc['iter_count']} iterations)")
            if sc.get("last_feedback"):
                lines.append(f"    Last evaluator note: {sc['last_feedback'][:120]}")
        lines.append("  Build on this context. Do not repeat already-solved work.")
        lines.append("")

    # RAG 섹션: 현재 상황을 쿼리로 과거 시도 검색·삽입
    if past_attempts:
        current_ctx = " ".join(
            f"{h.get('feedback','')} {h.get('worker_summary','')}"
            for h in history[-3:] if h.get('type') != 'compressed_summary'
        ) or goal
        rag = _build_rag_section(past_attempts, current_ctx)
        if rag:
            lines.append(rag)
            lines.append("")

    if not history:
        lines.append("Begin working on the goal above. Make concrete changes now.")
    else:
        lines.append("ITERATION HISTORY:")
        for h in history:
            if h.get('type') == 'compressed_summary':
                lines.append(f"  [COMPRESSED SUMMARY — Iter {h['covers']}]")
                for ln in h['content'].splitlines():
                    lines.append(f"    {ln}")
                lines.append("  ──────────────────────────────────────")
            else:
                lines.append(f"  Iteration {h['iter']}:")
                lines.append(f"    Your work: {h['worker_summary']}")
                lines.append(f"    Evaluator: {h['decision']}" +
                             (f" — {h['feedback']}" if h['feedback'] else ""))
        lines.append("")
        # 마지막 실제 iteration entry 찾기
        last = next((h for h in reversed(history) if h.get('type') != 'compressed_summary'), None)
        if last:
            eval_meta = last.get("eval_meta") or {}
            last_decision = last['decision'].upper()
            if last_decision in ('IMPROVE', 'CONTINUE'):
                lines.append(f"INSTRUCTION: Refine your previous work. Feedback: {last['feedback']}")
            elif last_decision == 'REDIRECT':
                lines.append(f"INSTRUCTION: Abandon previous approach. Try differently: {last['feedback']}")
            elif last_decision == 'DONE':
                lines.append("INSTRUCTION: The goal was previously judged complete. Only make further changes if the current run explicitly requires verification or packaging.")
            if eval_meta.get("reason_type"):
                lines.append(f"EVALUATOR REASON TYPE: {eval_meta['reason_type']}")
            if eval_meta.get("needs_search"):
                lines.append("EVALUATOR SIGNAL: targeted external research is needed before the next edit.")
            if eval_meta.get("needs_long_run_monitor"):
                lines.append("EVALUATOR SIGNAL: the next meaningful step likely requires a monitored long-running job.")
            if eval_meta.get("confidence") is not None:
                lines.append(f"EVALUATOR CONFIDENCE: {eval_meta['confidence']:.2f}")
        lines.append("Make the changes now.")
    return "\n".join(lines)


def _get_workspace_snapshot(workdir: str) -> str:
    """git diff --stat + 최근 변경 파일 목록으로 실제 작업 상태 스냅샷."""
    lines = []
    try:
        r = subprocess.run(
            ["git", "diff", "--stat", "HEAD"],
            capture_output=True, text=True, cwd=workdir, timeout=10,
        )
        if r.stdout.strip():
            lines.append("GIT DIFF --STAT:")
            lines.append(r.stdout.strip()[:1500])
        else:
            # git diff HEAD가 비면 unstaged 변경 확인
            r2 = subprocess.run(
                ["git", "status", "--short"],
                capture_output=True, text=True, cwd=workdir, timeout=10,
            )
            if r2.stdout.strip():
                lines.append("GIT STATUS:")
                lines.append(r2.stdout.strip()[:800])
    except Exception:
        pass
    # git 없는 경우: 최근 60초 내 수정된 파일 목록
    if not lines:
        try:
            r3 = subprocess.run(
                ["find", workdir, "-maxdepth", "4", "-newer",
                 f"{workdir}/.agentforge_ts", "-not", "-path", "*/.git/*",
                 "-not", "-path", "*/__pycache__/*", "-type", "f"],
                capture_output=True, text=True, timeout=10,
            )
            files = r3.stdout.strip().splitlines()[:20]
            if files:
                lines.append("RECENTLY MODIFIED FILES:")
                lines.extend(f"  {f}" for f in files)
        except Exception:
            pass
    return "\n".join(lines)


_METRIC_VALUE_RE = re.compile(
    r'\b(PMAE|loss|val_loss|accuracy|acc|f1|auc|map|score)\s*[=:]\s*([-+]?[0-9]*\.?[0-9]+(?:e[-+]?\d+)?)',
    re.I,
)


def _collect_changed_files(workdir: str) -> list[str]:
    changed: list[str] = []
    try:
        diff = subprocess.run(
            ["git", "diff", "--name-only", "HEAD"],
            capture_output=True, text=True, cwd=workdir, timeout=10,
        )
        status = subprocess.run(
            ["git", "status", "--short"],
            capture_output=True, text=True, cwd=workdir, timeout=10,
        )
        for line in diff.stdout.splitlines():
            line = line.strip()
            if line and line not in changed:
                changed.append(line)
        for line in status.stdout.splitlines():
            path = line[3:].strip() if len(line) > 3 else ""
            if path and path not in changed:
                changed.append(path)
    except Exception:
        pass
    return changed[:20]


def _extract_metric_events(text: str) -> list[dict]:
    metrics: dict[str, str] = {}
    for name, value in _METRIC_VALUE_RE.findall(text or ""):
        metrics[name.lower()] = value
    return [
        {"metric_name": name, "metric_value": value}
        for name, value in metrics.items()
    ]


def _tool_result_summary(result: str) -> str:
    if not result:
        return ""
    line = result.replace("\n", " ").strip()
    return line[:240]


def _get_gpu_status() -> str | None:
    """nvidia-smi snapshot; returns None if not available."""
    try:
        import subprocess as _sp
        r = _sp.run(
            ["nvidia-smi",
             "--query-gpu=index,name,utilization.gpu,memory.used,memory.total",
             "--format=csv,noheader,nounits"],
            capture_output=True, text=True, timeout=5
        )
        if r.returncode != 0 or not r.stdout.strip():
            return None
        lines = []
        for row in r.stdout.strip().splitlines():
            parts = [p.strip() for p in row.split(",")]
            if len(parts) >= 5:
                idx, name, util, mem_used, mem_total = parts[:5]
                lines.append(
                    f"  GPU {idx} [{name}]  util={util}%  mem={mem_used}/{mem_total} MiB"
                )
            else:
                lines.append("  " + row.strip())
        return "\n".join(lines)
    except Exception:
        return None


def build_evaluator_prompt(goal: str, worker_output: str, iteration: int,
                           workdir: str = ".",
                           past_attempts: list[dict] | None = None,
                           history: list | None = None,
                           policy_profile: dict | None = None) -> str:
    snapshot = _get_workspace_snapshot(workdir)
    gpu_status = _get_gpu_status()
    profile = policy_profile or {}
    # IMPROVE 연속 횟수 계산
    improve_count = 0
    if history:
        for h in reversed(history):
            if h.get('type') == 'compressed_summary':
                continue
            if h.get('decision') in ('IMPROVE', 'REDIRECT'):
                improve_count += 1
            else:
                break
    parts = [
        f"ORIGINAL GOAL: {goal}",
        f"CURRENT ITERATION: {iteration}",
    ]
    if profile:
        labels = ", ".join(profile.get("labels", []))
        if labels:
            parts.append(f"ACTIVE POLICIES: {labels}")
    if improve_count >= 3:
        parts.append(f"⚠ IMPROVE/REDIRECT issued {improve_count} times in a row without resolution.")
    current_entry = next((h for h in reversed(history or []) if h.get('type') != 'compressed_summary'), None)
    current_signals = (current_entry or {}).get("attempt_signals") or {}
    if current_entry:
        if not current_signals.get("has_evidence", True):
            parts.append(
                f"⚠ NO-EVIDENCE STREAK: {_count_trailing_no_evidence_attempts(history)} "
                "(empty worker summary and no changed files)."
            )
        if current_signals.get("auth_success") and current_signals.get("task_parse_failure"):
            parts.append(
                f"⚠ AUTH/PARSE SIGNAL: login/auth appears successful, but task parsing failed "
                f"({_count_trailing_auth_parse_failures(history)} time(s) in a row)."
            )
    parts.append("")
    # RAG: 과거 시도 중 현재 워커 출력과 관련된 것 삽입
    if past_attempts:
        rag = _build_rag_section(past_attempts, worker_output[-500:] or goal)
        if rag:
            parts += [rag, ""]
    if snapshot:
        parts += [
            "WORKSPACE STATE (actual filesystem changes):",
            "─" * 60,
            snapshot,
            "─" * 60,
            "",
        ]
    if gpu_status:
        parts += [
            "GPU STATUS (nvidia-smi):",
            "─" * 60,
            gpu_status,
            "─" * 60,
            "",
        ]
    parts += [
        "WORKER OUTPUT FROM THIS ITERATION:",
        "─" * 60,
        worker_output[-3000:].strip(),
        "─" * 60,
        "",
        "Return exactly one JSON object following the evaluator schema.",
    ]
    return "\n".join(parts)



