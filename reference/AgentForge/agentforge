def colorize_line(line: str) -> str:
    """Worker 출력 라인에 문맥 기반 색상 적용."""
    s = line.strip()
    if not s:
        return ""
    # 주석 → 초록
    if s.startswith(('#', '//', '/*', '*')):
        return f"[green]{line}[/green]"
    # 에러/경고 → 빨강
    if any(w in s.lower() for w in ['error', 'traceback', 'exception', 'failed', 'fatal', 'errno']):
        return f"[red]{line}[/red]"
    # 성공 표시 → 초록
    if any(w in s for w in ['✓', 'Created', 'Modified', 'written', 'Success', 'complete', 'Saved']):
        return f"[green]{line}[/green]"
    # 파일/작업 → 시안
    if s.startswith(('>', 'Writing', 'Reading', 'Creating', 'Updating', 'Deleting', 'Running')):
        return f"[cyan]{line}[/cyan]"
    if s.startswith(('+', '-')) and len(s) > 1 and not s.startswith('--'):
        return f"[cyan]{line}[/cyan]"
    # 코드 키워드 → 밝은 흰색
    if any(kw in s for kw in ['def ', 'class ', 'import ', 'from ', 'function ', 'const ', 'let ', 'var ', 'async ']):
        return f"[bright_white]{line}[/bright_white]"
    # 문자열 → 노란색
    if (s.count('"') >= 2 or s.count("'") >= 2) and len(s) < 80:
        return f"[yellow]{line}[/yellow]"
    return line


def strip_ansi(text: str) -> str:
    return ANSI_RE.sub('', text)


_WORKER_LINE_PREFIX_RE = re.compile(r'^\[[A-Z0-9]{1,4}\]\s+')


def _normalize_worker_status_line(line: str) -> str:
    text = strip_ansi(str(line or "")).strip()
    text = _WORKER_LINE_PREFIX_RE.sub('', text)
    if not text or NOISE_RE.match(text):
        return ""
    if text.startswith("```"):
        return ""
    return re.sub(r"\s+", " ", text)


def _trim_ui_text(text: str, width: int) -> str:
    text = str(text or "").strip()
    if len(text) <= width:
        return text
    return text[: max(1, width - 1)] + "…"


def safe_input(prompt: str = "", default: str = "") -> str:
    if _ACTIVE_UI is not None:
        return _ACTIVE_UI.read_input(prompt=prompt, default=default)
    if prompt:
        sys.stdout.write(prompt)
        sys.stdout.flush()
    value = sys.stdin.readline()
    if value == "":
        raise EOFError
    text = value.rstrip("\r\n")
    return text if text else default


