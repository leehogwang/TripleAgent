def _save_bg_train_state(bg: "dict | None") -> None:
    """bg_train 상태를 파일에 저장 (proc 제외 — 직렬화 불가)."""
    try:
        if bg is None:
            _BG_TRAIN_STATE_FILE.unlink(missing_ok=True)
            return
        state = {k: v for k, v in bg.items() if k != "proc"}
        _BG_TRAIN_STATE_FILE.parent.mkdir(parents=True, exist_ok=True)
        _BG_TRAIN_STATE_FILE.write_text(json.dumps(state))
    except Exception:
        pass

def _load_bg_train_state() -> "dict | None":
    """저장된 bg_train 상태 복원. 프로세스가 살아있을 때만 반환."""
    try:
        if not _BG_TRAIN_STATE_FILE.exists():
            return None
        state = json.loads(_BG_TRAIN_STATE_FILE.read_text())
        pid = state.get("pid")
        if pid and _is_proc_alive(pid, None):
            state["proc"] = None
            return state
        # 프로세스 종료됨 → 상태 파일 삭제
        _BG_TRAIN_STATE_FILE.unlink(missing_ok=True)
        return None
    except Exception:
        return None
