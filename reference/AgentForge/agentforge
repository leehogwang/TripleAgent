def _goal_to_slug(goal: str) -> str:
    """목표 문자열 → 파일시스템 안전 폴더명 (한글 보존)."""
    slug = re.sub(r'[^\w가-힣\s]', '', goal)   # 특수문자 제거, 한글·영문·숫자 보존
    slug = re.sub(r'\s+', '_', slug.strip())    # 공백 → 언더스코어
    return slug[:72] or "unnamed"


def _knowledge_path(goal: str) -> Path:
    """목표별 지식 저장소 디렉토리 경로 반환 (없으면 생성)."""
    p = KNOWLEDGE_DIR / _goal_to_slug(goal)
    p.mkdir(parents=True, exist_ok=True)
    return p


def _memory_events_path(goal: str) -> Path:
    return _knowledge_path(goal) / "events.jsonl"


def _append_memory_event(goal: str, event: dict) -> None:
    try:
        payload = {
            "event_type": event.get("event_type", "generic"),
            "timestamp": event.get("timestamp") or time.strftime("%Y-%m-%dT%H:%M:%S"),
            "goal": goal,
            **{k: v for k, v in event.items() if k not in {"event_type", "timestamp", "goal"}},
        }
        with open(_memory_events_path(goal), "a", encoding="utf-8") as f:
            f.write(json.dumps(payload, ensure_ascii=False) + "\n")
    except Exception:
        pass


def _save_attempt(goal: str, record: dict) -> None:
    """시도 기록을 JSONL에 append (스레드 안전: Linux append는 원자적)."""
    try:
        path = _knowledge_path(goal) / "attempts.jsonl"
        line = json.dumps(record, ensure_ascii=False) + "\n"
        with open(path, "a", encoding="utf-8") as f:
            f.write(line)
        _append_memory_event(goal, {
            "event_type": "attempt_summary",
            **record,
        })
    except Exception:
