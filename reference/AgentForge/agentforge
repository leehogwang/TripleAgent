            _shutil_up.copy2(src_script, deploy_target)

    console.print("[green]✓ 업데이트 완료! 새 버전으로 재시작합니다...[/green]\n")
    time.sleep(0.5)
    new_argv = [sys.argv[0]] + ["--skip-update-check"] + sys.argv[1:]
    os.execv(sys.argv[0], new_argv)

