import shlex as _shlex
import shutil as _shutil

def _in_tmux() -> bool:
    return bool(os.environ.get("TMUX"))


def _resolve_cli_workdir(argv: list[str]) -> str:
    workdir = "."
    for i, arg in enumerate(argv):
        if arg == "-d" and i + 1 < len(argv):
            workdir = argv[i + 1]
            break
        if arg.startswith("--dir="):
            workdir = arg.split("=", 1)[1]
            break
        if arg == "--dir" and i + 1 < len(argv):
            workdir = argv[i + 1]
            break
    return str(Path(workdir).expanduser().resolve())


def _tmux_session_name_for_workdir(workdir: str) -> str:
    return SessionContext(workdir).tmux_session


def _tmux_session_exists(session_name: str) -> bool:
    r = subprocess.run(["tmux", "has-session", "-t", session_name],
                       capture_output=True)
    return r.returncode == 0


def _tmux_launch(extra_args: list, session_name: str):
    """현재 프로세스를 tmux 세션 안의 agentforge로 교체."""
    if _tmux_session_exists(session_name):
        console.print(
            f"[yellow]이미 실행 중인 agentforge 세션이 있습니다.[/yellow]\n"
            f"  재접속:  [cyan]agentforge -r[/cyan]\n"
            f"  새 세션: [cyan]agentforge --new-session[/cyan]"
        )
        sys.exit(0)

    exe = _shutil.which("agentforge") or os.path.abspath(sys.argv[0])
    cmd_str = " ".join(_shlex.quote(p) for p in [exe] + extra_args)
    try:
        os.execvp("tmux", ["tmux", "new-session", "-s", session_name, cmd_str])
    except OSError:
        pass  # tmux 실행 실패 → 그냥 일반 모드로 계속


def _tmux_reconnect(workdir: str):
    """기존 agentforge tmux 세션에 재접속."""
    session_name = _tmux_session_name_for_workdir(workdir)
    if not _shutil.which("tmux"):
        console.print("[red]tmux가 설치되지 않았습니다.[/red]")
        sys.exit(1)
    if not _tmux_session_exists(session_name):
        console.print(
            "[yellow]실행 중인 agentforge 세션이 없습니다.[/yellow]\n"
            "새 세션 시작: [cyan]agentforge[/cyan]"
        )
        sys.exit(1)
    os.execvp("tmux", ["tmux", "attach-session", "-t", session_name])


# ── Checkpoint / Rollback ────────────────────────────────────────────────────

_CP_CODE_EXTS = {'.py', '.sh', '.yaml', '.yml', '.json', '.toml', '.cfg', '.ini', '.txt', '.md'}
_CP_SKIP_DIRS = {'__pycache__', '.ipynb_checkpoints', 'node_modules',
                 'wandb', 'checkpoints', 'runs', 'logs', '.git'}
_CP_MAX_FILE  = 10 * 1024 * 1024  # 10 MB


def _cp_save(workdir: str) -> str | None:
    """workdir 코드 파일을 스냅샷으로 저장.
    git이 있으면 git patch, 없으면 파일 복사 스냅샷.
    반환: 경로(str) | 'empty' | None(실패)"""
    if (Path(workdir) / ".git").exists():
        try:
            r = subprocess.run(
                ["git", "diff", "HEAD", "--binary"],
                capture_output=True, text=True, cwd=workdir, timeout=10,
            )
            if not r.stdout.strip():
                return "empty"
            p = Path(workdir) / f".agentforge_cp_{int(time.time()*1000)}.patch"
            p.write_text(r.stdout)
            return str(p)
        except Exception:
            pass  # fall through to file-copy

    # git 없음 → 파일 복사 스냅샷 (tmp 디렉토리)
    try:
        import tempfile as _tmpmod
        snap_dir = Path(_tmpmod.mkdtemp(prefix="agentforge_snap_"))
        workdir_path = Path(workdir)
        saved: list[str] = []
        for root, dirs, files in os.walk(workdir_path):
            dirs[:] = [d for d in dirs if d not in _CP_SKIP_DIRS]
            rel_root = Path(root).relative_to(workdir_path)
            for fname in files:
                fpath = Path(root) / fname
                if fpath.suffix not in _CP_CODE_EXTS:
                    continue
                try:
                    if fpath.stat().st_size > _CP_MAX_FILE:
                        continue
                except OSError:
                    continue
                dest_dir = snap_dir / rel_root
                dest_dir.mkdir(parents=True, exist_ok=True)
                _shutil.copy2(fpath, dest_dir / fname)
                saved.append(str(rel_root / fname))
        (snap_dir / ".agentforge_filelist").write_text("\n".join(saved))
        return str(snap_dir)
    except Exception:
        return None


def _cp_restore(workdir: str, patch_path: str | None) -> bool:
    """스냅샷으로 workdir 복원. True=성공."""
    if patch_path is None:
        return False

    # 디렉토리 스냅샷 (non-git)
    if Path(patch_path).is_dir():
        try:
            snap_dir = Path(patch_path)
            workdir_path = Path(workdir)
            filelist_path = snap_dir / ".agentforge_filelist"
            filelist = set(filelist_path.read_text().splitlines()) if filelist_path.exists() else set()

            # 스냅샷 이후 새로 생긴 코드 파일 삭제
            for root, dirs, files in os.walk(workdir_path):
                dirs[:] = [d for d in dirs if d not in _CP_SKIP_DIRS]
                rel_root = Path(root).relative_to(workdir_path)
                for fname in files:
                    fpath = Path(root) / fname
                    if fpath.suffix not in _CP_CODE_EXTS:
                        continue
                    if str(rel_root / fname) not in filelist:
                        try:
                            fpath.unlink()
                        except OSError:
                            pass

            # 원본 파일 복원
            for root, dirs, files in os.walk(snap_dir):
                rel_root = Path(root).relative_to(snap_dir)
                for fname in files:
                    if fname == ".agentforge_filelist":
                        continue
                    src = Path(root) / fname
                    dest_dir = workdir_path / rel_root
                    dest_dir.mkdir(parents=True, exist_ok=True)
                    _shutil.copy2(src, dest_dir / fname)
            return True
        except Exception:
            return False

    # git patch
    try:
        subprocess.run(["git", "checkout", "."], capture_output=True, cwd=workdir, timeout=10)
        subprocess.run(["git", "clean", "-fd"], capture_output=True, cwd=workdir, timeout=10)
        if patch_path == "empty":
            return True
        r = subprocess.run(
            ["git", "apply", "--whitespace=fix", patch_path],
            capture_output=True, cwd=workdir, timeout=10,
        )
        return r.returncode == 0
    except Exception:
        return False


def _cp_delete(patch_path: str | None) -> None:
    if not patch_path or patch_path == "empty":
        return
    try:
        p = Path(patch_path)
        if p.is_dir():
            _shutil.rmtree(p, ignore_errors=True)
        else:
            p.unlink(missing_ok=True)
    except Exception:
        pass


def _detect_gpu_in_command(cmd: str) -> int | None:
    m = _GPU_RE.search(cmd)
    if not m: return None
    for g in m.groups():
        if g is not None:
            try: return int(g)
            except ValueError: return None
    return None

def _list_all_gpus() -> list[dict]:
    """전체 GPU 목록 반환: [{id, name, used_mb, total_mb, util}]"""
    try:
        r = subprocess.run(
            ["nvidia-smi",
             "--query-gpu=index,name,memory.used,memory.total",
             "--format=csv,noheader,nounits"],
            capture_output=True, text=True, timeout=5)
        if r.returncode != 0: return []
        gpus = []
        for line in r.stdout.strip().splitlines():
            parts = [p.strip() for p in line.split(',')]
            if len(parts) == 4:
                used, total = float(parts[2]), float(parts[3])
                gpus.append({
                    "id": int(parts[0]), "name": parts[1],
                    "used_mb": used, "total_mb": total,
                    "util": used / total if total > 0 else 0.0,
                })
        return gpus
    except Exception:
        return []

def _check_gpu_capacity(gpu_id: int) -> float | None:
    """Used/total ratio (0.0~1.0). None if unavailable."""
    try:
        r = subprocess.run(
            ["nvidia-smi", "--query-gpu=index,memory.used,memory.total",
             "--format=csv,noheader,nounits"],
            capture_output=True, text=True, timeout=5)
        if r.returncode != 0: return None
        for line in r.stdout.splitlines():
            parts = [p.strip() for p in line.split(',')]
            if len(parts) == 3 and parts[0] == str(gpu_id):
                used, total = float(parts[1]), float(parts[2])
                return used / total if total > 0 else 0.0
    except Exception:
        return None
    return None


def _git_diff_stat(workdir: str) -> str:
