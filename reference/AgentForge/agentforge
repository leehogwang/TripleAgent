# ── 필수 패키지 자동 설치 (import 전에 실행) ─────────────────────────────────
def _ensure_deps():
    _REQUIRED = [
        ('rich',           'rich'),
        ('prompt_toolkit', 'prompt_toolkit'),
        ('requests',       'requests'),
        ('rank_bm25',      'rank-bm25'),
        ('tiktoken',       'tiktoken'),
    ]
    missing_pkgs = []
    for mod, pkg in _REQUIRED:
        try:
            __import__(mod)
        except ImportError:
            missing_pkgs.append(pkg)
    if not missing_pkgs:
        return
    print(f"[agentforge] 필수 패키지 설치 중: {', '.join(missing_pkgs)}", flush=True)
    try:
        subprocess.check_call(
            [sys.executable, '-m', 'pip', 'install', '--quiet'] + missing_pkgs
        )
    except subprocess.CalledProcessError:
        # --user 로 재시도
        try:
            subprocess.check_call(
                [sys.executable, '-m', 'pip', 'install', '--quiet', '--user'] + missing_pkgs
            )
        except subprocess.CalledProcessError:
            print(f"[agentforge] 설치 실패. 수동으로 실행하세요: pip install {' '.join(missing_pkgs)}")
            sys.exit(1)
    print("[agentforge] 설치 완료. 시작합니다...", flush=True)
    # 새로 설치된 패키지를 인식하도록 재실행
    import os as _os
    _os.execv(sys.executable, [sys.executable] + sys.argv)

_ensure_deps()
