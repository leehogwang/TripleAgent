                    ),
                    xcursor=True,
                    ycursor=True,
                    attach_to_window=self.input_field.window,
                    allow_cover_cursor=False,
                )
            ],
        )
        self.app = Application(
            layout=PtLayout(root, focused_element=self.input_field),
            full_screen=True,
            key_bindings=self._kb,
            mouse_support=False,
            min_redraw_interval=0.03,
            max_render_postpone_time=0.03,
            before_render=self._before_render,
            style=PtStyle.from_dict({
                "screen": "bg:#0f1115 #e7e7e7",
                "composer.frame": "bg:#0f1115 #e7e7e7",
                "composer.title": "bg:#181c23 #8ea2c0",
                "composer": "bg:#131721 #f4f4f0",
                "text-area.prompt": "#8bd5ca bold",
                "notices": "bg:#0f1115",
                "notices.body": "bg:#11161d #c5cad3",
                "frame.border": "#394150",
                "frame.label": "#d5dbe3 bold",
                "completion-menu.completion": "bg:#151922 #cfd6df",
                "completion-menu.completion.current": "bg:#2a3140 #ffffff bold",
                "completion-menu.meta.completion": "bg:#151922 #7f8792",
                "completion-menu.meta.completion.current": "bg:#2a3140 #dce3ed",
            }),
        )

        self._refresh_notice_control()
        self._refresh_composer_title()
        self._set_control_text(self._top_control, self._top_cache_text)
        self._persist_ui_state(force=True)

    def _install_keybindings(self) -> None:
        @self._kb.add("enter", filter=has_focus(self.input_field.buffer))
        def _submit(event):
            buf = event.current_buffer
            if buf.complete_state and buf.complete_state.current_completion:
                buf.apply_completion(buf.complete_state.current_completion)
                return
            buf.validate_and_handle()

        @self._kb.add("escape", "enter", filter=has_focus(self.input_field.buffer))
        def _newline(event):
            event.current_buffer.insert_text("\n")

        @self._kb.add("/", filter=has_focus(self.input_field.buffer))
        def _slash(event):
            buf = event.current_buffer
            buf.insert_text("/")
            if buf.text.lstrip().startswith("/"):
                buf.start_completion(select_first=False)

        @self._kb.add("tab", filter=has_focus(self.input_field.buffer))
        def _tab_complete(event):
            buf = event.current_buffer
            if buf.complete_state and buf.complete_state.current_completion:
                buf.apply_completion(buf.complete_state.current_completion)
                return
            if buf.text.lstrip().startswith("/"):
                buf.start_completion(select_first=False)
                return
            buf.insert_text("    ")

        @self._kb.add("c-c", filter=has_focus(self.input_field.buffer))
        def _interrupt(event):
            if self._pending_queue is not None:
                self._pending_queue.put(KeyboardInterrupt)
                event.current_buffer.reset()
                self.invalidate()

        @self._kb.add("c-d", filter=has_focus(self.input_field.buffer))
        def _eof(event):
            if self._pending_queue is not None and not event.current_buffer.text:
                self._pending_queue.put(EOFError)
                self.invalidate()
                return
            if not event.current_buffer.text:
                self.request_exit()

    def run(self) -> None:
        try:
            self.app.run()
        finally:
            self._closed = True

    def request_exit(self) -> None:
        if self._closed:
            return
        self._closed = True
        with self._lock:
            pending = self._pending_queue
        if pending is not None:
            pending.put(EOFError)
        self._command_queue.put(EOFError)
        try:
            self.app.exit()
        except Exception:
            pass

    def invalidate(self) -> None:
        try:
            self.app.invalidate()
        except Exception:
            pass

    def _set_control_text(self, control: FormattedTextControl, text: str) -> None:
        control.text = self._empty_text if not text else to_formatted_text(ANSI(text))

    def render_width(self) -> int:
        try:
            return max(80, self.app.output.get_size().columns)
        except Exception:
            return 120

    def set_busy(self, busy: bool) -> None:
        self._busy = busy
        self._refresh_composer_title()
        self._persist_ui_state()

    @property
    def fast_mode(self) -> bool:
        return self._fast_mode

    def set_fast_mode(self, enabled: bool) -> None:
        self._fast_mode = bool(enabled)
        self._refresh_composer_title()
        self._persist_ui_state(force=True)
        self.invalidate()

    def add_notice(self, text: str) -> None:
        if not text:
            return
        with self._lock:
            for line in text.rstrip().splitlines():
                if line.strip():
                    self._notices.append(line)
                    _append_session_event("notice", line=line)
        self._refresh_notice_control()
        self._persist_ui_state()
        self.invalidate()

    def clear_notices(self) -> None:
        with self._lock:
            self._notices.clear()
        self._refresh_notice_control()
        self._persist_ui_state(force=True)
        self.invalidate()

    def activate_mode(self, mode: str) -> _ShellLayoutProxy:
        with self._lock:
            self._panel_mode = mode
            self._render_version += 1
            if mode == "single":
                self._renderables.pop("summary_bar", None)
                self._renderables.pop("worker1", None)
                self._renderables.pop("worker2", None)
            else:
                self._renderables.pop("worker", None)
        self._persist_ui_state()
        self.invalidate()
        return _ShellLayoutProxy(self, mode)

    def create_live_proxy(self) -> _ShellLiveProxy:
        return _ShellLiveProxy(self)

    def update_renderable(self, name: str, renderable) -> None:
        with self._lock:
            self._renderables[name] = renderable
            self._render_version += 1
        self.invalidate()

    def read_input(self, prompt: str = "", default: str = "") -> str:
        if self._closed:
            raise EOFError
        response_q: queue.Queue = queue.Queue(maxsize=1)
        with self._lock:
            self._pending_queue = response_q
            self._composer_prompt = prompt or self._default_prompt
            self.input_field.buffer.set_document(
                Document(default, cursor_position=len(default)),
                bypass_readonly=True,
            )
            self.app.layout.focus(self.input_field)
        self._refresh_composer_title()
        self._persist_ui_state(force=True)
        self.invalidate()

        result = response_q.get()

        with self._lock:
            self._pending_queue = None
            self._composer_prompt = self._default_prompt
            self.input_field.buffer.reset(Document())
        self._refresh_composer_title()
        self._persist_ui_state(force=True)
        self.invalidate()

        if result is KeyboardInterrupt:
            raise KeyboardInterrupt
        if result is EOFError:
            raise EOFError
        return str(result)

    def get_command(self):
        result = self._command_queue.get()
        if result is EOFError:
            raise EOFError
        return str(result)

    def _accept_input(self, buffer) -> bool:
        text = buffer.text
        with self._lock:
            target = self._pending_queue
        if target is not None:
            target.put(text)
        else:
            self._command_queue.put(text)
            _append_session_event("command", text=text)
        buffer.reset(Document())
        self._persist_ui_state(force=True)
        return True

    def _on_buffer_change(self, _event=None) -> None:
        self._persist_ui_state()

    def _composer_line_count(self) -> int:
        text = self.input_field.buffer.text or ""
        return min(6, max(1, text.count("\n") + 1))

    def _notice_line_count(self) -> int:
        with self._lock:
            if not self._notices:
                return 0
            return min(8, max(3, len(self._notices)))

    def _top_height(self) -> int:
        try:
            total_rows = self.app.output.get_size().rows
        except Exception:
            total_rows = 40
        composer_rows = self._composer_line_count() + 4
        notice_rows = self._notice_line_count() + (2 if self._notices else 0)
        return max(12, total_rows - composer_rows - notice_rows)

    def _build_shell_renderable(self):
        top_rows = self._top_height()
        with self._lock:
            renderables = dict(self._renderables)
            mode = self._panel_mode
        if mode == "dual":
            layout = make_dual_layout(term_rows=top_rows)
            for key in ("header", "summary_bar", "worker1", "worker2", "evaluator", "cmd_bar"):
                layout[key].update(renderables.get(key, ""))
        else:
            layout = make_layout(term_rows=top_rows)
            for key in ("header", "worker", "evaluator", "cmd_bar"):
                layout[key].update(renderables.get(key, ""))
        return layout

    def _refresh_top_display(self, force: bool = False) -> None:
        width = self.render_width()
        top_height = self._top_height()
        with self._lock:
            cache_key = (self._panel_mode, self._render_version, width, top_height)
            if not force and cache_key == self._top_cache_key:
                return
            renderable = self._build_shell_renderable()
            self._top_cache_text = _capture_rich_text(renderable, width=width, height=top_height)
            self._top_cache_key = cache_key
            text = self._top_cache_text
        self._set_control_text(self._top_control, text)
        self._persist_ui_state()

    def _refresh_notice_control(self) -> None:
        with self._lock:
            text = "\n".join(list(self._notices)[-8:])
        self._set_control_text(self._notice_control, text)

    def _refresh_composer_title(self) -> None:
        state = "RUNNING" if self._busy else "READY"
        transport = "FAST" if self._fast_mode else "STD"
        hint = "Enter send  Esc+Enter newline  / for commands  -r reconnect"
        self._set_control_text(
            self._composer_title_control,
            f"\x1b[38;2;142;162;192m {self.app_name.upper()}  {state}  {transport} \x1b[0m"
            f"\x1b[38;2;120;128;140m  {hint}\x1b[0m"
        )

    def _persist_ui_state(self, force: bool = False) -> None:
        now = time.time()
        if not force and now - self._last_ui_persist < 0.15:
            return
        self._last_ui_persist = now
        with self._lock:
            state = {
                "panel_mode": self._panel_mode,
                "top_cache_text": self._top_cache_text,
                "notices": list(self._notices),
                "draft_text": self.input_field.buffer.text,
                "draft_cursor": self.input_field.buffer.cursor_position,
                "composer_prompt": self._composer_prompt,
                "busy": self._busy,
                "fast_mode": self._fast_mode,
            }
        _persist_ui_state(state)

    def _before_render(self, _app) -> None:
        self._refresh_top_display()

    def _get_prompt_fragments(self):
        return ANSI(self._composer_prompt)




class TuiAwareConsole:
    def __init__(self, base_console: Console):
        self._base_console = base_console

    def print(self, *objects, **kwargs):
        if _ACTIVE_UI is None:
            return self._base_console.print(*objects, **kwargs)
        width = _ACTIVE_UI.render_width()
        _ACTIVE_UI.add_notice(_capture_rich_text(*objects, width=width, **kwargs))

    def clear(self):
