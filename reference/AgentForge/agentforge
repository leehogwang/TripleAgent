def render_summary_bar(task_a: str, task_b: str, s1: str, s2: str) -> Panel:
    import shutil
    half = max(20, shutil.get_terminal_size(fallback=(80, 40)).columns // 2 - 8)
    a = task_a[:half] + ("…" if len(task_a) > half else "")
    b = task_b[:half] + ("…" if len(task_b) > half else "")
    c1 = "yellow bold" if s1 == "running" else "dim"
    c2 = "cyan bold"   if s2 == "running" else "dim"
    content = f"[{c1}]⚙ W1:[/{c1}] [dim]{a}[/dim]\n[{c2}]⚙ W2:[/{c2}] [dim]{b}[/dim]"
    return Panel(content, border_style="dim", box=box.SIMPLE, padding=(0, 1))


def render_cmd_bar(buf1, buf2, status1: str, status2: str,
                   spoken1: str = "", spoken2: str = "") -> Panel:
    """하단 상태바: 각 Worker의 현재 명령과 마지막 자연어 상태 표시."""
    import re as _re
    import shutil as _sh
    _markup_re = _re.compile(r'\[/?[a-zA-Z#][^\]]*\]')

    def _clean_line(line: str) -> str:
        clean = _markup_re.sub('', line or "")
        return _normalize_worker_status_line(clean)

    def last_cmd(buf, status: str) -> str:
        # 버퍼에서 마지막 ▶ 도구 호출 라인 추출
        for line in reversed(list(buf)):
            clean = _clean_line(line)
            if not clean:
                continue
            idx = clean.find('▶')
            if idx >= 0:
                return clean[idx + 1:].strip()
        if status == "running":
            return "실행 준비 중..."
        if status == "done":
            return "완료"
        if status == "error":
            return "오류"
        return "대기 중"

    line_w = max(36, _sh.get_terminal_size(fallback=(80, 40)).columns - 18)

    def render_line(label: str, color: str, buf, status: str, spoken: str) -> str:
        spoken_clean = _normalize_worker_status_line(spoken)
        cmd_text = last_cmd(buf, status)
        if status == "running" and spoken_clean:
            spoken_w = max(18, min(48, line_w // 3))
            cmd_w = max(18, line_w - spoken_w - 9)
            cmd_text = _trim_ui_text(cmd_text, cmd_w)
            spoken_text = _trim_ui_text(spoken_clean, spoken_w)
            body = (
                f"{_escape_markup(cmd_text)} "
                f"[dim]| 상태:[/dim] {_escape_markup(spoken_text)}"
            )
        else:
            body = _escape_markup(_trim_ui_text(cmd_text, line_w))
        return f"[{color}]{label}[/{color}] [dim]▶[/dim] {body}"

    c1 = "yellow" if status1 == "running" else "dim"
    c2 = "cyan"   if status2 == "running" else "dim"
    content = (
        f"{render_line('W1', c1, buf1, status1, spoken1)}\n"
        f"{render_line('W2', c2, buf2, status2, spoken2)}"
    )
    return Panel(content, title="[dim]현재 실행 중[/dim]",
                 border_style="dim", box=box.SIMPLE, padding=(0, 1))


def _fmt_elapsed(start: float) -> str:
    """시작 시각으로부터 경과 시간을 'Xh Ym' 형식으로 반환."""
    secs = int(time.time() - start)
    h, m = divmod(secs // 60, 60)
    if h > 0:
        return f"{h}h {m:02d}m"
    return f"{m}m {secs % 60:02d}s"


