            pass
        elif line.strip():
            console.print(f"  {line}")
    console.print()
    console.print(f"[dim]전체 파일: {report_path}[/dim]")


def _fetch_paper_and_extract(url: str, eval_model: str | None) -> str | None:
    """URL에서 논문 텍스트 fetch → LLM으로 구현 목표 추출. None이면 실패."""
    console.print(f"[dim]논문 fetching: {url}[/dim]")
    try:
        r = _session.get(url, timeout=20, headers={"User-Agent": "Mozilla/5.0"})
        r.raise_for_status()
        text = re.sub(r'<[^>]+>', ' ', r.text)
        text = re.sub(r'\s+', ' ', text).strip()
        # arXiv HTML/abs 페이지에서 abstract + title 추출
        paper_text = text[:12000]
    except Exception as e:
        console.print(f"[red]fetch 실패: {e}[/red]")
        return None

    console.print(f"[dim]논문 분석 중 (LLM)...[/dim]")
    result, rc = _run_text_completion(
        f"PAPER TEXT:\n{paper_text}",
        _current_session_workdir(),
        eval_model or DEFAULT_EVAL_MODEL,
        system_prompt=PAPER_EXTRACTOR_SYSTEM,
        sandbox="read-only",
    )
    if rc != 0:
        result = ""
    if not result:
        return None

    # GOAL: 줄에서 목표 추출
    goal_m = re.search(r'^GOAL:\s*(.+?)$', result, re.I | re.M)
    if goal_m:
        goal_line = goal_m.group(1).strip()
        # 전체 분석 결과를 목표에 첨부
        full_goal = (
            f"{goal_line}\n\n"
            f"[논문 상세 내용]\n{result}"
        )
        return full_goal
    return result


def split_goal_to_tasks(goal: str, model: str | None) -> tuple[str, str]:
    """Coordinator LLM → (task_a, task_b). 실패 시 (goal, goal) 폴백."""
    console.print("[dim]Coordinator: 목표를 두 작업으로 분리 중...[/dim]")
    text, rc = _run_text_completion(
        f"GOAL: {goal}",
        _current_session_workdir(),
        model or DEFAULT_EVAL_MODEL,
        system_prompt=COORDINATOR_SYSTEM,
        sandbox="read-only",
    )
    if rc != 0:
        text = ""
    tasks = {m.group(1).upper(): m.group(2).strip()
             for m in _TASK_RE.finditer(text)}
    task_a = tasks.get("A") or goal
    task_b = tasks.get("B") or goal
    if task_a == goal or task_b == goal:
        console.print("[yellow]Coordinator 파싱 실패 — 기본 분기 적용[/yellow]")
    else:
        console.print(f"[cyan]W1:[/cyan] {task_a[:70]}")
        console.print(f"[cyan]W2:[/cyan] {task_b[:70]}")
    return task_a, task_b


