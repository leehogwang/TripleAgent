def _trim_fast_worker_text(text: str, limit: int = 1200) -> str:
    text = (text or "").strip()
    if len(text) <= limit:
        return text
    head = max(200, limit // 2 - 10)
    tail = max(200, limit - head - 16)
    return text[:head] + "\n... [truncated] ...\n" + text[-tail:]


def _fast_worker_system_prompt(system_prompt: str) -> str:
    runtime_note = textwrap.dedent("""\
        FAST TRANSPORT RUNTIME:
        - You are running through the official Codex CLI agent, not the legacy custom tool API.
        - Use Codex's built-in shell, file editing, and patch application abilities directly.
        - Native web search may be available; use it only when genuinely needed.
        - There is NO custom shell_background tool in this runtime. If you start a long-running job,
          launch it yourself in the shell, redirect stdout/stderr to a log file, and make the shell
          print EXACTLY:
            PID:<pid>
            LOG:<absolute log path>
          Then end your turn without waiting.
        - There is NO custom data_profile tool in this runtime. If you need data inspection,
          use shell/Python commands directly.
        - MCP tools from agentforge are not available in this runtime.
    """).strip()
    return f"{system_prompt.strip()}\n\n{runtime_note}"


def _run_worker_fast(
    prompt: str,
    workdir: str,
    model: str,
    buf: deque,
    status_ref: list,
    *,
    system_prompt: str,
    tools: list | None = None,
    worker_id: int = 0,
    goal_context: str | None = None,
    iteration_id: int | str | None = None,
    last_spoken_ref: list[str] | None = None,
) -> tuple[str, int]:
    if any(str(t.get("name", "")).startswith("mcp__") for t in (tools or [])):
        buf.append("[yellow]Fast transport는 MCP 툴과 함께 사용할 수 없어 기본 transport로 폴백합니다.[/yellow]")
        status_ref[0] = "running"
        return "", -1

    search_enabled = any(
        str(t.get("name", "")) in {"web_search", "fetch_url"}
        for t in (tools or [])
    )
    transcript_parts: list[str] = []
    fallback_command_parts: list[str] = []
    background_marker_parts: list[str] = []
    line_buf = ""
    active_commands: dict[str, str] = {}
    status_ref[0] = "running"

    def _flush_line(text: str):
        nonlocal line_buf
        line_buf += text
        while '\n' in line_buf:
            ln, line_buf = line_buf.split('\n', 1)
            spoken = _normalize_worker_status_line(ln)
            if spoken:
                if last_spoken_ref is not None:
                    last_spoken_ref[0] = spoken
                buf.append(colorize_line(ln))

    for ev in _iter_codex_exec_events(
        prompt,
        workdir,
        model,
        system_prompt=_fast_worker_system_prompt(system_prompt),
        search=search_enabled,
        sandbox="workspace-write",
    ):
        evtype = ev.get("type")
        if evtype == "_error":
            reason = ev.get("message", "unknown error")
            _force_disable_fast_mode(reason)
            buf.append(f"[yellow]Fast transport 오류 → fast를 끄고 기본 transport로 재시도합니다.[/yellow]")
            buf.append(f"[dim]{reason}[/dim]")
            status_ref[0] = "running"
            if line_buf.strip():
                spoken = _normalize_worker_status_line(line_buf)
                if spoken and last_spoken_ref is not None:
                    last_spoken_ref[0] = spoken
                buf.append(colorize_line(line_buf))
            _dbg(f"W{worker_id}" if worker_id else "WORKER", f"FAST_FALLBACK  reason={reason}")
            return "", -1

        if evtype not in {"item.started", "item.completed"}:
            continue

        item = ev.get("item") or {}
        item_type = item.get("type")
        item_id = str(item.get("id") or "")

        if item_type == "command_execution" and evtype == "item.started":
            command = str(item.get("command") or "").strip()
            active_commands[item_id] = command
            if command:
                buf.append(f"[cyan]▶ {command[:180]}[/cyan]")
            continue

        if item_type == "command_execution" and evtype == "item.completed":
            command = str(item.get("command") or active_commands.pop(item_id, "")).strip()
            output = str(item.get("aggregated_output") or "")
            exit_code = item.get("exit_code")
            preview = _tool_result_summary(output)
            if preview:
                buf.append(f"[dim]{_osc8_linkify(preview.replace(chr(10), ' '))}[/dim]")
            elif command:
                buf.append(f"[dim](exit {exit_code})[/dim]")
            trimmed = _trim_fast_worker_text(output)
            if trimmed:
                _flush_line(trimmed + "\n")
            capture_parts: list[str] = []
            if command:
                capture_parts.append(f"$ {command}")
            if trimmed:
                capture_parts.append(trimmed)
            capture_text = "\n".join(part for part in capture_parts if part).strip()
            if capture_text:
                if _BG_PID_RE.search(output) or _BG_LOG_RE.search(output):
                    background_marker_parts.append(capture_text)
                else:
                    fallback_command_parts.append(capture_text)
            if goal_context:
                _append_memory_event(goal_context, {
                    "event_type": "command_execution",
                    "iter": iteration_id,
                    "worker_id": worker_id,
                    "command": command[:300],
                    "exit_code": exit_code,
                    "result_summary": preview,
                })
            continue

        if item_type == "agent_message" and evtype == "item.completed":
            text = str(item.get("text") or "").strip()
            if text:
                transcript_parts.append(text)
                _flush_line(text + "\n")
            continue

    if line_buf.strip():
        spoken = _normalize_worker_status_line(line_buf)
        if spoken and last_spoken_ref is not None:
            last_spoken_ref[0] = spoken
        buf.append(colorize_line(line_buf))
    status_ref[0] = "done"
    final_parts = [part for part in transcript_parts if part]
    final_parts.extend(background_marker_parts)
    if not transcript_parts:
        final_parts.extend(fallback_command_parts)
    return "\n\n".join(part for part in final_parts if part).strip(), 0

def run_worker(prompt: str, workdir: str, model: str | None,
               buf: deque, status_ref: list,
               system_prompt: str | None = None,
               tools: list | None = None,
               worker_id: int = 0,
               goal_context: str | None = None,
               iteration_id: int | str | None = None,
               last_spoken_ref: list[str] | None = None) -> tuple[str, int]:
    """Worker: ChatGPT backend Responses API 직접 호출 + 병렬 도구 실행 루프."""
    # ── DEBUG: worker 시작 ────────────────────────────────────────────────────
    _wlabel = f"W{worker_id}" if worker_id else "WORKER"
    _dbg(_wlabel, f"RUN_START  model={model or DEFAULT_WORKER_MODEL}")
    _wt0 = time.time()
    # ── END DEBUG ────────────────────────────────────────────────────────────
    model = model or DEFAULT_WORKER_MODEL
    system_prompt = system_prompt or WORKER_SYSTEM
    tools = tools if tools is not None else WORKER_TOOLS
    if last_spoken_ref is not None:
        last_spoken_ref[0] = ""

    if _fast_mode_active():
        fast_result, fast_rc = _run_worker_fast(
            prompt,
            workdir,
            model,
            buf,
            status_ref,
            system_prompt=system_prompt,
            tools=tools,
            worker_id=worker_id,
            goal_context=goal_context,
            iteration_id=iteration_id,
            last_spoken_ref=last_spoken_ref,
        )
        if fast_rc >= 0:
            _dbg(_wlabel, f"RUN_END    elapsed={time.time()-_wt0:.2f}s fast={fast_rc == 0}")
            return fast_result, fast_rc

    status_ref[0] = "running"

    # 입력 히스토리 (user msg + function_call + function_call_output 누적)
    input_history: list[dict] = [{"role": "user", "content": prompt}]
    all_text_parts: list[str] = []
    line_buf = ""

    def _flush_line(text: str):
        nonlocal line_buf
        line_buf += text
        while '\n' in line_buf:
            ln, line_buf = line_buf.split('\n', 1)
            spoken = _normalize_worker_status_line(ln)
            if spoken:
                if last_spoken_ref is not None:
                    last_spoken_ref[0] = spoken
                buf.append(colorize_line(ln))

    for _round in range(30):
        if _interrupt_event.is_set():
            break

        payload = {
            "model": model,
            "instructions": system_prompt,
            "input": input_history,
            "tools": tools,
            "store": False,
            "stream": True,
        }

        # 실시간 스트리밍 처리
        text_parts: list[str] = []
        fc_items: list[dict] = []   # {call_id, name, arguments}
        got_error = False

        for ev in _iter_events(payload):
            evtype = ev["type"]
            if evtype == "_error":
                buf.append(f"[red]API 오류: {ev['message']}[/red]")
                status_ref[0] = "error"
                if line_buf.strip():
                    spoken = _normalize_worker_status_line(line_buf)
                    if spoken and last_spoken_ref is not None:
                        last_spoken_ref[0] = spoken
                    buf.append(colorize_line(line_buf))
                got_error = True
                break
            elif evtype == "response.output_text.delta":
                delta = ev.get("delta", "")
                text_parts.append(delta)
                _flush_line(delta)
            elif evtype == "response.output_item.done" and ev.get("item", {}).get("type") == "function_call":
                item = ev["item"]
                fc_items.append({
                    "call_id": item["call_id"],
                    "name":    item["name"],
                    "arguments": item["arguments"],
                })

        if got_error:
            return "\n".join(all_text_parts), 1

        round_text = "".join(text_parts)
        if round_text:
            all_text_parts.append(round_text)

        # 도구 호출 없으면 종료
        if not fc_items:
            break

        # 도구 병렬 실행
        results: dict[str, str] = {}
        with ThreadPoolExecutor(max_workers=min(len(fc_items), 8)) as pool:
            futures = {}
            for fc in fc_items:
                try:
                    parsed_args = json.loads(fc["arguments"]) if fc["arguments"] else {}
                except json.JSONDecodeError as e:
                    # JSON 파싱 실패 시 해당 tool만 에러 처리, 다른 tool은 계속
                    results[fc["call_id"]] = f"Error: invalid tool arguments JSON — {e}"
                    buf.append(f"[red]▶ {fc['name']}: JSON parse error[/red]")
                    continue
                futures[pool.submit(_execute_tool, fc["name"], parsed_args, workdir, worker_id)] = fc
            for fut in as_completed(futures):
                fc = futures[fut]
                try:
                    results[fc["call_id"]] = fut.result()
                except Exception as e:
                    results[fc["call_id"]] = f"Error: {e}"

        # call_id 순서 보장하며 히스토리 추가
        for fc in fc_items:
            result = results[fc["call_id"]]
            buf.append(f"[cyan]▶ {fc['name']}({fc['arguments'][:80]})[/cyan]")
            buf.append(f"[dim]{_osc8_linkify(result[:300].replace(chr(10), ' '))}[/dim]")
            if goal_context:
                try:
                    event_args = json.loads(fc["arguments"]) if fc["arguments"] else {}
                except Exception:
                    event_args = {}
                event = {
                    "event_type": "tool_call",
                    "iter": iteration_id,
                    "worker_id": worker_id,
                    "tool_name": fc["name"],
                    "arguments": fc["arguments"][:500],
                    "result_summary": _tool_result_summary(result),
                }
                if fc["name"] in {"shell", "shell_background"}:
                    event["command"] = str(event_args.get("command", ""))[:300]
                if fc["name"] in {"read_file", "write_file", "list_files", "data_profile"}:
                    event["path"] = str(event_args.get("path", ""))[:300]
                _append_memory_event(goal_context, event)
            input_history.append({"type": "function_call", "call_id": fc["call_id"],
                                   "name": fc["name"], "arguments": fc["arguments"]})
            input_history.append({"type": "function_call_output", "call_id": fc["call_id"],
                                   "output": result})

    # 잔여 line_buf flush
    if line_buf.strip():
        spoken = _normalize_worker_status_line(line_buf)
        if spoken and last_spoken_ref is not None:
            last_spoken_ref[0] = spoken
        buf.append(colorize_line(line_buf))

    status_ref[0] = "done"
    # ── DEBUG: worker 완료 ────────────────────────────────────────────────────
    _dbg(_wlabel, f"RUN_END    elapsed={time.time()-_wt0:.2f}s")
    # ── END DEBUG ────────────────────────────────────────────────────────────
    return "\n".join(all_text_parts), 0


def run_evaluator(prompt: str, workdir: str, model: str | None,
                  system_prompt: str | None = None,
                  output_schema: dict | None = None,
                  retry_invalid_json: bool = False) -> tuple[str, int]:
    """Evaluator: ChatGPT backend Responses API, 도구 없이 텍스트만."""
    # ── DEBUG: evaluator 시작 ─────────────────────────────────────────────────
    _dbg("EVAL", f"RUN_START  model={model or DEFAULT_EVAL_MODEL}")
    _et0 = time.time()
    # ── END DEBUG ────────────────────────────────────────────────────────────
    model = model or DEFAULT_EVAL_MODEL
    system_prompt = system_prompt or EVALUATOR_SYSTEM
    def _invoke_once(active_prompt: str) -> tuple[str, int]:
        return _run_text_completion(
            active_prompt,
            workdir,
            model,
            system_prompt=system_prompt,
            sandbox="read-only",
            output_schema=output_schema,
        )

    result, rc = _invoke_once(prompt)
    if rc == 0 and retry_invalid_json and _fast_mode_active() and _fast_evaluator_response_invalid(result):
        retry_prompt = (
            prompt
            + "\n\nIMPORTANT: Your previous response violated the required JSON contract. "
              "Return ONLY one JSON object that matches the schema. "
              "Allowed decision values: CONTINUE, IMPROVE, REDIRECT, DONE, GPU_PICK, KILL."
        )
        result, rc = _invoke_once(retry_prompt)
    if rc != 0:
        _dbg("EVAL", f"RUN_ERROR  elapsed={time.time()-_et0:.2f}s")
        return f"[Evaluator error] {result}", 1
    # ── DEBUG: evaluator 완료 ─────────────────────────────────────────────────
    _result_preview = result[:60].replace("\n", " ")
    _dbg("EVAL", f"RUN_END    elapsed={time.time()-_et0:.2f}s  result={_result_preview}")
    # ── END DEBUG ────────────────────────────────────────────────────────────
    return result, 0


def parse_decision(text: str) -> tuple[str, str]:
    m = DECISION_RE.search(text)
    if m:
        return m.group(1).upper(), (m.group(2) or "").strip()
    lower = text.lower()
    if any(w in lower for w in ['task is complete', 'fully complete', 'goal achieved', 'all done']):
        return 'DONE', ''
    # 키워드 포함 여부로 fallback (순서: DONE > REDIRECT > IMPROVE > CONTINUE)
    if 'done' in lower:
        return 'DONE', text
    if 'redirect' in lower:
        return 'REDIRECT', text
    if 'improve' in lower:
        return 'IMPROVE', text
    if 'continue' in lower:
        return 'CONTINUE', text
    return 'IMPROVE', f"(parse failed) {text[:200]}"


