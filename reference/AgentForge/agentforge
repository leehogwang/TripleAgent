def render_dual_evaluator_panel(eval_history1: list, eval_history2: list,
                                 iteration: int, phase: str, done1: bool, done2: bool) -> Panel:
    def _block(hist, label, done, active):
        if not hist:
            return f"[dim]{label}: 대기 중[/dim]"
        e = hist[-1]
        badge = {"DONE": "[green]✓[/green]", "IMPROVE": "[yellow]▲[/yellow]",
                 "REDIRECT": "[red]↩[/red]", "GPU_PICK": "[red bold]![/red bold]"
                }.get(e['decision'], "?")
        fb = e['feedback'][:45] + ("…" if len(e['feedback']) > 45 else "")
        blink = " [blink]평가 중[/blink]" if active else ""
        return f"[bold]{label}[/bold] {badge} Iter {e['iter']}: [dim]{fb}[/dim]{blink}"

    e1_active = phase in ("dual_evaluator",)
    e2_active = phase in ("dual_evaluator",)
    lines = [
        _block(eval_history1, "E1 (W1)", done1, e1_active),
        "[dim]" + "─" * 22 + "[/dim]",
        _block(eval_history2, "E2 (W2)", done2, e2_active),
    ]
    border = "green" if (done1 and done2) else "magenta"
    is_active = phase == "dual_evaluator"
    title = ("[green bold]✓ EVALUATORS[/green bold]" if done1 and done2 else
             "[magenta bold]◈ EVALUATORS ◀ 평가 중[/magenta bold]" if is_active else
             "[dim]◈ EVALUATORS[/dim]")
    return Panel(Text.from_markup("\n".join(lines)),
                 title=title, border_style=border, box=box.ROUNDED, padding=(0, 1))


