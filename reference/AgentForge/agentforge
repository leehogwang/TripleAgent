def _detect_remote() -> bool:
    """SSH 또는 tmux(서버) 환경 여부 감지."""
    if any(os.getenv(v) for v in ('SSH_CLIENT', 'SSH_TTY', 'SSH_CONNECTION')):
        return True
    # tmux 안에서 실행 중이면서 DISPLAY/WAYLAND_DISPLAY가 없으면 원격 서버로 판정
    if os.getenv('TMUX') and not os.getenv('DISPLAY') and not os.getenv('WAYLAND_DISPLAY'):
        return True
    return False
