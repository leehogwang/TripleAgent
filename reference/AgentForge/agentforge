def _canonicalize_evaluator_decision(value: object) -> str:
    text = str(value or "").strip()
    if not text:
        return ""
    upper = text.upper().replace("-", "_").replace(" ", "_")
    return _EVALUATOR_DECISION_ALIASES.get(upper, upper)


def _fast_evaluator_response_invalid(text: str) -> bool:
    raw = _extract_json_object(text)
    if not isinstance(raw, dict):
        return True
    decision = _canonicalize_evaluator_decision(raw.get("decision", ""))
    if decision not in _FAST_EVALUATOR_DECISIONS:
        return True
    summary = raw.get("summary")
    if summary is None:
        return True
    return not isinstance(summary, (dict, str))


def _build_codex_exec_command(
    prompt: str,
    workdir: str,
    model: str,
    *,
    system_prompt: str | None = None,
    search: bool = False,
    sandbox: str = "workspace-write",
    output_schema_path: str | None = None,
) -> tuple[list[str], str]:
    combined_prompt = _compose_codex_exec_prompt(system_prompt, prompt)
    cmd = [str(_get_codex_bin() or _CODEX_BIN_HINT)]
    if search:
        cmd.append("--search")
    cmd += [
        "exec",
        "--json",
        "--ephemeral",
        "--skip-git-repo-check",
        "--cd",
        workdir,
        "--color",
        "never",
        "-m",
        model,
    ]
    cmd += _codex_exec_sandbox_args(sandbox)
    if output_schema_path:
        cmd += ["--output-schema", output_schema_path]
    cmd += ["-c", 'service_tier="fast"', "-c", "features.fast_mode=true", "-"]
    return cmd, combined_prompt


def _iter_codex_exec_events(
    prompt: str,
    workdir: str,
    model: str,
    *,
    system_prompt: str | None = None,
    search: bool = False,
    sandbox: str = "workspace-write",
    output_schema: dict | None = None,
):
    codex_bin = _get_codex_bin()
    if codex_bin is None:
        yield {"type": "_error", "message": f"codex not found at {_codex_display_path()}"}
        return

    schema_path: str | None = None
    if output_schema is not None:
        with tempfile.NamedTemporaryFile("w", encoding="utf-8", suffix=".json", delete=False) as schema_file:
            json.dump(output_schema, schema_file, ensure_ascii=False)
            schema_path = schema_file.name

    cmd, combined_prompt = _build_codex_exec_command(
        prompt,
        workdir,
        model,
        system_prompt=system_prompt,
        search=search,
        sandbox=sandbox,
        output_schema_path=schema_path,
    )
    proc: subprocess.Popen | None = None
    event_q: queue.Queue = queue.Queue()
    stderr_lines: list[str] = []
    stdout_done = False
    stderr_done = False

    def _pump_stream(kind: str, stream) -> None:
        try:
            for raw in stream:
                event_q.put((kind, raw))
        finally:
            event_q.put((f"{kind}_done", None))

    try:
        proc = subprocess.Popen(
            cmd,
            cwd=workdir,
            stdin=subprocess.PIPE,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            bufsize=1,
            start_new_session=True,
        )
        with _active_procs_lock:
            _active_procs.add(proc)

        stdout_thread = threading.Thread(
            target=_pump_stream, args=("stdout", proc.stdout), daemon=True
        )
        stderr_thread = threading.Thread(
            target=_pump_stream, args=("stderr", proc.stderr), daemon=True
        )
        stdout_thread.start()
        stderr_thread.start()

        if proc.stdin is not None:
            proc.stdin.write(combined_prompt)
            if not combined_prompt.endswith("\n"):
                proc.stdin.write("\n")
            proc.stdin.close()

        while True:
            if _interrupt_event.is_set():
                _terminate_child_process(proc)
            if stdout_done and proc.poll() is not None:
                break
            try:
                kind, raw = event_q.get(timeout=0.1)
            except queue.Empty:
                continue
            if kind == "stdout":
                line = (raw or "").strip()
                if not line:
                    continue
                try:
                    yield json.loads(line)
                except Exception:
                    stderr_lines.append(f"stdout(non-json): {line}")
            elif kind == "stderr":
                line = (raw or "").strip()
                if line:
                    stderr_lines.append(line)
            elif kind == "stdout_done":
                stdout_done = True
            elif kind == "stderr_done":
                stderr_done = True

        try:
            returncode = proc.wait(timeout=5)
        except subprocess.TimeoutExpired:
            _terminate_child_process(proc)
            returncode = proc.returncode or 1

        if returncode != 0 and not _interrupt_event.is_set():
            detail = stderr_lines[-1] if stderr_lines else f"codex exec exited with code {returncode}"
            yield {"type": "_error", "message": detail}
    except Exception as e:
        yield {"type": "_error", "message": str(e)}
    finally:
        if proc is not None:
            _terminate_child_process(proc)
            with _active_procs_lock:
                _active_procs.discard(proc)
        if schema_path:
            Path(schema_path).unlink(missing_ok=True)
        while not stderr_done:
            try:
                kind, raw = event_q.get_nowait()
            except queue.Empty:
                break
            if kind == "stderr":
                line = (raw or "").strip()
                if line:
                    stderr_lines.append(line)
            elif kind == "stderr_done":
                stderr_done = True


def _run_text_completion(
    prompt: str,
    workdir: str,
    model: str,
    *,
    system_prompt: str | None = None,
    search: bool = False,
    sandbox: str = "read-only",
    output_schema: dict | None = None,
) -> tuple[str, int]:
    if _fast_mode_active():
        parts: list[str] = []
        fast_failed = False
        for ev in _iter_codex_exec_events(
            prompt,
            workdir,
            model,
            system_prompt=system_prompt,
            search=search,
            sandbox=sandbox,
            output_schema=output_schema,
        ):
            if ev.get("type") == "_error":
                reason = ev.get('message', 'unknown error')
                _force_disable_fast_mode(reason)
                fast_failed = True
                _dbg("FAST", f"TEXT_FALLBACK  reason={reason}")
                break
            if ev.get("type") != "item.completed":
                continue
            item = ev.get("item") or {}
            if item.get("type") == "agent_message":
                text = str(item.get("text") or "").strip()
                if text:
                    parts.append(text)
        if not fast_failed:
            return "\n\n".join(parts).strip(), 0

    payload = {
        "model": model,
        "instructions": system_prompt or "",
        "input": [{"role": "user", "content": prompt}],
        "store": False,
        "stream": True,
    }
    parts: list[str] = []
    gen = _iter_events(payload)
    try:
        for ev in gen:
            if ev.get("type") == "_error":
                return f"[Backend error] {ev.get('message', 'unknown error')}", 1
            if ev.get("type") == "response.output_text.delta":
                parts.append(ev.get("delta", ""))
    finally:
        gen.close()
    return "".join(parts).strip(), 0


