def _latest_eval_meta(history: list | None) -> dict:
    if not history:
        return {}
    for item in reversed(history):
        if item.get("type") == "compressed_summary":
            continue
        meta = item.get("eval_meta")
        if isinstance(meta, dict):
            return meta
    return {}


def _detect_task_profile(goal: str, mode: str = "code", history: list | None = None) -> dict:
    goal_text = goal or ""
    combined = goal_text.lower()
    last_meta = _latest_eval_meta(history)

    is_research = mode == "research"
    is_ml = bool(TASK_ML_RE.search(combined))
    needs_search = is_research or bool(TASK_RESEARCH_RE.search(combined)) or bool(last_meta.get("needs_search"))
    needs_long_run = bool(TASK_LONG_RUN_RE.search(combined)) or is_ml or bool(last_meta.get("needs_long_run_monitor"))

    labels = ["base", "generalization", "paths"]
    if needs_search:
        labels.append("search")
    if needs_long_run:
        labels.append("long_run")
    if is_ml:
        labels.append("ml")
    if is_research:
        labels.append("research_mode")

    return {
        "mode": mode,
        "is_ml": is_ml,
        "needs_search": needs_search,
        "needs_long_run_monitor": needs_long_run,
        "labels": labels,
    }


def _compose_worker_system(profile: dict) -> str:
    sections = [
        WORKER_BASE_POLICY,
        WORKER_AUTONOMY_POLICY,
        WORKER_GENERALIZATION_POLICY,
        WORKER_PATH_POLICY,
        WORKER_BASELINE_POLICY,
    ]
    if profile.get("needs_search"):
        sections.append(WORKER_WEB_POLICY)
    if profile.get("needs_long_run_monitor"):
        sections.append(WORKER_LONG_RUN_POLICY)
    if profile.get("is_ml"):
        sections.append(WORKER_ML_POLICY)
    if profile.get("mode") == "research":
        sections.append(WORKER_RESEARCH_MODE_POLICY)
    return "\n\n".join(section for section in sections if section).strip()


def _compose_evaluator_system(profile: dict, monitor: bool = False) -> str:
    sections = [
        EVALUATOR_BASE_POLICY,
        EVALUATOR_EVIDENCE_POLICY,
        EVALUATOR_GENERALIZATION_POLICY,
        EVALUATOR_SIMPLICITY_POLICY,
        EVALUATOR_JSON_POLICY,
    ]
    if profile.get("needs_search"):
        sections.append(EVALUATOR_RESEARCH_POLICY)
    if profile.get("is_ml") or profile.get("needs_long_run_monitor"):
        sections.append(EVALUATOR_ML_POLICY)
    if monitor:
        sections.append(MONITOR_JSON_POLICY)
    return "\n\n".join(section for section in sections if section).strip()


