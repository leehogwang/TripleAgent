def _persist_session(session: dict) -> None:
    """세션을 디스크에 저장. worker_lines는 TUI 표시용이라 제외."""
    try:
        def _slim(hist):
            return [{k: v for k, v in h.items() if k != 'worker_lines'} for h in hist]
        data = dict(session)
        if session.get("mode") == "dual":
            data['history1'] = _slim(session.get('history1', []))
            data['history2'] = _slim(session.get('history2', []))
        else:
            data['history'] = _slim(session.get('history', []))
        data['saved_at'] = time.strftime("%Y-%m-%dT%H:%M:%S")
        data['session_key'] = _SESSION_CTX.key if _SESSION_CTX is not None else "legacy"
        data['fast_mode'] = _fast_mode_requested()
        _write_json_atomic(_current_session_file(), data)
    except Exception:
        pass


def _load_persisted_session() -> dict | None:
    """디스크에서 세션 로드. 실패 시 None."""
    try:
        path = _current_session_file()
        if not path.exists():
            if LEGACY_SESSION_FILE.exists():
                path = LEGACY_SESSION_FILE
            else:
                return None
        data = json.loads(path.read_text())
        # worker_lines 누락된 항목 복원
        if data.get("mode") == "dual":
            for key in ('history1', 'history2'):
                for h in data.get(key, []):
                    h.setdefault('worker_lines', [])
        else:
            for h in data.get('history', []):
                h.setdefault('worker_lines', [])
        return data
    except Exception:
        return None


