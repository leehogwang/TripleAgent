{
  "name": "triple-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Three-panel auth-backed CLI for Codex, Claude, and Gemini.",
  "bin": {
    "tripleagent": "./bin/tripleagent.js"
  },
  "scripts": {
    "bootstrap:node22": "bash scripts/ensure-node22.sh",
    "npm22": "bash scripts/npm22.sh",
    "build": "bash scripts/node22.sh ./node_modules/typescript/bin/tsc -p tsconfig.json",
    "check": "bash scripts/node22.sh ./node_modules/typescript/bin/tsc --noEmit -p tsconfig.json",
    "dev": "bash scripts/node22.sh ./node_modules/tsx/dist/cli.mjs src/index.ts",
    "claw-dev": "bash scripts/node22.sh Leonxlnx-claude-code/claw-dev-launcher.js",
    "proxy:compat": "bash scripts/node22.sh ./node_modules/tsx/dist/cli.mjs src/anthropicCompatProxy.ts",
    "proxy:gemini": "bash scripts/node22.sh ./node_modules/tsx/dist/cli.mjs src/anthropicCompatProxy.ts",
    "start": "bash scripts/node22.sh dist/index.js",
    "triple-agent": "bash scripts/node22.sh ./node_modules/tsx/dist/cli.mjs src/index.ts",
    "dry-run:triple": "bash scripts/node22.sh ./node_modules/tsx/dist/cli.mjs src/index.ts dry-run"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.58.0",
    "@google/genai": "^1.29.0",
    "dotenv": "^17.2.3",
    "ink": "^6.8.0",
    "ink-text-input": "^6.0.0",
    "picocolors": "^1.1.1",
    "react": "^19.2.4",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/react": "^19.2.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  },
  "files": [
    "bin/",
    "dist/",
    "src/",
    "scripts/",
    "shared/",
    "Leonxlnx-claude-code/",
    "README.md",
    "package.json"
  ]
}
